---
/**
 * Contact Page
 *
 * Structure:
 *   1. Hero section — background image + overlay, title + description
 *   2. Contact info + form — two-column layout (info left, form right)
 *   3. CTA section — reusable call-to-action
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/sections/CTASection.astro";
import TestimonialShowcase from "../components/sections/TestimonialShowcase.astro";
import Section from "../components/ui/Section.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Visual from "../components/ui/Visual.astro";
import HoneyBookEmbed from "../components/ui/HoneyBookEmbed.astro";
import { getTestimonialByName } from "../sanity/lib/testimonials";
import { getDraftModeProps } from "../sanity/lib/draft-mode";
import Button from "../components/ui/Button.astro";
import { SITE } from "../config/site";

import "../styles/pages/contact.css";

import contactHero from "../assets/contact/contact-hero-2.webp";
import happensNextImg from "../assets/contact/contact-happens-next-1.webp";

const draftProps = getDraftModeProps(Astro);
const [patrick, tom] = await Promise.all([
  getTestimonialByName("Patrick Payne", draftProps),
  getTestimonialByName("Tom Connally", draftProps),
]);
const contactTestimonials = [patrick, tom].filter(
  (t): t is NonNullable<typeof t> => !!t,
);
---

<BaseLayout
  title="Contact | CL Creative"
  description="Get in touch with CL Creative. Book a free strategy meeting to discuss your next web design, development, or SEO project."
>
  {
    /* ================================================================
      HERO — background image + overlay + centered text
      ================================================================ */
  }
  <Section paddingBottom="small" class="contact_hero_wrap">
    <Layout
      data-prevent-flicker="true"
      data-fade-list
      variant="columns"
      verticalAlign="center"
    >
      <Col slot="col1">
        <Heading tag="h1" variant="eyebrow"> Contact us </Heading>
        <Heading variant="h1"> Send Me a Quick Note </Heading>
        <Text>
          Have a question or not ready to book a strategy call yet? No problem.
          Send me a note about what's going on, and I'll get back to you within
          one business day.
        </Text>
      </Col>
      <Visual
        slot="col2"
        src={contactHero}
        alt="Person working on a laptop"
        ratio="landscape"
      />
    </Layout>
  </Section>

  {
    /* ================================================================
      CONTACT INFO + FORM — two-column layout
      ================================================================ */
  }
  <Section theme="dark">
    <Layout variant="columns" verticalAlign="start">
      <Col slot="col1">
        <Heading data-prevent-flicker="true" data-split-text
          >What to Expect After You Send</Heading
        >
        <Text data-prevent-flicker="true" data-fade-up>
          I read every message personally.
        </Text>
        <Text data-prevent-flicker="true" data-fade-up
          >You'll hear back from me within one business day, usually sooner,
          with thoughts on whether I can help and what your next step might be.</Text
        >

        <div
          data-prevent-flicker="true"
          data-fade-list
          class="contact_info_wrap"
        >
          <a
            href={`mailto:${SITE.email}`}
            class="contact_info_link is-underline"
          >
            <div class="contact_info_item">
              <div class="contact_info_icon u-icon-24">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <rect
                    x="2"
                    y="4"
                    width="20"
                    height="16"
                    rx="2"
                    stroke="currentColor"
                    stroke-width="var(--border-width-main)"
                    stroke-linecap="round"
                    stroke-linejoin="round"></rect>
                  <path
                    d="M2 7L10.165 12.593C10.6834 12.9515 11.3343 13.1436 12 13.1436C12.6657 13.1436 13.3166 12.9515 13.835 12.593L22 7"
                    stroke="currentColor"
                    stroke-width="var(--border-width-main)"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <span class="contact_info_text">{SITE.email}</span>
            </div>
          </a>

          <a href={`tel:${SITE.phone.tel}`} class="contact_info_link">
            <div class="contact_info_item">
              <div class="contact_info_icon u-icon-24">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M8.38028 8.85335C9.07627 10.303 10.0251 11.6616 11.2266 12.8632C12.4282 14.0648 13.7869 15.0136 15.2365 15.7096C15.3612 15.7694 15.4235 15.7994 15.5024 15.8224C15.7828 15.9041 16.127 15.8454 16.3644 15.6754C16.4313 15.6275 16.4884 15.5704 16.6027 15.4561C16.9523 15.1064 17.1271 14.9316 17.3029 14.8174C17.9658 14.3864 18.8204 14.3864 19.4833 14.8174C19.6591 14.9316 19.8339 15.1064 20.1835 15.4561L20.3783 15.6509C20.9098 16.1824 21.1755 16.4481 21.3198 16.7335C21.6069 17.301 21.6069 17.9713 21.3198 18.5389C21.1755 18.8242 20.9098 19.09 20.3783 19.6214L20.2207 19.779C19.6911 20.3087 19.4263 20.5735 19.0662 20.7757C18.6667 21.0001 18.0462 21.1615 17.588 21.1601C17.1751 21.1589 16.8928 21.0788 16.3284 20.9186C13.295 20.0576 10.4326 18.4332 8.04466 16.0452C5.65668 13.6572 4.03221 10.7948 3.17124 7.76144C3.01103 7.19699 2.93092 6.91477 2.9297 6.50182C2.92833 6.0436 3.08969 5.42311 3.31411 5.0236C3.51636 4.66357 3.78117 4.39876 4.3108 3.86913L4.46843 3.7115C4.99987 3.18006 5.2656 2.91433 5.55098 2.76999C6.11854 2.48292 6.7888 2.48292 7.35636 2.76999C7.64174 2.91433 7.90747 3.18006 8.43891 3.7115L8.63378 3.90637C8.98338 4.25597 9.15819 4.43078 9.27247 4.60655C9.70347 5.26945 9.70347 6.12403 9.27247 6.78692C9.15819 6.96269 8.98338 7.1375 8.63378 7.4871C8.51947 7.60142 8.46231 7.65857 8.41447 7.72538C8.24446 7.96281 8.18576 8.30707 8.26748 8.58743C8.29048 8.66632 8.32041 8.72866 8.38028 8.85335Z"
                    stroke="currentColor"
                    stroke-width="var(--border-width-main)"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <span class="contact_info_text">{SITE.phone.display}</span>
            </div>
          </a>

          <div class="contact_info_item">
            <div class="contact_info_icon u-icon-24">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="100%"
                height="100%"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <circle
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="var(--border-width-main)"
                  stroke-linecap="round"
                  stroke-linejoin="round"></circle>
                <path
                  d="M12 6V12L16 14"
                  stroke="currentColor"
                  stroke-width="var(--border-width-main)"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
            <span class="contact_info_text">M–F, 9 AM–5 PM CST</span>
          </div>
        </div>
      </Col>

      <HoneyBookEmbed
        data-prevent-flicker="true"
        data-fade-in
        slot="col2"
        class="contact_form_wrap"
      />
    </Layout>
  </Section>

  {
    /* ================================================================
      TESTIMONIALS
      ================================================================ */
  }
  <TestimonialShowcase paddingTop="small" testimonials={contactTestimonials} />

  {
    /* ================================================================
      BOOK A STRATEGY CALL INSTEAD
      ================================================================ */
  }
  <Section theme="brand" padding="small">
    <Layout variant="stack">
      <Col slot="col1">
        <Heading tag="h2" variant="h3"> Ready to Pick a Time Instead? </Heading>
        <Text
          >If you'd rather just book a free 30-minute strategy call, you can
          pick a time on my calendar here.</Text
        >
        <Button href="/book-a-call" arialabel="Book a Strategy Call"
          >Book a Strategy Call</Button
        >
      </Col>
    </Layout>
  </Section>
</BaseLayout>
