---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Visual from "../components/ui/Visual.astro";
import { SITE } from "../config/site";

import m2mWorkbookImg from "../assets/m2m-framework/m2m-workbook.avif";
---

<BaseLayout
  title="Check Your Inbox | CL Creative"
  description="Your ICP Discovery Worksheet is on its way."
  theme="light"
>
  <Section>
    <Layout variant="columns-reversed" verticalAlign="center">
      <Col slot="col1">
        <Heading tag="h1" variant="h1">Check Your Inbox</Heading>
        <Heading maxWidth="40ch" tag="p" variant="h4">
          Your ICP Discovery Worksheet is on its way.
        </Heading>
        <Text variant="large">
          The email should land in the next minute or two. Inside you'll find a
          link to duplicate the worksheet into your own Notion workspace — yours
          to fill out, save, and keep.
        </Text>
        <Text variant="large">
          If you don't see it in 5-10 minutes, check your spam or promotions
          folder. And if it's still missing, just email <a
            href={`mailto:${SITE.email}`}
            class="u-text-style-underline">{SITE.email}</a
          > and I'll sort it out.
        </Text>
      </Col>
      <Visual
        slot="col2"
        src={m2mWorkbookImg}
        alt="M2M Workbook cover"
        ratio="square"
        radius="large"
      />
    </Layout>
  </Section>
</BaseLayout>
