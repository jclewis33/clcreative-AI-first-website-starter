<script>
  /**
   * Style-guide sidebar nav: auto-toggle sub-lists based on which section
   * is currently visible in the viewport, plus smooth-scroll with custom easing.
   * Uses GSAP for sub-list expand/collapse (same technique as Accordion component).
   */
  function initNavToggle() {
    const gsap = (window as any).gsap;
    const sections = document.querySelectorAll<HTMLElement>(
      ".styleguide_section",
    );
    const allNavLinks = document.querySelectorAll<HTMLAnchorElement>(
      ".styleguide_nav .styleguide_nav_link",
    );
    const parentNavLinks = document.querySelectorAll<HTMLAnchorElement>(
      ".styleguide_nav_list > li > .styleguide_nav_link",
    );

    // ── Smooth scroll — native browser behavior with header offset ──
    function scrollToSection(targetId: string) {
      const target = document.getElementById(targetId);
      if (!target) return;

      // Resolve --nav-height-total + 1.5rem (matches CSS scroll-margin-top)
      const probe = document.createElement("div");
      probe.style.height = "calc(var(--nav-height-total) + 1.5rem)";
      probe.style.position = "absolute";
      probe.style.visibility = "hidden";
      document.body.appendChild(probe);
      const headerOffset = probe.offsetHeight;
      document.body.removeChild(probe);

      const elementPosition =
        target.getBoundingClientRect().top + window.scrollY;
      const offsetPosition = elementPosition - headerOffset;

      window.scrollTo({ top: offsetPosition, behavior: "smooth" });
    }

    // Intercept all nav link clicks for smooth scrolling
    allNavLinks.forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");
        if (!href?.startsWith("#")) return;
        const targetId = href.slice(1);
        if (!document.getElementById(targetId)) return;
        e.preventDefault();
        history.pushState(null, "", `#${targetId}`);
        // Slight delay lets GSAP toggle / layout settle before measuring
        setTimeout(() => scrollToSection(targetId), 20);
      });
    });

    // ── GSAP timelines for sub-list expand/collapse (Accordion pattern) ──
    type NavEntry = {
      link: HTMLAnchorElement;
      subList: HTMLUListElement | null;
      timeline: any | null;
    };

    const sectionMap = new Map<string, NavEntry>();

    parentNavLinks.forEach((link) => {
      const href = link.getAttribute("href");
      if (!href) return;
      const id = href.replace("#", "");
      const subList = link.nextElementSibling as HTMLUListElement | null;

      let timeline: any = null;

      if (subList && gsap) {
        timeline = gsap.timeline({
          paused: true,
          defaults: { duration: 0.3, ease: "power1.inOut" },
        });
        timeline.set(subList, { display: "flex" });
        timeline.fromTo(subList, { height: 0 }, { height: "auto" });
      }

      sectionMap.set(id, { link, subList, timeline });
    });

    // ── Expand / collapse helpers ──
    function openSection(entry: NavEntry) {
      entry.link.classList.add("is-active");
      if (entry.timeline) {
        entry.timeline.play();
      } else if (entry.subList) {
        entry.subList.classList.add("is-open");
      }
    }

    function closeSection(entry: NavEntry) {
      entry.link.classList.remove("is-active");
      if (entry.timeline) {
        entry.timeline.reverse();
      } else if (entry.subList) {
        entry.subList.classList.remove("is-open");
      }
    }

    // ── Section toggle via IntersectionObserver ──
    const visibleSections = new Set<string>();
    let currentActive = "";

    function updateActiveSection() {
      let bestId = "";
      let bestDistance = Infinity;

      visibleSections.forEach((id) => {
        const el = document.getElementById(id);
        if (!el) return;
        const distance = Math.abs(el.getBoundingClientRect().top);
        if (distance < bestDistance) {
          bestDistance = distance;
          bestId = id;
        }
      });

      if (!bestId && !visibleSections.size) {
        sectionMap.forEach((item) => closeSection(item));
        currentActive = "";
        return;
      }

      if (!bestId || bestId === currentActive) return;

      currentActive = bestId;
      sectionMap.forEach((item, key) => {
        if (key === bestId) {
          openSection(item);
        } else {
          closeSection(item);
        }
      });
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id;
          if (entry.isIntersecting) {
            visibleSections.add(id);
          } else {
            visibleSections.delete(id);
          }
        });
        updateActiveSection();
      },
      {
        rootMargin: "0px 0px -20% 0px",
        threshold: 0,
      },
    );

    sections.forEach((section) => observer.observe(section));
  }

  document.addEventListener("DOMContentLoaded", initNavToggle);
</script>
