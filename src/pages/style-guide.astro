---
/**
 * Style Guide — a living reference for all utility classes, typography,
 * colour themes, spacing, layout, and UI components in this design system.
 *
 * Visit /style-guide to view it.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Layout from "../components/ui/Layout.astro";
import Grid from "../components/ui/Grid.astro";
import Card from "../components/ui/Card.astro";
import Accordion from "../components/ui/Accordion.astro";
import AccordionItem from "../components/ui/AccordionItem.astro";
import Modal from "../components/ui/Modal.astro";
import Slider from "../components/ui/Slider.astro";
import Button from "../components/ui/Button.astro";

import "../styles/pages/style-guide.css";
---

<BaseLayout
  title="Style Guide | Design System"
  description="A living reference for all utility classes, typography, colour themes, spacing, layout, and UI components."
>
  <!-- ===== PAGE HEADER ===== -->
  <Section paddingTop="page-top" paddingBottom="small">
    <div class="styleguide_page_header">
      <p class="u-text-style-eyebrow u-margin-bottom-2">Design System</p>
      <Heading tag="h1" variant="display-lg">Style Guide</Heading>
      <p class="u-text-style-large u-text-style-muted u-margin-top-3">
        A living reference for all utility classes, typography, colour themes,
        spacing, layout, and UI components.
      </p>
    </div>
  </Section>

  <!-- ===== LAYOUT: SIDEBAR + CONTENT ===== -->
  <Section padding="none" paddingBottom="large">
    <div class="styleguide_layout">
      <!-- ── SIDEBAR NAV ── -->
      <nav class="styleguide_nav" aria-label="Style guide sections">
        <div class="styleguide_nav_card">
          <p class="styleguide_nav_title">Sections</p>
          <ul class="styleguide_nav_list">
            <li>
              <a class="styleguide_nav_link" href="#typography">Typography</a>
              <ul class="styleguide_nav_sub">
                <li>
                  <a class="styleguide_nav_link" href="#type-headings"
                    >Headings</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#type-display">Display</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#type-text">Text Sizes</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#type-styles"
                    >Text Styles</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#type-align">Alignment</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#type-clamp"
                    >Line Clamp</a
                  >
                </li>
              </ul>
            </li>
            <li>
              <a class="styleguide_nav_link" href="#color">Color</a>
              <ul class="styleguide_nav_sub">
                <li>
                  <a class="styleguide_nav_link" href="#color-brand"
                    >Brand Colors</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#color-themes">Themes</a>
                </li>
              </ul>
            </li>
            <li>
              <a class="styleguide_nav_link" href="#buttons">Buttons</a>
              <ul class="styleguide_nav_sub">
                <li>
                  <a class="styleguide_nav_link" href="#btn-primary">Primary</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#btn-secondary"
                    >Secondary</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#btn-themes">By Theme</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#btn-icon"
                    >Icon / Arrow</a
                  >
                </li>
              </ul>
            </li>
            <li>
              <a class="styleguide_nav_link" href="#spacing">Spacing</a>
              <ul class="styleguide_nav_sub">
                <li>
                  <a class="styleguide_nav_link" href="#spacing-scale">Scale</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#spacing-radius"
                    >Radius</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#spacing-ratio"
                    >Aspect Ratios</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#spacing-shadows"
                    >Shadows</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#spacing-padding"
                    >Padding</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#spacing-margin"
                    >Margin</a
                  >
                </li>
              </ul>
            </li>
            <li>
              <a class="styleguide_nav_link" href="#layout">Layout</a>
              <ul class="styleguide_nav_sub">
                <li>
                  <a class="styleguide_nav_link" href="#layout-containers"
                    >Containers</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#layout-flex">Flexbox</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#layout-grid">Grid</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#layout-gap">Gap</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#layout-component"
                    >Layout Component</a
                  >
                </li>
              </ul>
            </li>
            <li>
              <a class="styleguide_nav_link" href="#misc">Misc Utilities</a>
              <ul class="styleguide_nav_sub">
                <li>
                  <a class="styleguide_nav_link" href="#misc-display">Display</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#misc-overflow"
                    >Overflow</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#misc-dimensions"
                    >Dimensions</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#misc-objectfit"
                    >Object Fit</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#misc-button-wrappers"
                    >Button Wrappers</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#misc-responsive"
                    >Responsive</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#misc-icons">Icons</a>
                </li>
              </ul>
            </li>
            <li>
              <a class="styleguide_nav_link" href="#components">Components</a>
              <ul class="styleguide_nav_sub">
                <li>
                  <a class="styleguide_nav_link" href="#comp-section">Section</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#comp-card">Card</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#comp-accordion"
                    >Accordion</a
                  >
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#comp-modal">Modal</a>
                </li>
                <li>
                  <a class="styleguide_nav_link" href="#comp-slider">Slider</a>
                </li>
              </ul>
            </li>
          </ul>
        </div>
      </nav>

      <!-- ── MAIN CONTENT ── -->
      <div class="styleguide_content">
        <!-- ================================================
             TYPOGRAPHY
             ================================================ -->
        <section id="typography" class="styleguide_section">
          <h2 class="styleguide_section_title">Typography</h2>

          <!-- Semantic Headings -->
          <div id="type-headings">
            <h3 class="styleguide_subsection_title">Semantic Headings</h3>

            {
              [1, 2, 3, 4, 5, 6].map((n) => (
                <div class="styleguide_card_wrap">
                  <div class="tag_wrap">{`<h${n}> / .u-text-style-h${n}`}</div>
                  <div class={`u-text-style-h${n}`}>
                    {n === 1 && "Heading One — The Quick Brown Fox"}
                    {n === 2 && "Heading Two — The Quick Brown Fox"}
                    {n === 3 && "Heading Three — The Quick Brown Fox"}
                    {n === 4 && "Heading Four — The Quick Brown Fox"}
                    {n === 5 && "Heading Five — The Quick Brown Fox"}
                    {n === 6 && "Heading Six — The Quick Brown Fox"}
                  </div>
                </div>
              ))
            }

            <div class="styleguide_card_wrap">
              <div class="tag_wrap">.u-text-style-eyebrow</div>
              <div class="u-text-style-eyebrow">Eyebrow Label</div>
            </div>
          </div>

          <!-- Display Headings -->
          <div id="type-display">
            <h3 class="styleguide_subsection_title">Display Headings</h3>

            {
              ["display-xl", "display-lg", "display-md", "display-sm"].map(
                (v) => (
                  <div class="styleguide_card_wrap">
                    <div class="tag_wrap">{`.u-${v}`}</div>
                    <div class={`u-${v}`}>
                      Display — {v.replace("display-", "").toUpperCase()}
                    </div>
                  </div>
                ),
              )
            }
          </div>

          <!-- Text Sizes -->
          <div id="type-text">
            <h3 class="styleguide_subsection_title">Text Sizes</h3>

            {
              [
                "xlarge",
                "large",
                "regular",
                "small",
                "tiny",
              ].map((s) => (
                <div class="styleguide_card_wrap is-row">
                  <span class="tag_wrap">{`.u-text-style-${s}`}</span>
                  <span class={`u-text-style-${s}`}>
                    The quick brown fox jumps over the lazy dog
                  </span>
                </div>
              ))
            }
          </div>

          <!-- Text Styles -->
          <div id="type-styles">
            <h3 class="styleguide_subsection_title">
              Text Styles &amp; Modifiers
            </h3>

            <div class="styleguide_card_wrap">
              {
                [
                  { cls: "u-text-style-bold", label: "Bold text" },
                  { cls: "u-text-style-italic", label: "Italic text" },
                  {
                    cls: "u-text-style-strikethrough",
                    label: "Strikethrough text",
                  },
                  {
                    cls: "u-text-style-muted",
                    label: "Muted text (0.75 opacity)",
                  },
                  {
                    cls: "u-text-transform-capitalize",
                    label: "Capitalize text",
                  },
                  { cls: "u-text-style-nowrap", label: "No-wrap text" },
                  { cls: "u-weight-regular", label: "Weight regular (400)" },
                  { cls: "u-weight-medium", label: "Weight medium (500)" },
                  { cls: "u-weight-bold", label: "Weight bold (700)" },
                  { cls: "u-gradient-text", label: "Gradient text" },
                ].map(({ cls, label }) => (
                  <div
                    class="u-flex u-align-center u-gap-3"
                    style="margin-bottom:0.5rem"
                  >
                    <span class="tag_wrap">{`.${cls}`}</span>
                    <span class={cls}>{label}</span>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">Line Height</h3>
            <div class="styleguide_card_wrap">
              {
                [
                  { cls: "u-line-height-small", label: "small (1)" },
                  { cls: "u-line-height-medium", label: "medium (1.1)" },
                  { cls: "u-line-height-large", label: "large (1.3)" },
                  { cls: "u-line-height-huge", label: "huge (1.5)" },
                ].map(({ cls, label }) => (
                  <div style="margin-bottom:var(--space-5)">
                    <span
                      class="tag_wrap"
                      style="margin-bottom:var(--space-2); display:inline-flex"
                    >
                      {`.${cls}`} — {label}
                    </span>
                    <p
                      class={`u-text-style-regular ${cls} u-max-width-small`}
                      style="background:var(--background); padding:var(--space-3); border-radius:var(--radius-small); border:1px solid var(--border)"
                    >
                      The quick brown fox jumps over the lazy dog. Pack my box
                      with five dozen liquor jugs. How vexingly quick daft
                      zebras jump.
                    </p>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">Letter Spacing</h3>
            <div class="styleguide_card_wrap">
              {
                [
                  { cls: "u-letter-spacing-tight", label: "tight (-0.03em)" },
                  { cls: "u-letter-spacing-normal", label: "normal (0em)" },
                ].map(({ cls, label }) => (
                  <div style="margin-bottom:var(--space-4)">
                    <span
                      class="tag_wrap"
                      style="margin-bottom:var(--space-2); display:inline-flex"
                    >
                      {`.${cls}`} — {label}
                    </span>
                    <p class={`u-text-style-h2 ${cls}`}>
                      The Quick Brown Fox Jumps
                    </p>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">Text Wrap</h3>
            <div class="u-grid-3" style="gap:var(--space-3)">
              {
                [
                  { cls: "u-text-wrap-default", label: "wrap (default)" },
                  { cls: "u-text-wrap-balance", label: "balance" },
                  { cls: "u-text-wrap-pretty", label: "pretty" },
                ].map(({ cls, label }) => (
                  <div class="styleguide_card_wrap">
                    <span class="tag_wrap">
                      {`.${cls}`} — {label}
                    </span>
                    <p class={`u-text-style-h4 ${cls}`}>
                      A fairly long heading that wraps across multiple lines to
                      show the effect
                    </p>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Text Alignment -->
          <div id="type-align">
            <h3 class="styleguide_subsection_title">Text Alignment</h3>
            <div class="styleguide_card_wrap">
              {
                [
                  { cls: "u-text-align-left", label: "Left aligned text" },
                  { cls: "u-text-align-center", label: "Center aligned text" },
                  { cls: "u-text-align-right", label: "Right aligned text" },
                ].map(({ cls, label }) => (
                  <div
                    class="u-flex u-align-center u-gap-3"
                    style="margin-bottom:0.5rem"
                  >
                    <span class="tag_wrap">{`.${cls}`}</span>
                    <span class={`u-width-full ${cls}`} style="max-width:16rem">
                      {label}
                    </span>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Line Clamp -->
          <div id="type-clamp">
            <h3 class="styleguide_subsection_title">Line Clamp</h3>
            <div class="styleguide_card_wrap">
              {
                [1, 2, 3, 4, 5].map((n) => (
                  <div
                    class="u-flex u-align-start u-gap-3"
                    style="margin-bottom:0.75rem"
                  >
                    <span
                      class="tag_wrap"
                      style="flex-shrink:0"
                    >{`.u-line-clamp-${n}`}</span>
                    <p class={`u-line-clamp-${n}`} style="max-width:28rem">
                      The quick brown fox jumps over the lazy dog. Pack my box
                      with five dozen liquor jugs. How vexingly quick daft
                      zebras jump! The five boxing wizards jump quickly.
                    </p>
                  </div>
                ))
              }
            </div>
          </div>

          <!-- Heading Accent -->
          <div>
            <h3 class="styleguide_subsection_title">Heading Accent</h3>
            <div class="styleguide_card_wrap">
              <div class="tag_wrap">
                .u-heading-accent (wraps strong in accent color)
              </div>
              <p class="u-text-style-h3 u-heading-accent">
                Your website should <strong>convert</strong>, not just impress.
              </p>
            </div>
          </div>
        </section>

        <!-- ================================================
             COLOR
             ================================================ -->
        <section id="color" class="styleguide_section">
          <h2 class="styleguide_section_title">Color</h2>

          <!-- Brand Swatches -->
          <div id="color-brand">
            <h3 class="styleguide_subsection_title">Dark Palette</h3>
            <div class="styleguide_card_wrap is-grid">
              {
                [
                  { name: "dark-900", hex: "#1f1d1e", var: "--color-dark-900" },
                  {
                    name: "dark-900-o75",
                    hex: "75% opacity",
                    var: "--color-dark-900-o75",
                  },
                  {
                    name: "dark-900-o50",
                    hex: "50% opacity",
                    var: "--color-dark-900-o50",
                  },
                  {
                    name: "dark-900-o20",
                    hex: "20% opacity",
                    var: "--color-dark-900-o20",
                  },
                  { name: "dark-800", hex: "#2f2b2d", var: "--color-dark-800" },
                ].map(({ name, hex, var: cssVar }) => (
                  <div class="styleguide_swatch_wrap">
                    <div
                      class="styleguide_swatch"
                      style={`background-color: var(${cssVar})`}
                    />
                    <span class="styleguide_swatch_label">{name}</span>
                    <span class="styleguide_swatch_label">{hex}</span>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">Light Palette</h3>
            <div class="styleguide_card_wrap is-grid">
              {
                [
                  { name: "light-100", hex: "white", var: "--color-light-100" },
                  {
                    name: "light-100-o75",
                    hex: "75% opacity",
                    var: "--color-light-100-o75",
                  },
                  {
                    name: "light-100-o50",
                    hex: "50% opacity",
                    var: "--color-light-100-o50",
                  },
                  {
                    name: "light-100-o20",
                    hex: "20% opacity",
                    var: "--color-light-100-o20",
                  },
                  {
                    name: "light-200",
                    hex: "#ebebeb",
                    var: "--color-light-200",
                  },
                ].map(({ name, hex, var: cssVar }) => (
                  <div class="styleguide_swatch_wrap">
                    <div
                      class="styleguide_swatch"
                      style={`background-color: var(${cssVar})`}
                    />
                    <span class="styleguide_swatch_label">{name}</span>
                    <span class="styleguide_swatch_label">{hex}</span>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">
              Brand Palette — orange Scale
            </h3>
            <p class="u-text-style-small u-text-style-muted u-margin-bottom-4">
              All shades derived from <code>--color-brand-500</code> (#f35423) via
              <code>color-mix()</code>.
            </p>
            <div class="styleguide_card_wrap is-grid">
              {
                [
                  {
                    name: "brand-100",
                    hex: "80% white",
                    var: "--color-brand-100",
                  },
                  {
                    name: "brand-200",
                    hex: "60% white",
                    var: "--color-brand-200",
                  },
                  {
                    name: "brand-300",
                    hex: "40% white",
                    var: "--color-brand-300",
                  },
                  {
                    name: "brand-400",
                    hex: "20% white",
                    var: "--color-brand-400",
                  },
                  {
                    name: "brand-500",
                    hex: "#c6fb50",
                    var: "--color-brand-500",
                  },
                  {
                    name: "brand-600",
                    hex: "20% black",
                    var: "--color-brand-600",
                  },
                  {
                    name: "brand-700",
                    hex: "40% black",
                    var: "--color-brand-700",
                  },
                  {
                    name: "brand-800",
                    hex: "60% black",
                    var: "--color-brand-800",
                  },
                  {
                    name: "brand-900",
                    hex: "80% black",
                    var: "--color-brand-900",
                  },
                  {
                    name: "brand-text",
                    hex: "white",
                    var: "--color-brand-text",
                  },
                  {
                    name: "brand-text-o75",
                    hex: "75% opacity",
                    var: "--color-brand-text-o75",
                  },
                  {
                    name: "brand-text-o20",
                    hex: "20% opacity",
                    var: "--color-brand-text-o20",
                  },
                ].map(({ name, hex, var: cssVar }) => (
                  <div class="styleguide_swatch_wrap">
                    <div
                      class="styleguide_swatch"
                      style={`background-color: var(${cssVar})`}
                    />
                    <span class="styleguide_swatch_label">{name}</span>
                    <span class="styleguide_swatch_label">{hex}</span>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">System / Status Colors</h3>
            <div class="styleguide_card_wrap is-grid">
              {
                [
                  {
                    name: "success-green",
                    hex: "#cef5ca",
                    var: "--color-success-green",
                  },
                  {
                    name: "success-green-dark",
                    hex: "#114e0b",
                    var: "--color-success-green-dark",
                  },
                  {
                    name: "warning-yellow",
                    hex: "#fcf8d8",
                    var: "--color-warning-yellow",
                  },
                  {
                    name: "warning-yellow-dark",
                    hex: "#5e5515",
                    var: "--color-warning-yellow-dark",
                  },
                  {
                    name: "error-red",
                    hex: "#f8e4e4",
                    var: "--color-error-red",
                  },
                  {
                    name: "error-red-dark",
                    hex: "#3b0b0b",
                    var: "--color-error-red-dark",
                  },
                ].map(({ name, hex, var: cssVar }) => (
                  <div class="styleguide_swatch_wrap">
                    <div
                      class="styleguide_swatch"
                      style={`background-color: var(${cssVar})`}
                    />
                    <span class="styleguide_swatch_label">{name}</span>
                    <span class="styleguide_swatch_label">{hex}</span>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">Focus State</h3>
            <div class="styleguide_card_wrap is-grid">
              <div class="styleguide_swatch_wrap">
                <div
                  class="styleguide_swatch"
                  style="background-color: var(--color-focus-state)"
                >
                </div>
                <span class="styleguide_swatch_label">focus-state</span>
                <span class="styleguide_swatch_label">brand-500</span>
              </div>
            </div>

            <h3 class="styleguide_subsection_title">Semantic Theme Colors</h3>
            <p class="u-text-style-small u-text-style-muted u-margin-bottom-4">
              These switch automatically when a theme is applied.
            </p>
            <div class="styleguide_card_wrap is-grid">
              {
                [
                  { name: "--background", var: "--background" },
                  { name: "--background-2", var: "--background-2" },
                  { name: "--text", var: "--text" },
                  { name: "--border", var: "--border" },
                  { name: "--heading-accent", var: "--heading-accent" },
                ].map(({ name, var: cssVar }) => (
                  <div class="styleguide_swatch_wrap">
                    <div
                      class="styleguide_swatch"
                      style={`background-color: var(${cssVar}); border: 1px solid var(--border)`}
                    />
                    <span class="styleguide_swatch_label">{name}</span>
                  </div>
                ))
              }
            </div>

            <h3 class="styleguide_subsection_title">Background Utilities</h3>
            <div class="styleguide_card_wrap is-row">
              {
                [
                  { cls: "u-background-1", label: "--background" },
                  { cls: "u-background-2", label: "--background-2" },
                  {
                    cls: "u-background-skeleton",
                    label: "--background-skeleton",
                  },
                ].map(({ cls, label }) => (
                  <div class="styleguide_swatch_wrap">
                    <div
