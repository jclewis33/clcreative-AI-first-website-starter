---
/**
 * Contact Page
 *
 * Structure:
 *   1. Hero section — background image + overlay, title + description
 *   2. Contact info + form — two-column layout (info left, form right)
 *   3. CTA section — reusable call-to-action
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import CTASection from "../components/sections/CTASection.astro";
import FAQ from "../components/sections/FAQ.astro";
import TestimonialShowcase from "../components/sections/TestimonialShowcase.astro";
import { bookACallFaqs } from "../data/faqs";
import Section from "../components/ui/Section.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Visual from "../components/ui/Visual.astro";
import Button from "../components/ui/Button.astro";
import HoneyBookEmbedBookingWidget from "../components/ui/HoneyBookEmbedBookingWidget.astro";
import { getTestimonialByName } from "../sanity/lib/testimonials";
import { getDraftModeProps } from "../sanity/lib/draft-mode";

import "../styles/pages/strategy-call.css";

import contactHero from "../assets/contact/contact-hero-2.webp";
import strategyCall from "../assets/book-call/booking-strategy-call.webp";
import happensNextImg from "../assets/contact/contact-happens-next-1.webp";

const draftProps = getDraftModeProps(Astro);
const [patrick, tom] = await Promise.all([
  getTestimonialByName("Patrick Payne", draftProps),
  getTestimonialByName("Tom Connally", draftProps),
]);
const contactTestimonials = [patrick, tom].filter(
  (t): t is NonNullable<typeof t> => !!t,
);
---

<BaseLayout
  title="Strategy Call | CL Creative"
  description="Book a free strategy meeting. We'll dig into your website and how you're currently marketing your business as well as how you can improve."
>
  {
    /* ================================================================
      HERO — background image + overlay + centered text
      ================================================================ */
  }
  <Section paddingBottom="small">
    <Layout
      data-prevent-flicker="true"
      data-fade-list
      variant="columns"
      verticalAlign="center"
    >
      <Col slot="col1">
        <Heading tag="h1" variant="eyebrow">
          Book a Free Strategy Meeting
        </Heading>
        <Heading tag="h2" variant="h1">
          Get Clarity on Why Your Website and Marketing Aren't Bringing in Leads
        </Heading>
        <Text>
          Pick a time below for a free 30-minute strategy call. We'll talk
          through what's working, what's not, and what to focus on next, whether
          we end up working together or not.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#booking-form" ariaLabel="Jump to booking form">
            Pick a Time
            <svg
              slot="icon"
              aria-hidden="true"
              viewBox="0 0 10 10"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="5" y1="1" x2="5" y2="9"></line>
              <polyline points="2,6 5,9 8,6"></polyline>
            </svg>
          </Button>
        </div>
      </Col>
      <Visual
        slot="col2"
        src={contactHero}
        alt="Picture of Casey in his office"
        ratio="landscape"
      />
    </Layout>
  </Section>

  {
    /* ================================================================
      BOOKING FORM — STACKED layout
      ================================================================ */
  }
  <Section theme="dark" id="booking-form">
    <Layout variant="stack">
      <HoneyBookEmbedBookingWidget
        data-prevent-flicker="true"
        data-fade-in
        slot="col1"
        class="booking_form_wrap"
      />
    </Layout>
  </Section>
  {
    /* ================================================================
      WHAT YOU WALK AWAY WITH — Two Column Layout
      ================================================================ */
  }
  <Section>
    <Layout>
      <Col slot="col1">
        <Heading data-prevent-flicker="true" data-fade-in variant="eyebrow">
          What You Get
        </Heading>
        <Heading data-prevent-flicker="true" data-split-text tag="h3">
          You'll Leave the Call With a Clear Next Step
        </Heading>
        <Text data-prevent-flicker="true" data-fade-up variant="large">
          We'll look at your business, your goals, and what's getting in the
          way. You leave with honest recommendations you can act on, whether we
          end up working together or not.
        </Text>
        <ul
          class="walkaway_check_list"
          data-fade-list
          data-prevent-flicker="true"
        >
          <li class="walkaway_check_item u-text-shrink">
            <svg
              class="walkaway_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >A clear understanding of what's not working on your current site
              or marketing</Text
            >
          </li>
          <li class="walkaway_check_item u-text-shrink">
            <svg
              class="walkaway_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >Honest recommendations on what to focus on next</Text
            >
          </li>
          <li class="walkaway_check_item u-text-shrink">
            <svg
              class="walkaway_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >A rough budget range for the kind of project your business
              actually needs</Text
            >
          </li>
          <li class="walkaway_check_item u-text-shrink">
            <svg
              class="walkaway_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >At least one quick win you can implement this week</Text
            >
          </li>
        </ul>
      </Col>
      <Visual
        slot="col2"
        src={strategyCall}
        alt="Casey on a Strategy Call with a person who is interested"
        ratio="landscape"
      />
    </Layout>
  </Section>
  {
    /* ================================================================
      HERE'S WHAT HAPPENS NEXT — full-reversed breakout with numbered list
      ================================================================ */
  }
  <Section padding="none" class="strategy_next_section">
    <Layout
      variant="full-reversed"
      verticalAlign="center"
      columnGap="var(--gap-8)"
    >
      <Col slot="col1">
        <div class="strategy_next_content">
          <Heading data-split-text tag="h2" variant="h3" maxWidth="40ch">
            Here's What Happens Next
          </Heading>

          <div class="why-work_list" data-fade-list>
            <div class="why-work_row">
              <p class="why-work_number">01</p>
              <div class="why-work_item_content">
                <Heading tag="h3" variant="h5" marginBottom={0}>
                  We Listen
                </Heading>
                <Text marginBottom={0}>
                  I'll ask about your business, your goals, and the challenges
                  you're facing. This call is about understanding where you are
                  and where you want to go.
                </Text>
              </div>
            </div>
            <div class="why-work_row">
              <p class="why-work_number">02</p>
              <div class="why-work_item_content">
                <Heading tag="h3" variant="h5" marginBottom={0}>
                  You Get Honest Advice
                </Heading>
                <Text marginBottom={0}>
                  Based on what you share, you'll get honest recommendations on
                  what's worth fixing first and what to focus on next.
                </Text>
              </div>
            </div>
            <div class="why-work_row">
              <p class="why-work_number">03</p>
              <div class="why-work_item_content">
                <Heading tag="h3" variant="h5" marginBottom={0}>
                  You Walk Away With a Plan
                </Heading>
                <Text marginBottom={0}>
                  If you want more help with your marketing and website, we'll
                  outline a path forward and get you on the calendar. If you
                  just need a thinking partner and advisor, that's great too.
                  We're happy to be that for you. Either way, you'll walk away
                  with a clear picture of what to do next.
                </Text>
              </div>
            </div>
          </div>
        </div>
      </Col>
      <Visual
        radius="none"
        slot="col2"
        src={happensNextImg}
        alt="Abstract road map"
        ratio="square"
      />
    </Layout>
  </Section>

  {
    /* ================================================================
      FAQ
      ================================================================ */
  }
  <FAQ
    eyebrow="Before You Book"
    heading="A Few Things to Know"
    items={bookACallFaqs}
  />

  {
    /* ================================================================
      TESTIMONIALS
      ================================================================ */
  }
  <TestimonialShowcase paddingTop="small" testimonials={contactTestimonials} />
  {
    /* ================================================================
      SEND ME A QUICK NOTE FALLBACK
      ================================================================ */
  }
  <Section theme="brand" padding="small">
    <Layout variant="stack">
      <Col slot="col1">
        <Heading tag="h2" variant="h4">
          Times don't work?
          <a href="/contact" class="u-text-style-underline">
            Send me a quick note instead →
          </a>
        </Heading>
      </Col>
    </Layout>
  </Section>
</BaseLayout>
