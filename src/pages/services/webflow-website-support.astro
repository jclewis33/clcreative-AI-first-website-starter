---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { serviceFaqJsonLd } from "../../lib/jsonld";
import { SITE } from "../../config/site";
import Section from "../../components/ui/Section.astro";
import Layout from "../../components/ui/Layout.astro";
import Col from "../../components/ui/Col.astro";
import Heading from "../../components/ui/Heading.astro";
import Text from "../../components/ui/Text.astro";
import Button from "../../components/ui/Button.astro";
import Visual from "../../components/ui/Visual.astro";
import ContentWrapper from "../../components/ui/ContentWrapper.astro";
import Grid from "../../components/ui/Grid.astro";
import PricingCard from "../../components/ui/PricingCard.astro";
import PricingItem from "../../components/ui/PricingItem.astro";
import Accordion from "../../components/ui/Accordion.astro";
import AccordionItem from "../../components/ui/AccordionItem.astro";
import TestimonialShowcase from "../../components/sections/TestimonialShowcase.astro";
import FAQ from "../../components/sections/FAQ.astro";
import { websiteSupportFaqs } from "../../data/faqs";
import Services from "../../components/sections/Services.astro";

// Images — using placeholders for now
import heroImg from "../../assets/website-support/website-support-hero.avif";
import evolveImg from "../../assets/website-support/engage-visitors.avif";
import whyImg1 from "../../assets/website-support/ship-faster.webp";
import whyImg2 from "../../assets/website-support/stay-focused.webp";
import whyImg3 from "../../assets/website-support/look-professional.webp";
import whyImg4 from "../../assets/website-support/scale-flexible.webp";
import ctaImage from "../../assets/website-support/maintenance-cta.avif";

// Styles
import "../../styles/pages/webflow-website-support.css";

const pageUrl = `${SITE.url}/services/webflow-website-support`;

// Per-page Service + FAQPage schema. LocalBusiness lives sitewide in
// BaseLayout; referenced here via provider.@id.
const schemaGraph = serviceFaqJsonLd({
  pageUrl,
  serviceType: "Webflow Website Support",
  name: "Webflow Website Support",
  description:
    "Get dedicated design and development support from a Webflow Professional Partner, without the overhead of a full-time hire.",
  audience: { audienceType: "Growth-stage businesses ready to scale" },
  faqs: websiteSupportFaqs,
});
---

<BaseLayout
  title="Webflow Website Support | CL Creative"
  description="Get dedicated design and development support from a Webflow Professional Partner, without the overhead of a full-time hire."
  canonical={pageUrl}
  theme="light"
  schema={schemaGraph}
>
  <!-- Hero Section -->
  <Section class="wws_hero" padding="none">
    <Layout
      data-prevent-flicker="true"
      data-fade-list
      variant="full"
      verticalAlign="center"
    >
      <Col slot="col1">
        <div class="wws_hero_col1-wrap">
          <Heading variant="eyebrow" maxWidth="60ch"
            >Webflow Website Support</Heading
          >
          <Heading tag="h1" variant="h2"
            >Need Website Updates But Can't Justify a Full-Time Hire?</Heading
          >
          <Text maxWidth="48ch"
            >Get dedicated design and development support from a Webflow
            Professional Partner, without the overhead of a full-time hire or
            the hassle of one-off project quotes.</Text
          >
          <div class="u-button-wrapper">
            <Button href="/book-a-call" ariaLabel="Begin Website Support"
              >Begin Website Support</Button
            >
          </div>
        </div>
      </Col>
      <Visual
        class="wws_hero_image"
        slot="col2"
        src={heroImg}
        alt="Webflow website support"
        ratio="square"
        radius="none"
      />
    </Layout>
  </Section>

  <!-- Your Website Should Evolve -->
  <Section theme="dark">
    <ContentWrapper align="center">
      <Heading
        data-prevent-flicker="true"
        data-split-text
        variant="h3"
        maxWidth="30ch"
        >Your Website Should Evolve With Your Business — Not Hold It Back</Heading
      >
    </ContentWrapper>
    <Layout
      data-prevent-flicker="true"
      data-fade-list
      variant="columns"
      verticalAlign="start"
    >
      <Col slot="col1">
        <Heading balance variant="h4" maxWidth="30ch"
          >You've got ideas. A new service page. Updated pricing. A landing page
          for that campaign you want to run next month.</Heading
        >
      </Col>
      <div slot="col2" class="u-rich-text">
        <p>
          But every time you need something changed, you're stuck choosing
          between:
        </p>
        <ul class="wws_compare_list">
          <li class="wws_compare_item">
            <svg
              class="wws_compare_icon"
              viewBox="0 0 28 28"
              fill="none"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M13.9992 23.8C19.4116 23.8 23.7992 19.4123 23.7992 14C23.7992 8.58756 19.4116 4.19995 13.9992 4.19995C8.58683 4.19995 4.19922 8.58756 4.19922 14C4.19922 19.4123 8.58683 23.8 13.9992 23.8ZM12.4154 10.6837C11.937 10.2054 11.1614 10.2054 10.683 10.6837C10.2046 11.1621 10.2046 11.9378 10.683 12.4162L12.2668 14L10.683 15.5837C10.2046 16.0621 10.2046 16.8378 10.683 17.3162C11.1614 17.7945 11.937 17.7945 12.4154 17.3162L13.9992 15.7324L15.583 17.3162C16.0614 17.7945 16.837 17.7945 17.3154 17.3162C17.7938 16.8378 17.7938 16.0621 17.3154 15.5837L15.7316 14L17.3154 12.4162C17.7938 11.9378 17.7938 11.1621 17.3154 10.6837C16.837 10.2054 16.0614 10.2054 15.583 10.6837L13.9992 12.2675L12.4154 10.6837Z"
                fill="#D92D20"></path>
            </svg>
            <span
              ><strong>Figuring it out yourself</strong> — burning hours you don't
              have on tutorials</span
            >
          </li>
          <li class="wws_compare_item">
            <svg
              class="wws_compare_icon"
              viewBox="0 0 28 28"
              fill="none"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M13.9992 23.8C19.4116 23.8 23.7992 19.4123 23.7992 14C23.7992 8.58756 19.4116 4.19995 13.9992 4.19995C8.58683 4.19995 4.19922 8.58756 4.19922 14C4.19922 19.4123 8.58683 23.8 13.9992 23.8ZM12.4154 10.6837C11.937 10.2054 11.1614 10.2054 10.683 10.6837C10.2046 11.1621 10.2046 11.9378 10.683 12.4162L12.2668 14L10.683 15.5837C10.2046 16.0621 10.2046 16.8378 10.683 17.3162C11.1614 17.7945 11.937 17.7945 12.4154 17.3162L13.9992 15.7324L15.583 17.3162C16.0614 17.7945 16.837 17.7945 17.3154 17.3162C17.7938 16.8378 17.7938 16.0621 17.3154 15.5837L15.7316 14L17.3154 12.4162C17.7938 11.9378 17.7938 11.1621 17.3154 10.6837C16.837 10.2054 16.0614 10.2054 15.583 10.6837L13.9992 12.2675L12.4154 10.6837Z"
                fill="#D92D20"></path>
            </svg>
            <span
              ><strong>Hiring a freelancer</strong> — waiting days for quotes, hoping
              they deliver, then starting over when they disappear</span
            >
          </li>
          <li class="wws_compare_item">
            <svg
              class="wws_compare_icon"
              viewBox="0 0 28 28"
              fill="none"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                clip-rule="evenodd"
                d="M13.9992 23.8C19.4116 23.8 23.7992 19.4123 23.7992 14C23.7992 8.58756 19.4116 4.19995 13.9992 4.19995C8.58683 4.19995 4.19922 8.58756 4.19922 14C4.19922 19.4123 8.58683 23.8 13.9992 23.8ZM12.4154 10.6837C11.937 10.2054 11.1614 10.2054 10.683 10.6837C10.2046 11.1621 10.2046 11.9378 10.683 12.4162L12.2668 14L10.683 15.5837C10.2046 16.0621 10.2046 16.8378 10.683 17.3162C11.1614 17.7945 11.937 17.7945 12.4154 17.3162L13.9992 15.7324L15.583 17.3162C16.0614 17.7945 16.837 17.7945 17.3154 17.3162C17.7938 16.8378 17.7938 16.0621 17.3154 15.5837L15.7316 14L17.3154 12.4162C17.7938 11.9378 17.7938 11.1621 17.3154 10.6837C16.837 10.2054 16.0614 10.2054 15.583 10.6837L13.9992 12.2675L12.4154 10.6837Z"
                fill="#D92D20"></path>
            </svg>
            <span
              ><strong>Asking your "tech-savvy" team member</strong> — who already
              has a full-time job</span
            >
          </li>
        </ul>
        <p>
          Meanwhile, your website sits there. Outdated. Static. Not doing its
          job.
        </p>
        <p><strong>There's a better way.</strong></p>
      </div>
    </Layout>
    <Visual
      data-prevent-flicker="true"
      data-fade-in
      class="u-max-width-xlarge u-margin-inline-auto"
      src={evolveImg}
      alt="Website evolving with your business"
      ratio="10.25/5.64"
      transparent
    />
    <Layout data-fade-list variant="columns" verticalAlign="start">
      <Col slot="col1">
        <Heading variant="h4" maxWidth="30ch"
          >Your On-Demand Web Team Without the Overhead</Heading
        >
      </Col>
      <div slot="col2" class="u-rich-text">
        <p>
          Website Support gives you access to professional Webflow design and
          development whenever you need it, without hiring, training, or
          managing another employee.
        </p>
        <p><strong>Send me a message.</strong></p>
        <p><strong>I get to work. That's it.</strong></p>
        <p>No quotes. No scope creep. No waiting.</p>
        <p>
          Whether you need a quick content update, a new landing page, or a
          complete section redesign, I handle it with the same care I'd give my
          own site.
        </p>
        <div class="u-button-wrapper">
          <Button href="/book-a-call" ariaLabel="Book your free strategy call"
            >Book Your Free Strategy Call</Button
          >
        </div>
      </div>
    </Layout>
  </Section>

  <!-- Why Growth-Stage Companies Choose Monthly Support -->
  <Section padding="small">
    <ContentWrapper align="center">
      <Heading data-split-text maxWidth="40ch" variant="h2"
        >Why Growth-Stage Companies Choose Monthly Support</Heading
      >
    </ContentWrapper>
    <div class="wws_why_wrap" data-why-accordion>
      <Accordion openOnHover openByDefault={1} class="wws_why_accordion">
        <AccordionItem question="Ship Faster" data-visual-key="1">
          <Text
            >Stop waiting for quotes, contracts, and freelancer availability.
            Message me your request and I'm on it. Most updates completed within
            24–48 hours.</Text
          >
          <div class="wws_why_inline_visual">
            <Visual
              src={whyImg1}
              alt="Ship faster with website support"
              ratio="square"
              radius="main"
            />
          </div>
        </AccordionItem>
        <AccordionItem question="Stay Focused" data-visual-key="2">
          <Text
            >Your job is running your business, not debugging CSS. Hand off the
            web work so you can focus on what actually moves the needle.</Text
          >
          <div class="wws_why_inline_visual">
            <Visual
              src={whyImg2}
              alt="Stay focused on your business"
              ratio="square"
              radius="main"
              transparent
            />
          </div>
        </AccordionItem>
        <AccordionItem question="Look Professional" data-visual-key="3">
          <Text
            >Keep your site fresh, functional, and aligned with your brand as
            you evolve. First impressions matter — make sure yours is current.</Text
          >
          <div class="wws_why_inline_visual">
            <Visual
              src={whyImg3}
              alt="Look professional online"
              ratio="square"
              radius="main"
            />
          </div>
        </AccordionItem>
        <AccordionItem question="Scale Flexibly" data-visual-key="4">
          <Text
            >Need more support one month, less the next? Your plan adapts to
            your business rhythm. No long-term contracts. No wasted retainers.</Text
          >
          <div class="wws_why_inline_visual">
            <Visual
              src={whyImg4}
              alt="Scale your website flexibly"
              ratio="square"
              radius="main"
            />
          </div>
        </AccordionItem>
      </Accordion>
      <div class="wws_why_visual_wrap">
        <div class="wws_why_visual" data-visual-key="1" data-accordion-active>
          <Visual
            src={whyImg1}
            alt="Ship faster with website support"
            ratio="square"
            radius="main"
          />
        </div>
        <div class="wws_why_visual" data-visual-key="2">
          <Visual
            src={whyImg2}
            alt="Stay focused on your business"
            ratio="square"
            radius="main"
            transparent
          />
        </div>
        <div class="wws_why_visual" data-visual-key="3">
          <Visual
            src={whyImg3}
            alt="Look professional online"
            ratio="square"
            radius="main"
          />
        </div>
        <div class="wws_why_visual" data-visual-key="4">
          <Visual
            src={whyImg4}
            alt="Scale your website flexibly"
            ratio="square"
            radius="main"
          />
        </div>
      </div>
    </div>
  </Section>

  <!-- No More Quote-Chasing Comparison -->
  <Section padding="small">
    <Heading data-split-text>No More Quote-Chasing, Just Results</Heading>
    <Layout data-fade-list variant="columns" verticalAlign="stretch">
      <div
        slot="col1"
        class="wws_compare_card u-radius-main u-padding-5"
        data-theme="dark"
      >
        <Heading tag="h3" variant="h4"
          >W/out a Support Plan <svg
            class="wws_compare_icon"
            viewBox="0 0 32 32"
            fill="none"
            aria-hidden="true"
            ><path
              d="M21.3346 21.3332C21.3346 21.3332 19.3346 18.6665 16.0013 18.6665C12.668 18.6665 10.668 21.3332 10.668 21.3332M20.0013 11.9998H20.0146M12.0013 11.9998H12.0146M29.3346 15.9998C29.3346 23.3636 23.3651 29.3332 16.0013 29.3332C8.63751 29.3332 2.66797 23.3636 2.66797 15.9998C2.66797 8.63604 8.63751 2.6665 16.0013 2.6665C23.3651 2.6665 29.3346 8.63604 29.3346 15.9998ZM20.668 11.9998C20.668 12.368 20.3695 12.6665 20.0013 12.6665C19.6331 12.6665 19.3346 12.368 19.3346 11.9998C19.3346 11.6316 19.6331 11.3332 20.0013 11.3332C20.3695 11.3332 20.668 11.6316 20.668 11.9998ZM12.668 11.9998C12.668 12.368 12.3695 12.6665 12.0013 12.6665C11.6331 12.6665 11.3346 12.368 11.3346 11.9998C11.3346 11.6316 11.6331 11.3332 12.0013 11.3332C12.3695 11.3332 12.668 11.6316 12.668 11.9998Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          ></Heading
        >
        <hr class="wws_compare_divider" />
        <div class="u-rich-text">
          <p>Here's how a typical one-off update looks:</p>
          <ul>
            <li>You reach out with your request.</li>
            <li>Wait for a quote.</li>
            <li>Review and approve the quote.</li>
            <li>Wait for scheduling.</li>
            <li>Work gets completed.</li>
            <li>Receive an invoice.</li>
            <li>Process Payment.</li>
            <li>Repeat for the next request.</li>
          </ul>
          <p>Sounds exhausting, right?</p>
        </div>
      </div>
      <div
        slot="col2"
        class="wws_compare_card u-radius-main u-padding-5"
        data-theme="brand"
      >
        <Heading tag="h3" variant="h4"
          >With a Support Plan <svg
            class="wws_compare_icon"
            viewBox="0 0 32 32"
            fill="none"
            aria-hidden="true"
            ><path
              d="M10.668 18.6665C10.668 18.6665 12.668 21.3332 16.0013 21.3332C19.3346 21.3332 21.3346 18.6665 21.3346 18.6665M20.0013 11.9998H20.0146M12.0013 11.9998H12.0146M29.3346 15.9998C29.3346 23.3636 23.3651 29.3332 16.0013 29.3332C8.63751 29.3332 2.66797 23.3636 2.66797 15.9998C2.66797 8.63604 8.63751 2.6665 16.0013 2.6665C23.3651 2.6665 29.3346 8.63604 29.3346 15.9998ZM20.668 11.9998C20.668 12.368 20.3695 12.6665 20.0013 12.6665C19.6331 12.6665 19.3346 12.368 19.3346 11.9998C19.3346 11.6316 19.6331 11.3332 20.0013 11.3332C20.3695 11.3332 20.668 11.6316 20.668 11.9998ZM12.668 11.9998C12.668 12.368 12.3695 12.6665 12.0013 12.6665C11.6331 12.6665 11.3346 12.368 11.3346 11.9998C11.3346 11.6316 11.6331 11.3332 12.0013 11.3332C12.3695 11.3332 12.668 11.6316 12.668 11.9998Z"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path></svg
          ></Heading
        >
        <hr class="wws_compare_divider" />
        <div class="u-rich-text">
          <p>This whole process becomes simpler:</p>
          <ul>
            <li>You send a message</li>
            <li>I get to work</li>
          </ul>
          <p>
            Skip the back-and-forth. Your requests go straight to the top of my
            queue, and you get results instead of paperwork.
          </p>
          <p>No quotes, no time-wasting, and no stress.</p>
        </div>
      </div>
    </Layout>
  </Section>

  <!-- More Than Maintenance — Services Included -->
  <Section theme="dark">
    <Layout verticalAlign="start" variant="sticky-left" ratio="4-8">
      <Col slot="col1">
        <Heading variant="h3"
          >More Than Maintenance Real Design & Development Support</Heading
        >
        <Text
          >Website Support goes beyond fixing broken links. I'm here to bring
          your ideas to life, optimize performance, and help your site evolve
          with your business.</Text
        >
        <Text weight="bold">Included Services:</Text>
      </Col>
      <Grid
        slot="col2"
        largeColumns={2}
        mediumColumns={2}
        smallColumns={1}
        rowGap={6}
      >
        <div
          class="wws_service_card_wrap u-padding-4 u-radius-main"
          data-theme="brand"
        >
          <div class="wws_service_card_icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
            </svg>
          </div>
          <Heading tag="h3" variant="h5" marginBottom={0}
            >Performance Optimization</Heading
          >
          <Text muted>Speed improvements, mobile responsiveness</Text>
        </div>
        <div
          class="wws_service_card_wrap u-padding-4 u-radius-main"
          data-theme="brand"
        >
          <div class="wws_service_card_icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2"></rect>
              <path d="M3 9h18M9 21V9"></path>
            </svg>
          </div>
          <Heading tag="h3" variant="h5" marginBottom={0}
            >Section & Component Design</Heading
          >
          <Text muted>Headers, CTAs, feature blocks, testimonials</Text>
        </div>
        <div
          class="wws_service_card_wrap u-padding-4 u-radius-main"
          data-theme="brand"
        >
          <div class="wws_service_card_icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"
              ></path>
              <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"
              ></path>
            </svg>
          </div>
          <Heading tag="h3" variant="h5" marginBottom={0}
            >Content Updates</Heading
          >
          <Text muted>Text changes, image swaps, product updates</Text>
        </div>
        <div
          class="wws_service_card_wrap u-padding-4 u-radius-main"
          data-theme="brand"
        >
          <div class="wws_service_card_icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"
              ></path>
              <path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"></path>
            </svg>
          </div>
          <Heading tag="h3" variant="h5" marginBottom={0}
            >New Landing Pages</Heading
          >
          <Text muted>Campaign pages, service pages, lead magnets</Text>
        </div>
        <div
          class="wws_service_card_wrap u-padding-4 u-radius-main"
          data-theme="brand"
        >
          <div class="wws_service_card_icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M4 7V4a2 2 0 012-2h8.5L20 7.5V20a2 2 0 01-2 2H4"></path>
              <polyline points="8,16 10,18 14,14"></polyline>
            </svg>
          </div>
          <Heading tag="h3" variant="h5" marginBottom={0}
            >CMS Management</Heading
          >
          <Text muted>Blog posts, team pages, portfolios, product catalogs</Text
          >
        </div>
        <div
          class="wws_service_card_wrap u-padding-4 u-radius-main"
          data-theme="brand"
        >
          <div class="wws_service_card_icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <polyline points="16,18 22,12 16,6"></polyline>
              <polyline points="8,6 2,12 8,18"></polyline>
            </svg>
          </div>
          <Heading tag="h3" variant="h5" marginBottom={0}
            >Development Work</Heading
          >
          <Text muted>Custom interactions, integrations, form logic</Text>
        </div>

        <div
          class="wws_service_card_wrap u-padding-4 u-radius-main"
          data-theme="brand"
        >
          <div class="wws_service_card_icon">
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 012 2v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6a2 2 0 012-2z"
              ></path>
            </svg>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <rect x="2" y="3" width="20" height="14" rx="2"></rect>
              <path d="M8 21h8M12 17v4"></path>
            </svg>
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M16 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"></path>
              <circle cx="8.5" cy="7" r="4"></circle>
              <path d="M20 8v6M23 11h-6"></path>
            </svg>
          </div>
          <Heading tag="h3" variant="h5" marginBottom={0}
            >Need help with Calendly setup, CRM configuration, or automations?</Heading
          >
          <Text muted>I can handle that too.</Text>
        </div>
      </Grid>
    </Layout>
  </Section>

  <!-- Pricing Section -->
  <Section paddingBottom="small" id="pricing">
    <ContentWrapper align="center">
      <Heading variant="eyebrow">Monthly Website Support Pricing</Heading>
      <Heading data-split-text>Simple, Predictable Pricing</Heading>
      <Text maxWidth="48rem"
        >Choose the support level that fits your needs. No surprise invoices. No
        chasing quotes. Cancel anytime.</Text
      >
    </ContentWrapper>
