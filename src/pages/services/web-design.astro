---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { serviceFaqJsonLd } from "../../lib/jsonld";
import { SITE } from "../../config/site";
import Section from "../../components/ui/Section.astro";
import Layout from "../../components/ui/Layout.astro";
import Col from "../../components/ui/Col.astro";
import Heading from "../../components/ui/Heading.astro";
import Text from "../../components/ui/Text.astro";
import Button from "../../components/ui/Button.astro";
import Visual from "../../components/ui/Visual.astro";
import Overlay from "../../components/ui/Overlay.astro";
import ContentWrapper from "../../components/ui/ContentWrapper.astro";
import Marquee from "../../components/ui/Marquee.astro";

// Section Components
import HowItWorks from "../../components/sections/HowItWorks.astro";
import M2MFramework from "../../components/sections/M2MFramework.astro";
import WhyWorkWithUs from "../../components/sections/WhyWorkWithUs.astro";
import TestimonialShowcase from "../../components/sections/TestimonialShowcase.astro";
import SingleTestimonial from "../../components/sections/SingleTestimonial.astro";
import CTASection from "../../components/sections/CTASection.astro";
import CaseStudyFeatured from "../../components/sections/CaseStudyFeatured.astro";
import AfterLaunch from "../../components/sections/AfterLaunch.astro";
import SignUpForm from "../../components/sections/SignUpForm.astro";
import FAQ from "../../components/sections/FAQ.astro";
import Services from "../../components/sections/Services.astro";
import HowWeWorkPromo from "../../components/sections/HowWeWorkPromo.astro";
import { webDesignFaqs } from "../../data/faqs";

// Components
import Grid from "../../components/ui/Grid.astro";
import { Image } from "astro:assets";

// Images
import outgrownImg from "../../assets/web-design/design-convert-m2m-1.webp";
import m2mImg from "../../assets/web-design/design-convert-m2m-2.webp";
import withoutMessagingImg from "../../assets/web-design/without-messaging.webp";
import withMessagingImg from "../../assets/web-design/with-messaging.webp";
import websiteHelpsGrowImg from "../../assets/web-design/website-helps-grow.webp";
import heroTopLeft from "../../assets/web-design/hero/web-design-hero-top-left.avif";
import heroTopMiddle from "../../assets/web-design/hero/web-design-hero-top-middle.avif";
import heroTopRight from "../../assets/web-design/hero/web-design-hero-top-right.avif";
import heroLeftSide from "../../assets/web-design/hero/web-design-hero-left-side.avif";
import heroRightSide from "../../assets/web-design/hero/web-design-hero-right-side.avif";
import heroCenterMiddleLeft from "../../assets/web-design/hero/web-design-hero-center-middle-left.avif";
import heroCenterMiddleRight from "../../assets/web-design/hero/web-design-hero-center-middle-right.avif";
import heroRightBottom from "../../assets/web-design/hero/web-design-hero-right-bottom.avif";

// Styles
import "../../styles/pages/web-design.css";

const pageUrl = `${SITE.url}/services/web-design`;

// Per-page Service + FAQPage schema. LocalBusiness lives sitewide in
// BaseLayout; referenced here via provider.@id.
const schemaGraph = serviceFaqJsonLd({
  pageUrl,
  serviceType: "Web Design",
  name: "Web Design",
  description: "Web Design for growth stage companies.",
  audience: { audienceType: "Growth-stage businesses ready to scale" },
  faqs: webDesignFaqs,
});
---

<BaseLayout
  title="Web Design | CL Creative"
  description="Web Design for growth stage companies."
  canonical={pageUrl}
  theme="light"
  schema={schemaGraph}
>
  <!-- Hero Section -->
  <Section padding="large" theme="light" class="wd-hero_section">
    <Fragment slot="background">
      <div
        data-prevent-flicker="true"
        data-fade-list
        class="wd-hero_images"
        aria-hidden="true"
      >
        <div class="wd-hero_img is-top-left" data-parallax="0.3">
          <Image
            src={heroTopLeft}
            alt="CL Creative website design example"
            loading="eager"
          />
        </div>
        <div class="wd-hero_img is-top-middle" data-parallax="0.5">
          <Image
            src={heroTopMiddle}
            alt="Webflow homepage design by CL Creative"
            loading="eager"
          />
        </div>
        <div class="wd-hero_img is-top-right" data-parallax="0.4">
          <Image
            src={heroTopRight}
            alt="Website landing page design example"
            loading="eager"
          />
        </div>
        <div class="wd-hero_img is-left-side" data-parallax="0.25">
          <Image
            src={heroLeftSide}
            alt="Custom Webflow website layout by CL Creative"
            loading="eager"
          />
        </div>
        <div class="wd-hero_img is-right-side" data-parallax="0.35">
          <Image
            src={heroRightSide}
            alt="Responsive website design example"
            loading="eager"
          />
        </div>
        <div class="wd-hero_img is-center-middle-left" data-parallax="0.45">
          <Image
            src={heroCenterMiddleLeft}
            alt="Modern website interface design by CL Creative"
            loading="eager"
          />
        </div>
        <div class="wd-hero_img is-center-middle-right" data-parallax="0.2">
          <Image
            src={heroCenterMiddleRight}
            alt="Web design project example by CL Creative"
            loading="eager"
          />
        </div>
        <div class="wd-hero_img is-right-bottom" data-parallax="0.35">
          <Image
            src={heroRightBottom}
            alt="Webflow website design example by CL Creative"
            loading="eager"
          />
        </div>
      </div>
    </Fragment>

    <Layout data-prevent-flicker="true" data-fade-list variant="stack-centered">
      <Col slot="col1">
        <Heading
          maxWidth="none"
          tag="h1"
          variant="eyebrow"
          class="wd-hero_eyebrow">Web Design for Growth-Stage Companies</Heading
        >
        <Heading
          >Stop Losing Revenue to a Website That Doesn't Bring in the Right
          Customer</Heading
        >
        <Text
          >A beautiful site that doesn't bring in customers is decoration, not
          design. We build strategy-first websites that match your business and
          convert your ideal customer, so they buy from you and not the
          competition.</Text
        >
        <div class="u-button-wrapper">
          <Button href="/book-a-call" ariaLabel="Book a Strategy Call"
            >Book a Strategy Call</Button
          >
          <Button
