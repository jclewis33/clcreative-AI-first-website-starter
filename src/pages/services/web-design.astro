<script>
  /**
   * Hero parallax — images follow mouse movement at different speeds.
   * Each image's data-parallax attribute (0–1) controls intensity.
   * Uses GSAP for smooth interpolation. Desktop only (> 800px).
   */
  const g = window as any;

  function initHeroParallax() {
    if (!g.gsap) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const section = document.querySelector(".wd-hero_section");
    if (!section) return;

    const images = section.querySelectorAll<HTMLElement>("[data-parallax]");
    if (!images.length) return;

    const isDesktop = () => window.innerWidth > 800;

    section.addEventListener("mousemove", (e) => {
      if (!isDesktop()) return;

      const rect = section.getBoundingClientRect();
      const xNorm =
        (((e as MouseEvent).clientX - rect.left) / rect.width) * 2 - 1;
      const yNorm =
        (((e as MouseEvent).clientY - rect.top) / rect.height) * 2 - 1;

      images.forEach((img) => {
        const strength = parseFloat(img.dataset.parallax || "0.3");
        const maxMove = 40;
        const xMove = xNorm * maxMove * strength;
        const yMove = yNorm * maxMove * strength;

        g.gsap.to(img, {
          x: xMove,
          y: yMove,
          duration: 0.8,
          ease: "power2.out",
          overwrite: "auto",
        });
      });
    });

    section.addEventListener("mouseleave", () => {
      if (!isDesktop()) return;
      images.forEach((img) => {
        g.gsap.to(img, {
          x: 0,
          y: 0,
          duration: 0.6,
          ease: "power2.out",
          overwrite: "auto",
        });
      });
    });
  }

  if (g.gsap) {
    initHeroParallax();
  } else {
    document.addEventListener("DOMContentLoaded", () => {
      setTimeout(initHeroParallax, 100);
    });
  }
</script>
