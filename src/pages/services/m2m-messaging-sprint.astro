---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { serviceFaqJsonLd } from "../../lib/jsonld";
import { SITE } from "../../config/site";
import Section from "../../components/ui/Section.astro";
import Layout from "../../components/ui/Layout.astro";
import Col from "../../components/ui/Col.astro";
import Heading from "../../components/ui/Heading.astro";
import Text from "../../components/ui/Text.astro";
import Button from "../../components/ui/Button.astro";
import Visual from "../../components/ui/Visual.astro";
import ContentWrapper from "../../components/ui/ContentWrapper.astro";
import Grid from "../../components/ui/Grid.astro";
import PricingCard from "../../components/ui/PricingCard.astro";
import PricingItem from "../../components/ui/PricingItem.astro";

// Section Components
import HowItWorks from "../../components/sections/HowItWorks.astro";
import CTASection from "../../components/sections/CTASection.astro";
import TestimonialShowcase from "../../components/sections/TestimonialShowcase.astro";
import FAQ from "../../components/sections/FAQ.astro";

// Data
import { m2mMessagingSprintFaqs } from "../../data/faqs";

// Images
import heroImg from "../../assets/m2m-messaging-sprint/m2m-messaging-hero.webp";
import failsImg from "../../assets/m2m-messaging-sprint/m2m-messaging-fails.webp";
import differenceImg from "../../assets/m2m-messaging-sprint/m2m-messaging-difference.webp";
import knowImg from "../../assets/m2m-messaging-sprint/m2m-messaging-know.webp";
import rightForImg from "../../assets/m2m-messaging-sprint/m2m-messaging-right-for.webp";

// Icons
import CheckMarkIcon from "../../components/icons/checkMarkIcon.astro";
import XIcon from "../../components/icons/xIcon.astro";

// Styles
import "../../styles/pages/m2m-messaging-sprint.css";

const pageUrl = `${SITE.url}/services/m2m-messaging-sprint`;

// Per-page Service + FAQPage schema. LocalBusiness lives sitewide in
// BaseLayout; referenced here via provider.@id.
const schemaGraph = serviceFaqJsonLd({
  pageUrl,
  serviceType: "Messaging Strategy",
  name: "M2M Messaging Sprint",
  description:
    "Lock down who you're talking to and what to say. A focused sprint to fix your messaging across your website, sales calls, and marketing.",
  audience: { audienceType: "Growth-stage businesses ready to scale" },
  faqs: m2mMessagingSprintFaqs,
});
---

<BaseLayout
  title="M2M Messaging Sprint | CL Creative"
  description="Lock down who you're talking to and what to say. A focused sprint to fix your messaging across your website, sales calls, and marketing."
  canonical={pageUrl}
  theme="light"
  schema={schemaGraph}
>
  <!-- ==================== HERO ==================== -->
  <Section paddingBottom="none" id="m2m-sprint-hero">
    <Layout variant="stack">
      <Col slot="col1">
        <Heading variant="eyebrow" data-fade-in data-prevent-flicker="true"
          >M2M Messaging Sprint</Heading
        >
        <Heading
          maxWidth="30ch"
          tag="h1"
          variant="h1"
          data-splittext
          data-prevent-flicker="true"
        >
          Stop Guessing at What to Say to the Right Customer
        </Heading>
        <Text maxWidth="60ch" data-fade-up data-prevent-flicker="true">
          You've rewritten your homepage three times this year. Your sales calls
          still need different language. Your LinkedIn posts say one thing, your
          ads say another, and your team can't agree on the elevator pitch. The
          problem isn't your design or your copywriter. It's that nobody locked
          down who you're talking to and what to say.
        </Text>
        <div
          class="u-button-wrapper"
          data-fade-up
          data-prevent-flicker="true"
          data-duration="0.6"
        >
          <Button href="/book-a-call" ariaLabel="Fix My Messaging"
            >Fix My Messaging</Button
          >
        </div>
      </Col>
    </Layout>
    <Visual
      data-prevent-flicker
      data-fade-in
      data-delay="0.6"
      class="m2m-sprint-hero_img"
      ratio="1440/480"
      radius="none"
      src={heroImg}
      alt="Team aligning on messaging in a strategy session"
    />
  </Section>

  <!-- ==================== PROBLEM ==================== -->
  <Section theme="brand" container="narrow" padding="small">
    <ContentWrapper align="center">
      <Heading tag="h2" variant="h2" maxWidth="30ch">
        Most Businesses Don't Have a Messaging Problem. They Have a "Who Are We
        Talking To" Problem.
      </Heading>
    </ContentWrapper>
  </Section>

  <!-- ==================== AGITATION ==================== -->
  <Section>
    <Layout variant="full" verticalAlign="center">
      <Col slot="col1">
        <Heading
          data-split-text
          data-prevent-flicker="true"
          tag="h2"
          variant="h3"
        >
          Most messaging work fails because it skips the foundation
        </Heading>
        <Text data-fade-up data-prevent-flicker="true" variant="large">
          You can't write a homepage that converts if you don't know who's
          reading it. You can't write a sales script that lands if you don't
          know what your buyer is actually worried about. You can't write
          LinkedIn posts that build a pipeline if every post is aimed at a
          different person.
        </Text>
        <Text
          data-fade-up
          data-prevent-flicker="true"
          variant="large"
          weight="bold"
          marginBottom={2}
        >
          We start with research:
        </Text>
        <ul
          data-fade-list
          data-prevent-flicker="true"
          class="u-list u-text-style-large"
        >
          <li>Who's actually buying</li>
          <li>What language they use</li>
          <li>What makes them say yes.</li>
        </ul>
        <Text data-fade-up data-prevent-flicker="true" variant="large">
          Then we build the messaging around that.
        </Text>
      </Col>
      <Visual
        data-fade-up
        data-prevent-flicker="true"
        slot="col2"
        src={failsImg}
        alt="Strategist reviewing customer research to inform messaging"
        ratio="landscape"
        transparent
      />
    </Layout>
    <Heading data-split-text data-prevent-flicker="true" tag="h2">
      Get the customer right, and the words follow.
    </Heading>
  </Section>

  <!-- ==================== WHAT YOU GET ==================== -->
  <Section theme="brand">
    <ContentWrapper>
      <Heading data-fade-in variant="eyebrow">
        The M2M Messaging Sprint
      </Heading>
      <Heading data-split-text tag="h2" variant="h2">
        A 2-3 Week Sprint That Locks In Your Messaging
      </Heading>
      <Text data-fade-up maxWidth="60ch">
        The Sprint does one thing: it figures out who you're talking to and what
        to say to them, then hands you a complete messaging system you can use
        everywhere. You walk away with eight deliverables you'll use on your
        website, your sales calls, your LinkedIn, your ads, and every other
        surface where your business shows up.
      </Text>
    </ContentWrapper>

    <Grid
      data-fade-list
      largeColumns={6}
      mediumColumns={1}
      smallColumns={1}
      rowGap={4}
    >
      <div class="m2m_card m2m-sprint-deliverable_card">
        <span class="m2m_card_number u-font-mono">01</span>
        <Heading tag="h3" variant="h4" marginBottom={0}>
          Ideal Customer Profile
        </Heading>
        <Text marginBottom={0}>
          A named, specific persona — not "small business owners," but the
          actual person you're selling to, in their own words. Where they work,
          what they're worried about, what they Google when they're looking for
          a solution, and the exact words they use to describe their problem.
        </Text>
      </div>
      <div class="m2m_card m2m-sprint-deliverable_card">
        <span class="m2m_card_number u-font-mono">02</span>
        <Heading tag="h3" variant="h4" marginBottom={0}>
          Five Messaging Soundbites
        </Heading>
        <Text marginBottom={0}>
          Short, repeatable lines that cover the problem, the empathy, the
          answer, the change, and the end result. These are the same five lines
          you'll use everywhere — homepage hero, sales call open, email subject
          lines, LinkedIn bio, ad headlines. Same words, same surface, same
          recognition every time.
        </Text>
      </div>
      <div class="m2m_card m2m-sprint-deliverable_card">
        <span class="m2m_card_number u-font-mono">03</span>
        <Heading tag="h3" variant="h4" marginBottom={0}>
          Your Business Story
        </Heading>
        <Text marginBottom={0}>
          A 150-word story you'll use in your About page, your sales
          conversations, your podcast bios, and anywhere else someone asks "so
          what do you do?" Built so it can be told in 30 seconds or expanded
          into a 5-minute version, depending on the room.
        </Text>
      </div>
      <div class="m2m_card m2m-sprint-deliverable_card">
        <span class="m2m_card_number u-font-mono">04</span>
        <Heading tag="h3" variant="h4" marginBottom={0}
          >Controlling Idea</Heading
        >
        <Text marginBottom={0}>
          The single thread that ties every soundbite together, so your
          messaging feels like one voice instead of five disconnected lines.
        </Text>
      </div>
      <div class="m2m_card m2m-sprint-deliverable_card">
        <span class="m2m_card_number u-font-mono">05</span>
        <Heading tag="h3" variant="h4" marginBottom={0}>Tagline</Heading>
        <Text marginBottom={0}>
          A short memorable line that explains what you do in a single phrase or
          short sentence, so your offer is memorable and repeatable.
        </Text>
      </div>
      <div class="m2m_card m2m-sprint-deliverable_card">
        <span class="m2m_card_number u-font-mono">06</span>
        <Heading tag="h3" variant="h4" marginBottom={0}>
          Repeatable Closing Line
        </Heading>
        <Text marginBottom={0}>
          Instead of writing a new call to action every time, you have one
          proven line that turns interest into action wherever a decision
          happens.
        </Text>
      </div>
      <div class="m2m_card m2m-sprint-deliverable_card is-wide">
        <span class="m2m_card_number u-font-mono">07</span>
        <Heading tag="h3" variant="h4" marginBottom={0}>Deployment Map</Heading>
        <Text marginBottom={0}>
          The exact placement of every soundbite across every surface in your
          business. Homepage hero. Sales call open. Email subject lines.
          LinkedIn bio. Ad headlines. Nothing left to guess.
        </Text>
      </div>
      <div class="m2m_card m2m-sprint-deliverable_card is-wide">
        <span class="m2m_card_number u-font-mono">08</span>
        <Heading tag="h3" variant="h4" marginBottom={0}
          >Measurement Plan</Heading
        >
        <Text marginBottom={0}>
          A simple framework for tracking whether the messaging is landing —
          what to look for in your sales calls, your conversion rates, your
          inbound inquiries — so you'll know in 90 days whether it's working.
        </Text>
      </div>
    </Grid>
  </Section>

  <!-- ==================== WITH/WITHOUT ==================== -->
  <Section gap={6}>
    <Visual
      data-fade-up
      data-prevent-flicker="true"
      src={differenceImg}
      alt="A website that performs because the messaging behind it is locked in"
      ratio="widescreen"
      radius="main"
    />

    <ContentWrapper align="center">
      <Heading
        data-split-text
        data-prevent-flicker="true"
        tag="h2"
        maxWidth="22ch"
      >
        Same Business. Same Website. Very Different Year.
      </Heading>
    </ContentWrapper>

    <Grid
      data-fade-list
      data-prevent-flicker="true"
      largeColumns={2}
      mediumColumns={1}
      rowGap={6}
    >
      <div class="m2m-sprint-compare_card u-theme-brand">
        <div class="m2m-sprint-compare_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}>
            Without Locked-In Messaging
          </Heading>
        </div>
        <ul class="u-list">
          <li>You rewrite your homepage. Again.</li>
          <li>Your team can't agree on the elevator pitch.</li>
          <li>
            You wing your sales pitch on every call, and no two sound alike.
          </li>
          <li>You blame the design and brace for another redesign.</li>
        </ul>
      </div>

      <div class="m2m-sprint-compare_card u-theme-dark">
        <div class="m2m-sprint-compare_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}>
            With Locked-In Messaging
          </Heading>
        </div>
        <ul class="u-list">
          <li>Your homepage stays put because it works.</li>
          <li>Your team, ads, and posts all say the same thing.</li>
          <li>You enter every sales call knowing exactly what to say.</li>
          <li>The site you already have starts converting.</li>
        </ul>
      </div>
    </Grid>
  </Section>

  <!-- ==================== INVESTMENT ==================== -->
  <Section theme="brand" padding="large">
    <Layout variant="columns" verticalAlign="start">
      <Col slot="col1">
        <Heading data-fade-in variant="eyebrow">
          Your Investment Pays for Itself
        </Heading>
        <Heading data-split-text>
          Flat-Priced, 2-3 Weeks, No Surprises
        </Heading>
        <Text data-fade-up>
          Two to three weeks, start to finish. You'll know exactly what you're
          getting, when you're getting it, and what to do with it before we
          start.
        </Text>
      </Col>
      <PricingCard
        slot="col2"
        theme="light"
        variant="general"
        priceLabel="Messaging Sprint"
        price="$2,500"
        href="/book-a-call"
        buttonText="Let's Fix Your Messaging"
        ariaLabel="Let's fix your messaging"
        data-fade-up
        data-prevent-flicker="true"
      >
        <PricingItem>Ideal Customer Profile</PricingItem>
        <PricingItem>Messaging soundbites</PricingItem>
        <PricingItem>150-Word Business Story</PricingItem>
        <PricingItem>Controlling Idea</PricingItem>
        <PricingItem>Tagline</PricingItem>
        <PricingItem>Closing Line</PricingItem>
        <PricingItem>Deployment Map</PricingItem>
        <PricingItem>Measurement Plan</PricingItem>
      </PricingCard>
    </Layout>
  </Section>

  <!-- ==================== HOW IT WORKS ==================== -->
  <HowItWorks>
    <Fragment slot="eyebrow">How the Sprint Works</Fragment>
    <Fragment slot="heading">
      Three Phases. Two to Three Weeks. One Locked-In Messaging System.
    </Fragment>
    <Fragment slot="intro"></Fragment>
    <Fragment slot="step1Title">Research and Discovery</Fragment>
    <Fragment slot="step1Body">
      You complete the M2M Workbook. We dig into your business, your customers,
      and your competitors, and we pull the actual language your buyers use. By
      the end of week one, your ideal customer profile takes shape.
    </Fragment>
    <Fragment slot="step2Title">Drafting and Refinement</Fragment>
    <Fragment slot="step2Body">
      We draft your messaging. You see everything in progress and we work
      together to refine the messages so it sounds like you. By the end of week
      two, the messaging system is in v1.
    </Fragment>
    <Fragment slot="step3Title">Finalize and Handoff</Fragment>
    <Fragment slot="step3Body">
      We finalize every deliverable based on your feedback. You get the complete
      messaging system in a single document, ready to use across your business.
      We walk through it together so you know how to deploy each piece.
    </Fragment>
  </HowItWorks>

  <!-- ==================== END RESULTS ==================== -->
  <Section>
    <Layout variant="columns" verticalAlign="center">
      <Col slot="col1">
        <Heading
          data-split-text
          data-prevent-flicker="true"
          tag="h2"
          variant="h3"
        >
          Know Exactly What to Say, Everywhere You Say It
        </Heading>
        <Text data-fade-up data-prevent-flicker="true">
          A few weeks from now, you stop second-guessing your own words. You
          know who you're talking to, what to say to them, and where every piece
          goes.
        </Text>
        <Text data-fade-up data-prevent-flicker="true">
          Your homepage, your sales conversations, your posts, your lead
          magnets, and your emails all carry the same messaging, toward the
          customer you actually want.
        </Text>
        <div class="u-button-wrapper" data-fade-up data-prevent-flicker="true">
          <Button href="/book-a-call" ariaLabel="Let's fix your messaging">
            Let's Fix Your Messaging
          </Button>
        </div>
      </Col>
      <Visual
        data-fade-up
        data-prevent-flicker="true"
        slot="col2"
        src={knowImg}
        alt="One messaging system deployed across the website, social, sales, and email"
        ratio="landscape"
      />
    </Layout>
  </Section>

  <!-- ==================== RIGHT FIT ==================== -->
  <Section theme="dark" padding="small">
    <ContentWrapper align="center">
      <Heading
        data-fade-in
        variant="eyebrow"
        class="u-color-brand"
      >
        Is the Sprint Right For You?
      </Heading>
    </ContentWrapper>

    <Grid
      data-fade-list
      data-prevent-flicker="true"
      largeColumns={2}
      mediumColumns={1}
      rowGap={6}
      columnGap={8}
    >
      <div class="m2m-sprint-fit_column">
        <Heading tag="h3" variant="h4">The Sprint Is Right For</Heading>
        <div class="m2m-sprint-fit_list">
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-check" aria-hidden="true">
              <CheckMarkIcon />
            </span>
            <Text marginBottom={0}>
              Founders who've outgrown the messaging they launched with
            </Text>
          </div>
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-check" aria-hidden="true">
              <CheckMarkIcon />
            </span>
            <Text marginBottom={0}>
              Businesses with a working website but inconsistent words across
              channels
            </Text>
          </div>
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-check" aria-hidden="true">
              <CheckMarkIcon />
            </span>
            <Text marginBottom={0}>
              Teams who can't agree on the elevator pitch
            </Text>
          </div>
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-check" aria-hidden="true">
              <CheckMarkIcon />
            </span>
            <Text marginBottom={0}>
              Operators who know they need messaging help but aren't ready for a
              redesign
            </Text>
          </div>
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-check" aria-hidden="true">
              <CheckMarkIcon />
            </span>
            <Text marginBottom={0}>
              Anyone who's rewritten their homepage three or more times in the
              last year
            </Text>
          </div>
        </div>
      </div>

      <div class="m2m-sprint-fit_column">
        <Heading tag="h3" variant="h4">Not the Right Fit If</Heading>
        <div class="m2m-sprint-fit_list">
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-x" aria-hidden="true">
              <XIcon />
            </span>
            <Text marginBottom={0}>
              You haven't defined what your business actually does
            </Text>
          </div>
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-x" aria-hidden="true">
              <XIcon />
            </span>
            <Text marginBottom={0}>
              You're not willing to spend time on the M2M Workbook (the Sprint
              is a collaboration)
            </Text>
          </div>
          <div class="m2m-sprint-fit_item u-text-shrink">
            <span class="m2m-sprint-fit_icon is-x" aria-hidden="true">
              <XIcon />
            </span>
            <Text marginBottom={0}>
              You're hoping this engagement will replace your sales team
            </Text>
          </div>
        </div>
      </div>
    </Grid>

    <Visual
      data-fade-up
      data-prevent-flicker="true"
      src={rightForImg}
      alt="Founder working through the M2M Workbook to lock in messaging"
      ratio="widescreen"
      radius="main"
    />
  </Section>

  <!-- ==================== CTA ==================== -->
  <CTASection
    heading="If you're tired of rewriting your content and still ending up with the wrong words, the M2M Messaging Sprint is the right next step"
    text="Book a short call to get started."
    buttonText="Let's Fix Your Messaging"
    buttonHref="/book-a-call"
    secondaryButtonText=""
  />

  <!-- ==================== TESTIMONIALS ==================== -->
  <TestimonialShowcase />

  <!-- ==================== FAQ's ==================== -->
  <FAQ items={m2mMessagingSprintFaqs} />

  <!-- ==================== OPTIONAL CTA ==================== -->
  <Section theme="brand" padding="small">
    <Layout variant="stack">
      <Col slot="col1">
        <Heading
          data-split-text
          data-prevent-flicker="true"
          tag="h2"
          variant="h3"
          maxWidth="22ch"
        >
          Not ready to start a messaging sprint?
        </Heading>
        <Text data-fade-up data-prevent-flicker="true">
          Download the Free M2M Worksheet. It helps you determine your Ideal
          Customer and represents step one in the M2M Messaging Sprint.
        </Text>
        <div class="u-button-wrapper" data-fade-up data-prevent-flicker="true">
          <Button
            variant="secondary"
            href="/m2m-framework#m2m-worksheet"
            ariaLabel="Download the M2M Worksheet"
          >
            Download the M2M Worksheet
          </Button>
        </div>
      </Col>
    </Layout>
  </Section>
</BaseLayout>
