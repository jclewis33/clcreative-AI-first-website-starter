---
/**
 * Component Examples — a living showcase of every UI component and variant.
 *
 * Built entirely with system components and utility classes — zero custom CSS.
 * Visit /components to view it.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Grid from "../components/ui/Grid.astro";
import Card from "../components/ui/Card.astro";
import Accordion from "../components/ui/Accordion.astro";
import AccordionItem from "../components/ui/AccordionItem.astro";
import Modal from "../components/ui/Modal.astro";
import Slider from "../components/ui/Slider.astro";
import Tab from "../components/ui/Tab.astro";
import TabButton from "../components/ui/TabButton.astro";
import TabPanel from "../components/ui/TabPanel.astro";
import Button from "../components/ui/Button.astro";
import TestimonialsSlider from "../components/sections/TestimonialsSlider.astro";
import TestimonialsGrid from "../components/sections/TestimonialsGrid.astro";
import { getTestimonials } from "../sanity/lib/testimonials";
import Form from "../components/form/Form.astro";
import FormField from "../components/form/FormField.astro";
import FormFieldset from "../components/form/FormFieldset.astro";
import FormTextarea from "../components/form/FormTextarea.astro";
import FormSelect from "../components/form/FormSelect.astro";
import FormCheckbox from "../components/form/FormCheckbox.astro";
import FormRadio from "../components/form/FormRadio.astro";
import FormRange from "../components/form/FormRange.astro";
import Visual from "../components/ui/Visual.astro";
import BlogPostGrid from "../components/sections/BlogPostGrid.astro";

import humanTouch from "../assets/placeholder-images/placeholder-15.webp";
import manCouch from "../assets/placeholder-images/placeholder-16.webp";
import CaseStudyGrid from "../components/sections/CaseStudyGrid.astro";
import ContentWrapper from "../components/ui/ContentWrapper.astro";
import PricingCard from "../components/ui/PricingCard.astro";
import PricingItem from "../components/ui/PricingItem.astro";
import Marquee from "../components/ui/Marquee.astro";
import ScrollReveal from "../components/ui/ScrollReveal.astro";

/* ── Fetch testimonials from Sanity (tolerate an empty/unreachable dataset) ── */
import { getDraftModeProps } from "../sanity/lib/draft-mode";
const testimonials = await getTestimonials(getDraftModeProps(Astro)).catch(
  () => [],
);
---

<BaseLayout
  title="Component Examples | Design System"
  description="Real-world component patterns built with this design system. Composable, accessible, and ready to use."
>
  <!-- ============================================================
       1. HERO
       ============================================================ -->
  <Section
    docs=""
    paddingTop="page-top"
    paddingBottom="large"
    theme="brand"
    id="hero"
  >
    <Layout docs="" variant="stack-centered">
      <Col slot="col1">
        <Heading variant="eyebrow">Component Library</Heading>
        <Heading tag="h1" variant="display-lg" balance accent>
          Build faster with <strong>reusable components</strong>
        </Heading>
        <Text variant="large" align="center" muted maxWidth="32rem">
          Every component in this library is built with Astro and styled with
          the design system. Composable, accessible, and ready to ship.
        </Text>
        <div class="u-button-wrapper">
          <Button
            href="/style-guide"
            size="large"
            ariaLabel="Browse style guide">Browse Style Guide</Button
          >
          <Button
            variant="secondary"
            size="large"
            data-modal-trigger="comp-modal-small"
            ariaLabel="Open a modal"
          >
            Open a Modal
          </Button>
        </div>
      </Col>
    </Layout>
  </Section>

  <Section docs="" minHeight>
    <Layout docs="">
      <Col slot="col1">
        <Heading docs="" variant="h2"
          >Build faster with reusable components</Heading
        >
        <Text docs="">
          Every component in this library is built with Astro and styled with
          the design system. Composable, accessible, and ready to ship.</Text
        >
        <div class="u-button-wrapper">
          <Button docs="" href="#">Sign Up Now</Button>
        </div>
      </Col>
      <Visual
        slot="col2"
        docs=""
        src={manCouch}
        alt="man on couch looking at computer"
        ratio="square"
      />
    </Layout>
  </Section>

  <!-- ============================================================
       2. LAYOUT VARIANTS
       ============================================================ -->
  <Section padding="large" theme="light" id="layout">
    <ContentWrapper>
      <Heading variant="eyebrow" class="u-margin-bottom-2">Layout</Heading>
      <Heading tag="h2" balance>Flexible two-column layouts</Heading>
      <Text variant="regular" muted maxWidth="48rem">
        The Layout component provides 13 named two-column variants. Use col1 and
        col2 named slots to fill each column. All variants collapse to a single
        column on mobile.
      </Text>
    </ContentWrapper>

    <!-- ── columns ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >columns</Heading
    >
    <Layout variant="columns" verticalAlign="center">
      <Col slot="col1">
        <Heading variant="eyebrow" class="u-margin-bottom-3"
          >50 / 50 split</Heading
        >
        <Heading tag="h3" variant="h2" balance>
          Equal columns, side by side
        </Heading>
        <Heading tag="h3" variant="h2" balance>
          Equal columns, side by side
        </Heading>
        <Text muted>
          Use variant="columns" for a balanced split. Great for feature sections
          where text and visuals share equal weight.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#" ariaLabel="Get started">Get started</Button>
          <Button variant="secondary" href="#" ariaLabel="Learn more"
            >Learn more</Button
          >
        </div>
      </Col>
      <img
        slot="col2"
        src="https://picsum.photos/seed/layout-col/800/600"
        alt="Placeholder image"
        loading="lazy"
        style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; border-radius: var(--radius-large);"
      />
    </Layout>

    <!-- ── columns-reversed ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >columns-reversed</Heading
    >
    <Layout variant="columns-reversed" verticalAlign="center">
      <Col slot="col1">
        <Heading variant="eyebrow" class="u-margin-bottom-3"
          >Reversed order</Heading
        >
        <Heading tag="h3" variant="h2" balance>
          Image left, content right
        </Heading>
        <Text muted>
          Use variant="columns-reversed" to visually flip the columns on
          desktop. Column 2 appears on the left. Great for alternating feature
          sections.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#" ariaLabel="Explore">Explore</Button>
        </div>
      </Col>
      <img
        slot="col2"
        src="https://picsum.photos/seed/layout-rev/800/600"
        alt="Placeholder image"
        loading="lazy"
        style="width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; border-radius: var(--radius-large);"
      />
    </Layout>

    <!-- ── breakout ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >breakout</Heading
    >
    <Layout variant="breakout" verticalAlign="center">
      <Col slot="col1">
        <Heading variant="eyebrow" class="u-margin-bottom-3">Edge bleed</Heading
        >
        <Heading tag="h3" variant="h2" balance>
          Narrow accent, wide content
        </Heading>
        <Text muted>
          Use variant="breakout" when you want a narrow left accent panel with a
          wide right content area — great for feature callouts. The image column
          bleeds to the viewport edge.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#" ariaLabel="Explore">Explore</Button>
        </div>
      </Col>

      <Visual
        src={"https://picsum.photos/seed/layout-bk/800/1000"}
        ratio="16/9"
        alt="layout image"
        slot="col2"
        width={1200}
        height={900}
      />
    </Layout>

    <!-- ── contain (card layout) ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >contain</Heading
    >
    <Layout variant="contain">
      <Col slot="col1">
        <Heading variant="eyebrow" class="u-margin-bottom-3"
          >Card layout</Heading
        >
        <Heading tag="h3" variant="h2" balance>
          Content and image in a card
        </Heading>
        <Text muted>
          Use variant="contain" to wrap both columns in a rounded card with a
          background color. The left column is padded content; the right clips
          an image to the card shape.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#" ariaLabel="Learn more">Learn more</Button>
        </div>
      </Col>
      <img
        slot="col2"
        src="https://picsum.photos/seed/layout-contain/800/600"
        alt="Placeholder image"
        loading="lazy"
        style="width: 100%; height: 100%; object-fit: cover; display: block;"
      />
    </Layout>

    <!-- ── contain-reversed ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >contain-reversed</Heading
    >
    <Layout variant="contain-reversed">
      <img
        slot="col1"
        src="https://picsum.photos/seed/layout-contain-rev/800/600"
        alt="Placeholder image"
        loading="lazy"
        style="width: 100%; height: 100%; object-fit: cover; display: block;"
      />
      <Col slot="col2">
        <Heading variant="eyebrow" class="u-margin-bottom-3"
          >Reversed card</Heading
        >
        <Heading tag="h3" variant="h2" balance>
          Image left, content right
        </Heading>
        <Text muted>
          Use variant="contain-reversed" to flip the card layout. The image
          clips to the left side and the padded content sits on the right.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#" ariaLabel="Explore">Explore</Button>
        </div>
      </Col>
    </Layout>

    <!-- ── sticky-left ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >sticky-left</Heading
    >
    <Layout variant="sticky-left" verticalAlign="start">
      <Col slot="col1">
        <Heading variant="eyebrow" class="u-margin-bottom-3"
          >Sticky column</Heading
        >
        <Heading tag="h3" variant="h2" balance>
          Left column stays fixed
        </Heading>
        <Text muted>
          Use variant="sticky-left" when the left column should stay visible
          while the right column scrolls. Perfect for table of contents, labels,
          or navigation.
        </Text>
      </Col>
      <Col slot="col2">
        <Text class="u-margin-bottom-5">
          Scroll this column to see the left side stay in place. This pattern
          works great for FAQ layouts, documentation sidebars, and feature
          comparison sections.
        </Text>
        <Text class="u-margin-bottom-5">
          The sticky behavior activates on desktop viewports and collapses to a
          standard stacked layout on mobile — so there's no accessibility
          concern.
        </Text>
        <Text>
          You can combine this with the ratio prop for asymmetric splits, like
          ratio="4-8" for a narrow label column and wide content area.
        </Text>
      </Col>
    </Layout>

    <!-- ── columns + ratio ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >columns + ratio</Heading
    >
    <Layout variant="columns" ratio="5-7" verticalAlign="start">
      <Col slot="col1">
        <Heading variant="eyebrow" class="u-margin-bottom-3"
          >Custom ratio</Heading
        >
        <Heading tag="h3" variant="h2" balance>
          Label left, content right
        </Heading>
        <Text muted>
          Add ratio="5-7" to any two-column variant for a custom split. Works
          with columns, columns-reversed, sticky-left, and contain.
        </Text>
      </Col>
      <Grid slot="col2" variant="autofit" minColWidth="12rem" rowGap={4}>
        <Card variant="stacked" title="01">
          <Text weight="bold">Discovery</Text>
          <Text muted
            >Understand your audience, goals, and competitive landscape.</Text
          >
        </Card>
        <Card variant="stacked" title="02">
          <Text weight="bold">Design</Text>
          <Text muted
            >Build a pixel-perfect system grounded in your brand identity.</Text
          >
        </Card>
        <Card variant="stacked" title="03">
          <Text weight="bold">Develop</Text>
          <Text muted
            >Ship production-ready Astro code that's fast and maintainable.</Text
          >
        </Card>
      </Grid>
    </Layout>

    <!-- ── stack ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >stack</Heading
    >
    <Layout variant="stack">
      <Col slot="col1">
        <Heading tag="h3" variant="h2" balance
          >Single column, left-aligned</Heading
        >
        <Text muted>
          Use variant="stack" for a single-column layout that aligns content to
          the left. Great for article content or simple text sections.
        </Text>
      </Col>
    </Layout>

    <!-- ── stack-centered ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >stack-centered</Heading
    >
    <Layout variant="stack-centered">
      <Col slot="col1">
        <Heading tag="h3" variant="h2" balance>Single column, centered</Heading>
        <Text align="center" muted>
          Use variant="stack-centered" for a centered single-column layout.
          Perfect for hero sections, CTAs, and centered introductions.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#" ariaLabel="Get started">Get started</Button>
        </div>
      </Col>
      <Visual
        slot="col2"
        src={humanTouch}
        alt="human touch image"
        ratio="wide"
      />
    </Layout>

    <!-- ── auto-width ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >auto-width</Heading
    >
    <Layout variant="auto-width" verticalAlign="center">
      <Heading slot="col1" tag="h3" variant="h4">Auto-sized</Heading>
      <Text slot="col2" muted
        >Both columns size to their content — neither stretches to fill.</Text
      >
    </Layout>

    <!-- ── card ── -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-4"
      >card (centered card with background)</Heading
    >
    <Layout variant="card">
      <Col slot="col1">
        <Heading tag="h3" variant="h3">Centered card layout</Heading>
        <Text>
          Use variant="card" for a rounded, clipped card. Content in col1 is
          centered with padding. Col2 is positioned absolutely as the background
          — place a Visual and Overlay there for a background image CTA.
        </Text>
        <div class="u-button-wrapper">
          <Button href="#" ariaLabel="Example button">Example CTA</Button>
        </div>
      </Col>
    </Layout>
  </Section>

  <!-- ============================================================
       3. CARDS
       ============================================================ -->
  <Section padding="large" theme="dark" id="cards">
    <ContentWrapper data-animate-in>
      <Heading variant="eyebrow" class="u-margin-bottom-2">Card</Heading>
      <Heading tag="h2" balance>Three card variants</Heading>
      <Text variant="regular" muted maxWidth="48rem">
        The Card component supports default, stacked, and cover variants. Use
        href to make the entire card surface a clickable link.
      </Text>
    </ContentWrapper>

    <!-- default cards -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-5"
      >default — visual on top, content below</Heading
    >
    <Grid largeColumns={3} mediumColumns={2} smallColumns={1} data-animate-up>
      {
        [
          {
            seed: "card-d1",
            title: "Strategic Web Design",
            text: "Every pixel serves a purpose. We build interfaces that convert visitors into customers.",
          },
          {
            seed: "card-d2",
            title: "Custom Development",
            text: "Clean, maintainable Astro code that performs at the highest level on any device.",
          },
          {
            seed: "card-d3",
            title: "SEO Architecture",
            text: "Sites built with a crawl-first mindset — structured data, performance, and authority.",
          },
        ].map(({ seed, title, text }) => (
          <Card variant="default" title={title} href="#">
            <img
              slot="visual"
              src={`https://picsum.photos/seed/${seed}/800/500`}
              alt={title}
              loading="lazy"
              style="width:100%; aspect-ratio:16/9; object-fit:cover; display:block;"
            />
            <Text muted clamp={3}>
              {text}
            </Text>
            <div slot="footer">
              <Button variant="text" href="#" ariaLabel="Read more">
                Read more →
              </Button>
            </div>
          </Card>
        ))
      }
    </Grid>

    <!-- stacked cards -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-5"
      >stacked — text-only, no visual</Heading
    >
    <Grid largeColumns={3} mediumColumns={2} smallColumns={1} data-animate-up>
      {
        [
          {
            title: "Zero JS by Default",
            text: "Astro ships no client-side JS unless you opt in — pages load instantly.",
            tag: "Performance",
          },
          {
            title: "TypeScript Props",
            text: "Every component is typed. Editor autocomplete and type safety everywhere.",
            tag: "DX",
          },
          {
            title: "Accessible Patterns",
            text: "ARIA, keyboard navigation, and semantic HTML are baked in from day one.",
            tag: "A11y",
          },
        ].map(({ title, text, tag }) => (
          <Card variant="stacked" title={title}>
            <Text muted>{text}</Text>
            <div slot="footer">
              <Heading variant="eyebrow">{tag}</Heading>
            </div>
          </Card>
        ))
      }
    </Grid>

    <!-- cover cards -->
    <Heading variant="eyebrow" class="u-margin-top-8 u-margin-bottom-5"
      >cover — image fills card, content overlays</Heading
    >
    <Grid largeColumns={3} mediumColumns={2} smallColumns={1} data-animate-up>
      {
        [
          {
            seed: "cover-c1",
            title: "Wizard Perks",
            text: "Loyalty platform for retail brands.",
          },
          {
            seed: "cover-c2",
            title: "Astro Starter",
            text: "Always-on recruiting automation.",
          },
          {
            seed: "cover-c3",
            title: "TreeRing",
            text: "Custom school yearbooks, reimagined.",
          },
        ].map(({ seed, title, text }) => (
          <Card variant="cover" title={title} href="#">
            <img
              slot="visual"
              src={`https://picsum.photos/seed/${seed}/800/1000`}
              alt={title}
              loading="lazy"
              style="width:100%; height:100%; object-fit:cover; display:block;"
            />
            <Text muted>{text}</Text>
          </Card>
        ))
      }
    </Grid>
  </Section>

  <!-- cover cards -->
  <CaseStudyGrid docs="" limit={6} />

  <!-- ============================================================
       4. SLIDER
       ============================================================ -->
  <Section padding="large" theme="dark" id="slider">
    <ContentWrapper>
      <Heading variant="eyebrow" class="u-margin-bottom-2">Slider</Heading>
      <Heading tag="h2" balance>Touch-friendly card carousel</Heading>
      <Text variant="regular" muted maxWidth="48rem">
        The Slider component wraps Swiper v8. Each slide must be a .swiper-slide
        div. Control per-breakpoint slide counts with slidesLg, slidesMd, and
        slidesSm.
      </Text>
    </ContentWrapper>

    <div class="u-margin-top-8">
      <Slider
        slidesLg={3}
        slidesMd={2}
        slidesSm={1.2}
        showBullets={true}
        showArrows={true}
      >
        {
          [
            {
              seed: "sl-1",
              title: "Web Design",
              text: "High-converting pages built on this design system.",
            },
            {
              seed: "sl-2",
              title: "Development",
              text: "Astro + clean code that scales with your business.",
            },
            {
              seed: "sl-3",
              title: "Brand Identity",
              text: "Visual systems that make your brand unmistakable.",
            },
            {
              seed: "sl-4",
              title: "SEO Strategy",
              text: "Authority architecture that earns traffic and trust.",
            },
            {
              seed: "sl-5",
              title: "Analytics",
              text: "Data-informed decisions from day one of launch.",
            },
            {
              seed: "sl-6",
              title: "Conversion Rate",
              text: "A/B testing and UX audit to maximise every visit.",
            },
          ].map(({ seed, title, text }) => (
            <div class="swiper-slide">
              <Card variant="default" title={title} href="#">
                <img
                  slot="visual"
                  src={`https://picsum.photos/seed/${seed}/800/500`}
                  alt={title}
                  loading="lazy"
                  style="width:100%; aspect-ratio:16/9; object-fit:cover; display:block;"
                />
                <Text muted clamp={2}>
                  {text}
                </Text>
              </Card>
            </div>
          ))
        }
      </Slider>
    </div>
  </Section>

  <!-- ============================================================
       MARQUEE
       ============================================================ -->
  <Section padding="large" theme="dark" id="marquee">
    <ContentWrapper>
      <Heading variant="eyebrow" class="u-margin-bottom-2">Marquee</Heading>
      <Heading tag="h2" balance>Infinite scrolling ticker</Heading>
      <Text variant="regular" muted maxWidth="48rem">
        The Marquee component uses GSAP for smooth infinite horizontal
        scrolling. Drop in text, logos, or any content. Pauses on hover.
      </Text>
    </ContentWrapper>

    <div class="u-margin-top-8">
      <Marquee>
        <span class="marquee_item u-text-style-h3">Design</span>
        <span class="marquee_item u-text-style-h3">Develop</span>
        <span class="marquee_item u-text-style-h3">Deploy</span>
        <span class="marquee_item u-text-style-h3">Iterate</span>
        <span class="marquee_item u-text-style-h3">Scale</span>
        <span class="marquee_item u-text-style-h3">Optimize</span>
      </Marquee>
    </div>

    <div class="u-margin-top-8">
      <Marquee direction="right" speed={30} gap={8}>
        <span class="marquee_item u-text-style-large u-text-style-muted"
          >Webflow</span
        >
        <span class="marquee_item u-text-style-large u-text-style-muted"
          >Astro</span
        >
        <span class="marquee_item u-text-style-large u-text-style-muted"
          >GSAP</span
        >
        <span class="marquee_item u-text-style-large u-text-style-muted"
          >Figma</span
        >
        <span class="marquee_item u-text-style-large u-text-style-muted"
          >TypeScript</span
        >
        <span class="marquee_item u-text-style-large u-text-style-muted"
          >Sanity</span
        >
      </Marquee>
    </div>
  </Section>

  <!-- ============================================================
       SCROLL REVEAL
       ============================================================ -->
  <Section padding="large" theme="dark" id="scroll-reveal">
    <ContentWrapper>
      <Heading variant="eyebrow" class="u-margin-bottom-2"
        >Scroll Reveal</Heading
      >
      <Heading tag="h2" balance>Scroll-linked sticky image reveal</Heading>
      <Text variant="regular" muted maxWidth="48rem">
        Text blocks fade in and out on the left while a sticky image on the
        right cross-fades to match the active block. Collapses to inline images
        on mobile.
      </Text>
    </ContentWrapper>

    <div class="u-margin-top-8">
      <ScrollReveal
        items={[
          {
            eyebrow: "Platform",
            heading: "Powerful analytics dashboard",
            text: "Track every metric that matters to your business with real-time dashboards and custom reports.",
            image: humanTouch,
            imageAlt: "Analytics dashboard screenshot",
          },
          {
            heading: "Automated workflows",
            text: "Set it and forget it. Our automation engine handles repetitive tasks so your team can focus on what matters.",
            image: manCouch,
            imageAlt: "Workflow builder interface",
            buttonHref: "#",
            buttonText: "Learn more",
          },
          {
            heading: "Real-time collaboration",
            text: "Work together seamlessly, no matter where your team is located. Changes sync instantly across all devices.",
            image: humanTouch,
            imageAlt: "Team collaboration view",
          },
          {
            eyebrow: "Security",
            heading: "Enterprise-grade security",
            text: "Your data is protected with bank-level encryption, SSO, and compliance certifications your security team will love.",
            image: manCouch,
            imageAlt: "Security settings panel",
          },
        ]}
      />
    </div>
  </Section>

  <!-- ============================================================
       5. TABS
       ============================================================ -->
  <Section padding="large" theme="light" id="tabs">
    <ContentWrapper>
      <Heading variant="eyebrow" class="u-margin-bottom-2">Tab</Heading>
      <Heading tag="h2" balance>Four tab variants</Heading>
