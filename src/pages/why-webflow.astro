---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Visual from "../components/ui/Visual.astro";
import Button from "../components/ui/Button.astro";

import "../styles/pages/why-webflow.css";

import CTASection from "../components/sections/CTASection.astro";
import StackingPanels from "../components/sections/StackingPanels.astro";
import StackingPanel from "../components/sections/StackingPanel.astro";
import partnerBadge from "../assets/why-webflow/Badge_Professional_Partner_White@2x 1.png";
import professionalPartnerImg from "../assets/why-webflow/why-webflow-professional-partner.avif";
import heroImg from "../assets/why-webflow/why-webflow-hero.avif";
import shipFasterImg from "../assets/why-webflow/why-webflow-ship-faster.avif";
import controlContentImg from "../assets/why-webflow/why-webflow-control-content.avif";
import scaleImg from "../assets/why-webflow/why-webflow-scale.avif";
import rightFitImg from "../assets/why-webflow/why-webflow-right-fit.avif";
import ContentWrapper from "../components/ui/ContentWrapper.astro";
import Grid from "../components/ui/Grid.astro";
---

<BaseLayout
  title="Why Webflow | CL Creative"
  description="After 100+ projects, we've built on every platform that matters. Webflow is the one we keep coming back to."
  theme="light"
>
  <!-- Hero -->
  <Section>
    <Layout variant="stack-centered">
      <Col slot="col1">
        <div class="why-webflow_hero_badge">
          <img
            data-fade-up
            data-prevent-flicker="true"
            src={partnerBadge.src}
            alt="Webflow Professional Partner"
            width="164"
            height="25"
          />
        </div>
        <Heading
          data-split-text
          data-prevent-flicker="true"
          tag="h1"
          variant="h1"
          maxWidth="30ch"
          >Webflow is the platform we trust to build websites that perform.</Heading
        >
        <Text data-fade-up data-prevent-flicker="true" data-delay="0.2"
          >After 50+ projects, we've built on every platform that matters.
          Webflow is the one we keep coming back to, because it gives
          growth-stage businesses speed, control, and a foundation that scales
          without a rebuild every two years.</Text
        >
        <div
          class="u-button-wrapper"
          data-fade-up
          data-prevent-flicker="true"
          data-delay="0.4"
        >
          <Button href="/book-a-call" ariaLabel="Talk to a Webflow partner"
            >Talk to a Webflow Partner</Button
          >
          <Button
            variant="secondary"
            href="/case-studies"
            ariaLabel="See how we use Webflow">See How We Use Webflow</Button
          >
        </div>
      </Col>
      <Visual
        data-fade-up
        data-prevent-flicker="true"
        data-delay="0.5"
        slot="col2"
        src={heroImg}
        alt="Collage of websites built with Webflow by CL Creative"
        ratio="widescreen"
        radius="main"
      />
    </Layout>
  </Section>

  <!-- How do you know -->
  <Section theme="dark">
    <Layout verticalAlign="start" variant="sticky-left">
      <Heading data-split-text data-prevent-flicker="true" slot="col1"
        >How do you know your website is hurting your business?</Heading
      >
      <Col slot="col2">
        <Text data-fade-in data-prevent-flicker="true"
          >Most growth-stage founders don't realize their website is the
          bottleneck until they lose a deal they should have won. The signs are
          more subtle than you'd expect.</Text
        >
        <Text data-fade-in data-prevent-flicker="true"
          >You probably need a new platform if:</Text
        >
        <ul
          class="why-webflow_check_list"
          data-fade-list
          data-prevent-flicker="true"
        >
          <li class="why-webflow_check_item u-text-shrink">
            <svg
              class="why-webflow_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >Your team has to file a ticket with a developer just to update a
              headline</Text
            >
          </li>
          <li class="why-webflow_check_item u-text-shrink">
            <svg
              class="why-webflow_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >Your site takes more than three seconds to load on mobile</Text
            >
          </li>
          <li class="why-webflow_check_item u-text-shrink">
            <svg
              class="why-webflow_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >You've outgrown the template you launched on but can't break out
              of it without a full rebuild</Text
            >
          </li>
          <li class="why-webflow_check_item u-text-shrink">
            <svg
              class="why-webflow_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >Your marketing team has ideas they can't ship because the
              platform won't let them</Text
            >
          </li>
          <li class="why-webflow_check_item u-text-shrink">
            <svg
              class="why-webflow_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >You're paying for plugins, hosting, security, and maintenance
              from four different vendors</Text
            >
          </li>
          <li class="why-webflow_check_item u-text-shrink">
            <svg
              class="why-webflow_check_icon"
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M18.3337 9.23843V10.0051C18.3326 11.8021 17.7507 13.5507 16.6748 14.99C15.5988 16.4292 14.0864 17.4822 12.3631 17.9917C10.6399 18.5012 8.79804 18.44 7.11238 17.8172C5.42673 17.1945 3.98754 16.0435 3.00946 14.536C2.03138 13.0285 1.56682 11.2451 1.68506 9.45202C1.80329 7.6589 2.498 5.95203 3.66556 4.58599C4.83312 3.21994 6.41098 2.26791 8.16382 1.87188C9.91665 1.47585 11.7505 1.65704 13.392 2.38843M18.3337 3.33366L10.0003 11.6753L7.50033 9.17533"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            <Text tag="span" marginBottom={0}
              >Your last redesign was supposed to last five years, and you're
              already shopping for the next one</Text
            >
          </li>
        </ul>
        <Text data-prevent-flicker="true" data-fade-in
          >If two or more of those sound familiar, the platform is probably the
          problem. And the platform we'd point you to is Webflow.</Text
        >
        <div class="u-button-wrapper" data-fade-in data-prevent-flicker="true">
          <Button href="/how-we-work" ariaLabel="How We Fix Your Website & Marketing">How We Fix Your Website & Marketing</Button>
        </div>
      </Col>
    </Layout>
  </Section>

  <!-- What You Get — Stacking Cards -->
  <StackingPanels>
    <Col slot="heading">
      <Heading data-fade-in data-prevent-flicker="true" variant="eyebrow"
        >What You Get</Heading
      >
      <Heading
        data-split-text
        data-prevent-flicker="true"
        tag="h2"
        variant="h2"
        >What growth-stage businesses get when they build on Webflow</Heading
      >
    </Col>

    <!-- Card 1: Ship Faster -->
    <StackingPanel>
      <Heading maxWidth="none" variant="eyebrow">Ship Faster</Heading>
      <Heading tag="h3" variant="h3">Launch in weeks. Update in minutes.</Heading>
      <Text
        >Webflow's visual development environment lets us build production-grade
        marketing sites in a fraction of the time WordPress takes without
        sacrificing quality or custom design.</Text
      >
      <Text
        >Once your site is live, your team can update copy, swap images, and
        publish new pages without filing a ticket or learning code.</Text
      >
      <Text>The result: less waiting, more shipping.</Text>
      <Visual
        slot="visual"
        src={shipFasterImg}
        alt="Webflow designer interface showing a school website"
        ratio="landscape"
      />
    </StackingPanel>

    <!-- Card 2: Control Your Content -->
    <StackingPanel reversed>
      <Heading maxWidth="none" variant="eyebrow">Control Your Content</Heading>
      <Heading tag="h3" variant="h3"
        >Your marketing team. In the driver's seat.</Heading
      >
      <Text
        >WordPress puts your content behind a wall of plugins, page builders,
        and developer dependencies.</Text
      >
      <Text
        >Webflow gives your marketing team direct control over the content that
        drives your business without the risk of breaking something every time
        they touch it.</Text
      >
      <Text
        >If your marketing team has ever been blocked by a developer, this is
        the fix.</Text
      >
      <Visual
        slot="visual"
        src={controlContentImg}
        alt="Team collaborating around a laptop"
        ratio="landscape"
      />
    </StackingPanel>

    <!-- Card 3: Scale Without Rebuilding -->
    <StackingPanel>
      <Heading maxWidth="none" variant="eyebrow">Scale Without Rebuilding</Heading>
      <Heading tag="h3" variant="h3"
        >Built to grow with you, not against you.</Heading
      >
      <Text
        >Most platforms force a full rebuild every two to three years as your
        business outgrows them.</Text
      >
      <Text
        >Webflow's component system, CMS, and clean code mean the site we build
        today can scale with you for years while adding new pages, new sections,
        new features without starting over.</Text
      >
      <Text
        >Your last redesign should be the last one you need for a while.</Text
      >
      <Visual
        slot="visual"
        src={scaleImg}
        alt="Webflow CMS collections dashboard"
        ratio="landscape"
      />
    </StackingPanel>
  </StackingPanels>

  <!-- Webflow vs WordPress Comparison -->
  <Section gap={4} theme="brand">
    <Layout variant="stack-centered">
      <Col slot="col1">
        <Heading data-fade-in data-prevent-flicker="true" variant="eyebrow"
          >Comparison</Heading
        >
        <Heading
          data-split-text
          data-prevent-flicker="true"
          tag="h2"
          variant="h2">Webflow vs WordPress</Heading
        >
        <Text data-fade-in data-prevent-flicker="true" align="center"
          >Most of our clients come to us from WordPress. Not because WordPress
          is bad — it built the modern web — but because it wasn't built for
          what growth-stage businesses need today.</Text
        >
      </Col>
    </Layout>

    <div class="comparison_table_wrap">
      <table class="comparison_table">
        <thead>
          <tr>
            <th class="comparison_table_label"></th>
            <th class="comparison_table_webflow comparison_table_header"
              >Webflow</th
            >
            <th class="comparison_table_wordpress comparison_table_header"
              >WordPress</th
            >
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="comparison_table_label">Time to launch</td>
            <td class="comparison_table_webflow">4–8 weeks</td>
            <td class="comparison_table_wordpress">3–6 months</td>
          </tr>
          <tr>
            <td class="comparison_table_label">Plugins required</td>
            <td class="comparison_table_webflow">None</td>
            <td class="comparison_table_wordpress">10–20 typical</td>
          </tr>
          <tr>
            <td class="comparison_table_label">Security maintenance</td>
            <td class="comparison_table_webflow">Built in</td>
            <td class="comparison_table_wordpress"
              >Ongoing, your responsibility</td
            >
          </tr>
          <tr>
            <td class="comparison_table_label">Page speed</td>
            <td class="comparison_table_webflow">Fast by default</td>
            <td class="comparison_table_wordpress"
              >Depends on plugins, hosting, theme</td
            >
          </tr>
          <tr>
            <td class="comparison_table_label">Marketing independence</td>
            <td class="comparison_table_webflow">High</td>
            <td class="comparison_table_wordpress">Low (developer-dependent)</td
            >
          </tr>
          <tr>
            <td class="comparison_table_label">Total cost over 3 years</td>
            <td class="comparison_table_webflow">Lower</td>
            <td class="comparison_table_wordpress"
              >Higher (hosting, plugins, dev hours)</td
            >
          </tr>
          <tr>
            <td class="comparison_table_label">Best for</td>
            <td class="comparison_table_webflow"
              >Marketing sites that need to move</td
            >
            <td class="comparison_table_wordpress"
              >Blogs, e-commerce, complex apps</td
            >
          </tr>
        </tbody>
      </table>
    </div>

    <ContentWrapper align="center">
      <Text maxWidth="64ch"
        >WordPress still wins for some use cases: high-volume blogs, complex
        e-commerce, custom applications. For everything else a growth-stage
        business needs from a marketing site, Webflow is the better tool.</Text
      >
      <div class="u-margin-top-6">
        <Button href="/how-we-work" ariaLabel="How We Fix Your Website & Marketing">How We Fix Your Website & Marketing</Button>
      </div>
    </ContentWrapper>
  </Section>

  <!-- Right Fit -->
  <Section gap={4}>
    <Visual
      data-fade-up
      data-prevent-flicker="true"
      src={rightFitImg}
      alt="Laptop showing a Webflow website on a desk with plants"
      ratio="widescreen"
      radius="large"
    />

    <Grid
      data-fade-list
      data-prevent-flicker="true"
      largeColumns={2}
      mediumColumns={1}
      rowGap={6}
      class="right-fit_grid"
    >
      <!-- Right fit card -->
      <div class="right-fit_card" data-theme="brand">
        <div class="right-fit_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}
            >Webflow is the right fit if…</Heading
          >
        </div>
        <Text
          >You're a growth-stage business with a marketing site that needs to
          move fast and scale cleanly. Specifically:</Text
        >
        <ul class="right-fit_list">
          <li>You're between $50K and $50M in revenue</li>
          <li>
            You have a marketing team (or marketing person) who needs to ship
            without waiting on a developer
          </li>
          <li>
            Your current site is on WordPress, Squarespace, Wix, or a custom
            build that's become a maintenance burden
          </li>
          <li>
            You're tired of paying for plugins, hosting, and developer hours
            that don't move the needle
          </li>
          <li>
            You need a site that can scale with you for the next 3–5 years, not
            just look good at launch
          </li>
        </ul>
      </div>

      <!-- Not right fit card -->
      <div class="right-fit_card" data-theme="dark">
        <div class="right-fit_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}
            >Webflow probably isn't the right fit if…</Heading
          >
        </div>
        <Text
          >We'd rather tell you the truth than sell you the wrong thing. Webflow
          is not the best choice if:</Text
        >
        <ul class="right-fit_list">
          <li>
            You're running a high-volume blog with hundreds of writers and a
            complex editorial workflow (stick with WordPress)
          </li>
          <li>
            You need a fully custom web application with user accounts,
            payments, and complex backend logic (you need a custom build, not a
            website platform)
          </li>
          <li>
            You're a Fortune 500 with a 50-person digital team and existing
            platform investments you can't migrate
          </li>
          <li>
            Your business needs nothing more than a simple one-page site you'll
            never update (Squarespace will do)
          </li>
        </ul>
      </div>
    </Grid>
  </Section>

  <!-- Professional Partner -->
  <Section padding="none">
    <Layout
      variant="full-reversed"
      verticalAlign="center"
      columnGap="var(--gap-8)"
    >
      <Col slot="col1">
        <div class="why-webflow_partner_content">
          <div class="why-webflow_partner_badge">
            <img
              src={partnerBadge.src}
              alt="Webflow Professional Partner"
              width="164"
              height="25"
            />
          </div>
          <Heading
            data-fade-in
            data-prevent-flicker="true"
            maxWidth="none"
            variant="eyebrow">Why Trust Us With Your Webflow Project</Heading
          >
          <Heading
            data-split-text
            data-prevent-flicker="true"
            maxWidth="50ch"
            tag="h2"
            variant="h3"
            >We're a Webflow Professional Partner. That matters.</Heading
          >
          <div
            class="why-webflow_partner_body"
            data-fade-in
            data-delay="0.2"
            data-prevent-flicker="true"
          >
            <Text
              >Webflow vetted our work: three original client sites, no
              templates, reviewed against their published rubric. We passed
              their exams, too.</Text
            >
            <Text>When Webflow looked at our work, they signed off on it.</Text>
            <Text
              >We've shipped 50+ Webflow projects since 2022, from solo
              consultants to multi-million-dollar corporations, and migrated
              many clients off other platforms — WordPress, Squarespace, Wix,
              and custom builds.</Text
            >
            <Text
              >We know what works on this platform and what doesn't, because
              we've built it.</Text
            >
          </div>
          <Button href="/book-a-call" ariaLabel="Book a Strategy Call"
            >Book a Strategy Call</Button
          >
        </div>
      </Col>
      <Visual
        radius="none"
        slot="col2"
        src={professionalPartnerImg}
        alt="Webflow project displayed on a tablet"
        ratio="square"
      />
    </Layout>
  </Section>

  <!-- CTA -->
  <CTASection
    heading="Ready to build on a platform that doesn't fight you?"
    text="One call. We'll look at your current site, talk through where Webflow fits, and figure out whether a redesign or migration is the right next step."
  />

</BaseLayout>
