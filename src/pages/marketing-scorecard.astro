---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Button from "../components/ui/Button.astro";
import Grid from "../components/ui/Grid.astro";
import Visual from "../components/ui/Visual.astro";
import Scorecard from "../components/MarketingScorecard";

import heroBG from "../assets/placeholder-images/placeholder-6.webp";
import Overlay from "../components/ui/Overlay.astro";

export const prerender = true;

const ROOMS = [
  { icon: "①", name: "Section One", subtitle: "Lorem ipsum" },
  { icon: "②", name: "Section Two", subtitle: "Dolor sit amet" },
  { icon: "③", name: "Section Three", subtitle: "Consectetur" },
  { icon: "④", name: "Section Four", subtitle: "Adipiscing elit" },
  { icon: "⑤", name: "Section Five", subtitle: "Sed do eiusmod" },
  { icon: "⑥", name: "Section Six", subtitle: "Tempor incididunt" },
  { icon: "⑦", name: "Section Seven", subtitle: "Ut labore" },
];

const BENEFITS = [
  {
    title: "Lorem ipsum",
    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit.",
  },
  {
    title: "Dolor sit amet",
    text: "Sed do eiusmod tempor incididunt ut labore et dolore.",
  },
  {
    title: "Consectetur elit",
    text: "Ut enim ad minim veniam, quis nostrud exercitation.",
  },
];

const TRUST_BADGES = [
  { title: "100% Free", text: "Lorem ipsum dolor sit amet." },
  { title: "5 Minutes", text: "Consectetur adipiscing elit." },
  {
    title: "Actionable Results",
    text: "Sed do eiusmod tempor incididunt.",
  },
];
---

<BaseLayout
  title="Scorecard | Astro Starter"
  description="An example multi-step quiz funnel with email capture and scored results."
  theme="light"
>
  <Section id="scorecard-section">
    <Fragment slot="background">
      <Visual src={heroBG} alt="Scorecard background" variant="background" priority />
    </Fragment>

    <!-- Stacked phases — both occupy the same grid cell. CSS fades between
         them based on the data-phase attribute on the stack -->
    <div class="scorecard_phase_stack" data-phase="hero">
      <!-- HERO PHASE -->
      <div class="scorecard_phase scorecard_phase_hero">
        <Layout variant="columns" ratio="6-4" verticalAlign="center">
          <!-- Left column -->
          <Col slot="col1">
            <p class="scorecard_hero_eyebrow u-text-style-eyebrow">
              <span class="scorecard_hero_eyebrow_dot" aria-hidden="true"
              ></span>
              The Starter Scorecard
            </p>

            <Heading tag="h1" variant="h1">
              Lorem ipsum dolor sit amet consectetur adipiscing elit
            </Heading>

            <Text variant="large">
              Answer a few quick questions across 7 key areas and get a
              personalized breakdown of your results — in about 5 minutes.
            </Text>

            <Grid
              largeColumns={3}
              mediumColumns={3}
              smallColumns={1}
              rowGap={4}
            >
              {
                BENEFITS.map((b) => (
                  <div class="scorecard_hero_benefit">
                    <div class="scorecard_hero_benefit_icon" aria-hidden="true">
                      ✓
                    </div>
                    <p class="scorecard_hero_benefit_title u-text-style-regular">
                      <strong>{b.title}</strong>
                    </p>
                    <p class="scorecard_hero_benefit_text u-text-style-small u-text-style-muted">
                      {b.text}
                    </p>
                  </div>
                ))
              }
            </Grid>

            <div class="u-button-wrapper">
              <Button
                data-scorecard-start
                href="#scorecard-section"
                ariaLabel="Start the scorecard"
              >
                Start the Scorecard
                <svg
                  slot="icon"
                  viewBox="0 0 14 10"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  class="scorecard_hero_btn_arrow"
                >
                  <line x1="0" y1="5" x2="12" y2="5"></line>
                  <polyline points="8,1 12,5 8,9"></polyline>
                </svg>
              </Button>
            </div>

            <p
              class="scorecard_hero_microcopy u-text-style-small u-text-style-muted"
            >
              <span aria-hidden="true">⏱</span> Takes 5 minutes
              <span aria-hidden="true" class="scorecard_hero_dot">·</span>
              <span aria-hidden="true">🔒</span> Get your personalized score and next
              steps by email.
            </p>
          </Col>

          <!-- Right column -->
          <div slot="col2" class="scorecard_hero_rooms_card">
            <p class="scorecard_hero_rooms_label u-text-style-eyebrow">
              You'll score 7 sections
            </p>
            <ul class="scorecard_rooms_list">
              {
                ROOMS.map((r) => (
                  <li class="scorecard_rooms_item">
                    <span class="scorecard_rooms_icon" aria-hidden="true">
                      {r.icon}
                    </span>
                    <span class="scorecard_rooms_name">{r.name}</span>
                    <span class="scorecard_rooms_sub u-text-style-small u-text-style-muted">
                      — {r.subtitle}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </Layout>

        <!-- Trust badges row, inside the hero phase -->
        <div class="scorecard_trust_card u-margin-top-5">
          <Grid largeColumns={3} mediumColumns={3} smallColumns={1} rowGap={5}>
            {
              TRUST_BADGES.map((t) => (
                <div class="scorecard_trust_item">
                  <div class="scorecard_trust_icon" aria-hidden="true">
                    ✓
                  </div>
                  <div class="scorecard_trust_body">
                    <p class="scorecard_trust_title u-text-style-regular">
                      <strong>{t.title}</strong>
                    </p>
                    <p class="scorecard_trust_text u-text-style-small u-text-style-muted">
                      {t.text}
                    </p>
                  </div>
                </div>
              ))
            }
          </Grid>
        </div>
      </div>

      <!-- QUIZ PHASE -->
      <div class="scorecard_phase scorecard_phase_quiz">
        <Scorecard client:load skipIntro />
      </div>
    </div>
  </Section>
</BaseLayout>

<script>
  const stack = document.querySelector<HTMLElement>(".scorecard_phase_stack");
  const startButtons = document.querySelectorAll("[data-scorecard-start]");
  const section = document.getElementById("scorecard-section");

  startButtons.forEach((btn) => {
    btn.addEventListener("click", (e) => {
      if (!stack) return;
      e.preventDefault();
      stack.setAttribute("data-phase", "quiz");
      // Smooth-scroll to the top of the section so the quiz lines up with
      // the viewport (the hero may have been taller than the quiz).
      requestAnimationFrame(() => {
        section?.scrollIntoView({ behavior: "smooth", block: "start" });
      });
    });
  });
</script>
