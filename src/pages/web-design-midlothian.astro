---
import BaseLayout from "../layouts/BaseLayout.astro";
import { serviceFaqJsonLd } from "../lib/jsonld";
import { SITE } from "../config/site";
import Section from "../components/ui/Section.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Button from "../components/ui/Button.astro";
import Visual from "../components/ui/Visual.astro";
import ContentWrapper from "../components/ui/ContentWrapper.astro";

// Section components
import LocalDesignerIntro from "../components/sections/LocalDesignerIntro.astro";
import ComparisonSection from "../components/sections/ComparisonSection.astro";
import WebsiteGrowthPromo from "../components/sections/WebsiteGrowthPromo.astro";
import CTASection from "../components/sections/CTASection.astro";
import CaseStudyFeatured from "../components/sections/CaseStudyFeatured.astro";
import HowWeWorkPromo from "../components/sections/HowWeWorkPromo.astro";
import TestimonialShowcase from "../components/sections/TestimonialShowcase.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import FAQ from "../components/sections/FAQ.astro";
import NotReadyToBook from "../components/sections/NotReadyToBook.astro";

// Data
import { webDesignMidlothianFaqs } from "../data/faqs";

// Images
import heroImg from "../assets/local-web-designer/local-web-designer-hero.webp";
import portraitImg from "../assets/local-web-designer/local-web-designer.webp";
import m2mImg from "../assets/local-web-designer/local-web-designer-m2m.webp";
import artImg from "../assets/local-web-designer/local-web-designer-art.webp";
import bestSalespersonImg from "../assets/local-web-designer/local-web-designer-best-salesperson.webp";
import websiteHelpsGrowImg from "../assets/local-web-designer/local-web-designer-website-helps-grow.webp";

const pageUrl = `${SITE.url}/web-design-midlothian`;

// Per-page structured data — Service + FAQPage combined into a single @graph.
// LocalBusiness lives sitewide in BaseLayout; referenced here via provider.@id.
const schemaGraph = serviceFaqJsonLd({
  pageUrl,
  serviceType: "Web Design",
  name: "Web Design in Midlothian, TX",
  description:
    "Strategy-first Webflow web design for Midlothian, TX businesses. Clear, conversion-focused websites built on the M2M Framework.",
  areaServed: [
    { type: "City", name: "Midlothian" },
    { type: "AdministrativeArea", name: "Ellis County" },
  ],
  audience: {
    audienceType: "Local businesses in Midlothian and Ellis County, TX",
  },
  faqs: webDesignMidlothianFaqs,
});
---

<BaseLayout
  title="Web Design in Midlothian, TX | CL Creative"
  description="Web design in Midlothian, TX that brings in the right customers. We build clear Webflow sites that turn visitors into bookings. Book a free strategy call."
  canonical={pageUrl}
  theme="light"
  schema={schemaGraph}
>
  <!-- ==================== HERO ==================== -->
  <Section id="midlothian-hero">
    <Layout variant="stack">
      <Col slot="col1">
        <Heading
          tag="h1"
          variant="h1"
          data-splittext
          data-prevent-flicker="true"
        >
          Web Design in Midlothian for Businesses Ready to Stop Losing Customers
          to a Confusing Website
        </Heading>
        <Text
          variant="xlarge"
          maxWidth="60ch"
          data-fade-up
          data-prevent-flicker="true"
        >
          If you're honest, your website probably isn't bringing in the leads
          and customers you need to grow.
        </Text>
        <Text maxWidth="70ch" data-fade-up data-prevent-flicker="true">
          That's not because your business isn't good. It's because most
          business websites are confusing. The visitor can't tell who it's for
          or what to do next, so they leave.
        </Text>
        <Text maxWidth="60ch" data-fade-up data-prevent-flicker="true">
          A good business shouldn't be held back by a confusing website.
        </Text>
        <div
          class="u-button-wrapper"
          data-fade-up
          data-prevent-flicker="true"
          data-duration="0.6"
        >
          <Button href="/book-a-call" ariaLabel="Book a Strategy Call"
            >Book a Strategy Call</Button
          >
          <Button
            variant="secondary"
            href="/marketing-scorecard"
            ariaLabel="Free Marketing Health Quiz"
          >
            Free Marketing Health Quiz
          </Button>
        </div>
      </Col>
    </Layout>
    <Visual
      data-prevent-flicker
      data-fade-in
      data-delay="0.6"
      ratio="1440/640"
      radius="main"
      src={heroImg}
      alt="Examples of CL Creative web design projects for local businesses"
      style="width: calc(100% - 11% * var(--responsive-large, 0)); margin-left: auto;"
    />
  </Section>

  <!-- ==================== BRAND CALLOUT ==================== -->
  <Section theme="brand" container="narrow" padding="small">
    <ContentWrapper>
      <Heading tag="h2" variant="h3">
        A Better-Looking Website Won't Fix it. A Clearer One Will.
      </Heading>
      <Text variant="large">
        Most of the time, the reason a site doesn't bring in customers has
        nothing to do with how it looks. It's that the website doesn't clearly
        tell the right person what you do, who it's for, and why they should
        pick you over the competition.
      </Text>
    </ContentWrapper>
  </Section>

  <!-- ==================== MIDLOTHIAN WEB DESIGNER ==================== -->
  <LocalDesignerIntro
    heading="A Midlothian Web Designer Who Gets the Message Right Before Building the Site"
    portraitImage={portraitImg}
    portraitAlt="Casey Lewis, CL Creative founder and Midlothian web designer"
    m2mImage={m2mImg}
    m2mAlt="The M2M Framework — research-driven website strategy"
  >
    <Fragment slot="intro">
      <Text variant="large">
        CL Creative is based right here in Midlothian, and we're a member of the
        Waxahachie Chamber of Commerce.
      </Text>
      <Text variant="large">
        We've built websites for businesses across Ellis County and the
        Metroplex. Therapists and counselors. Coaches. Authors. Corporate
        trainers. Home-services companies like landscaping and irrigation.
      </Text>
    </Fragment>
    <Fragment slot="m2m">
      <p>
        Every website we build runs on a framework we created called M2M.
        Before we design a single page, we figure out who your customer is and
        what they need to hear. Then the whole site gets built around that:
      </p>
      <ul>
        <li>The words your customer reads first</li>
        <li>The order of the page, built around how they actually decide</li>
        <li>The buttons and calls to action that get them to book or buy</li>
        <li>The questions and objections we answer, and where</li>
      </ul>
      <p>
        That's why the sites we build bring in customers instead of just
        compliments. And it's all done by someone who lives and works in the
        same community you serve.
      </p>
    </Fragment>
  </LocalDesignerIntro>

  <!-- ==================== SAME DESIGNER HOURS ==================== -->
  <ComparisonSection leftImage={artImg} rightImage={bestSalespersonImg} />

  <!-- ==================== CTA SECTION ==================== -->
  <CTASection
    heading="If Your Website Isn't Helping You Grow Your Business, We Need to Talk."
    text="Book a 30-minute strategy call. We'll look at your business and your current site, figure out what's working and what isn't, and you'll walk away with a clear picture of what your website needs to do, plus a rough budget range. Whether you hire us or not."
    secondaryButtonText=""
  />

  <!-- ==================== WEBSITE HELPS GROW ==================== -->
  <WebsiteGrowthPromo
    heading="A Website That Helps Your Midlothian Business Grow on Purpose"
    image={websiteHelpsGrowImg}
    imageAlt="A clear, conversion-focused website built for a Midlothian business"
  >
    <Fragment slot="body">
      <Text>
        The website is clear. It says what you do, who it's for, and why you're
        the one to call. They don't leave. They book.
      </Text>
      <Text>
        And you stop having that same frustrating conversation about why the
        website isn't bringing in business.
      </Text>
      <Text>
        That's what we build. Local to Midlothian, clear by design, made to
        bring in the right customer. So your business grows on purpose, not by
        accident.
      </Text>
    </Fragment>
  </WebsiteGrowthPromo>

  <!-- How We Work promo -->
  <HowWeWorkPromo padding="small" />

  <!-- ==================== FEATURED CASE STUDY ==================== -->
  <CaseStudyFeatured theme="brand" />

  <!-- ==================== TESTIMONIALS ==================== -->
  <TestimonialShowcase />

  <!-- ==================== HOW IT WORKS ==================== -->
  <HowItWorks />

  <!-- ==================== FAQ ==================== -->
  <FAQ items={webDesignMidlothianFaqs} />

  {/* Send-me-a-quick-note fallback */}
  <NotReadyToBook />
</BaseLayout>
