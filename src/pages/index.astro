---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";

import "../styles/pages/home.css";
import HowItWorks from "../components/sections/HowItWorks.astro";
import FrameworkSection from "../components/sections/FrameworkSection.astro";
import TestimonialShowcase from "../components/sections/TestimonialShowcase.astro";
import SingleTestimonial from "../components/sections/SingleTestimonial.astro";
import ProjectImages from "../components/sections/ProjectImages.astro";
import WhyWorkWithUs from "../components/sections/WhyWorkWithUs.astro";
import Services from "../components/sections/Services.astro";
import CTASection from "../components/sections/CTASection.astro";

import CaseStudyFeatured from "../components/sections/CaseStudyFeatured.astro";
import Visual from "../components/ui/Visual.astro";
import ContentWrapper from "../components/ui/ContentWrapper.astro";
import Grid from "../components/ui/Grid.astro";
import Button from "../components/ui/Button.astro";
import ImagePromo from "../components/sections/ImagePromo.astro";

//images
import problemImage from "../assets/placeholder-images/placeholder-1.webp";
import theFixImage from "../assets/placeholder-images/placeholder-2.webp";
import stakes1 from "../assets/placeholder-images/placeholder-3.webp";
import stakes2 from "../assets/placeholder-images/placeholder-4.webp";
import future1 from "../assets/placeholder-images/placeholder-11.webp";
import future2 from "../assets/placeholder-images/placeholder-12.webp";
import future3 from "../assets/placeholder-images/placeholder-13.webp";
import future4 from "../assets/placeholder-images/placeholder-14.webp";
import future5 from "../assets/placeholder-images/placeholder-15.webp";
import future6 from "../assets/placeholder-images/placeholder-16.webp";
---

<BaseLayout
  title="Home | Astro Starter"
  description="A starter website built on a structured component and design system."
  theme="light"
>
  <!-- Hero Section -->
  <Section padding="main">
    <Layout
      docs=""
      class="home-hero_layout home-hero_content"
      variant="columns"
    >
      <Col docs="" slot="col1" class="home-hero_text">
        <Heading tag="h1" maxWidth="none" variant="eyebrow"
          >Lorem ipsum dolor sit amet</Heading
        >
        <Heading variant="h2" maxWidth="40ch"
          >Lorem ipsum dolor sit amet, consectetur adipiscing elit sed do
          eiusmod tempor incididunt.</Heading
        >
        <Text variant="xlarge">
          Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris
          nisi ut aliquip ex ea commodo consequat.
        </Text>

        <div class="u-button-wrapper">
          <Button
            id="main-cta-home-hero"
            href="/contact"
            ariaLabel="Get started">Get Started</Button
          >
          <Button
            variant="secondary"
            href="/marketing-scorecard"
            ariaLabel="Take the scorecard"
            >Take the Scorecard</Button
          >
        </div>
      </Col>
      <Visual
        slot="col2"
        src={theFixImage}
        alt="Placeholder hero image"
        ratio="landscape"
      />
    </Layout>
  </Section>

  <!-- Problem / Two-Column Statement Section -->
  <Section
    theme="dark"
    paddingTop="main"
    paddingBottom="none"
    class="problem_section"
  >
    <Layout variant="columns" verticalAlign="start">
      <Heading
        data-prevent-flicker="true"
        data-split-text
        slot="col1"
        tag="h2"
        variant="h2"
        maxWidth="16ch"
      >
        Lorem ipsum dolor sit amet consectetur.
      </Heading>
      <Col slot="col2">
        <Heading
          data-fade-in
          data-prevent-flicker="true"
          tag="h3"
          variant="h4"
          maxWidth="40ch"
        >
          Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </Heading>
        <Text data-fade-in data-prevent-flicker="true" size="regular">
          Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris
          nisi ut aliquip ex ea commodo consequat.
        </Text>
      </Col>
    </Layout>
    <Visual
      src={problemImage}
      alt="Placeholder feature image"
      ratio="12.80/6.86"
      class="problem_feature_img u-radius-main"
      position={{ x: 50, y: 20 }}
      data-fade-up
    />
  </Section>

  <!-- Agitation Section -->
  <Section padding="small" theme="brand">
    <ContentWrapper
      data-prevent-flicker="true"
      data-fade-list
      align="left"
      class="not-fixing_content"
    >
      <Heading variant="h3" maxWidth="none" marginBottom={3}
        >Lorem ipsum dolor sit amet, consectetur adipiscing elit sed do.
      </Heading>
      <Text
        >Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi
        ut aliquip ex ea commodo consequat duis aute irure dolor.
      </Text>
    </ContentWrapper>
  </Section>

  <!-- The Fix Section -->
  <Section gap={8}>
    <Layout variant="columns" ratio="6.5-5.5" rowGap="var(--space-4)">
      <Heading maxWidth="none" slot="col1" data-fade-in tag="h2" variant="h3">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit sed do eiusmod.
      </Heading>

      <ContentWrapper slot="col2">
        <Text data-fade-in>
          Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris
          nisi ut aliquip ex ea commodo consequat.
        </Text>
        <Text data-fade-in>
          Duis aute irure dolor in reprehenderit in voluptate velit esse cillum
          dolore eu fugiat nulla pariatur.
        </Text>
      </ContentWrapper>
    </Layout>
    <Visual
      src={theFixImage}
      alt="Placeholder section image"
      data-fade-in
      ratio="landscape"
    />
    <ContentWrapper align="center">
      <div class="u-button-wrapper">
        <Button href="/contact" ariaLabel="Get started">Get Started</Button>
      </div>
    </ContentWrapper>
  </Section>

  <!-- Framework Section -->
  <FrameworkSection paddingTop="none" />

  <!--Stakes Section -->
  <Section>
    <ContentWrapper align="center">
      <Heading tag="h2" variant="h2" maxWidth="25ch">
        Lorem ipsum dolor sit amet consectetur adipiscing elit.
      </Heading>
    </ContentWrapper>

    <Layout variant="columns" verticalAlign="center">
      <Visual
        slot="col1"
        src={stakes1}
        alt="Placeholder image"
        ratio="landscape"
      />
      <Col slot="col2">
        <Heading tag="h3" variant="h3">
          Lorem ipsum dolor sit amet consectetur adipiscing.
        </Heading>
        <Text variant="xlarge">
          Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </Text>
        <Text>
          Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris
          nisi ut aliquip ex ea commodo consequat.
        </Text>
      </Col>
    </Layout>

    <Layout variant="columns-reversed" verticalAlign="center">
      <Visual
        slot="col1"
        src={stakes2}
        alt="Placeholder image"
        ratio="landscape"
      />
      <Col slot="col2">
        <Heading maxWidth="30ch" tag="h3" variant="h3">
          Duis aute irure dolor in reprehenderit in voluptate velit esse.
        </Heading>
        <Text variant="xlarge">
          Excepteur sint occaecat cupidatat non proident sunt in culpa qui.
        </Text>
        <Text>
          Sed ut perspiciatis unde omnis iste natus error sit voluptatem
          accusantium doloremque laudantium totam rem aperiam.
        </Text>
      </Col>
    </Layout>

    <ContentWrapper align="center">
      <div class="u-button-wrapper">
        <Button href="/contact" ariaLabel="Get started">Get Started</Button>
      </div>
    </ContentWrapper>
  </Section>

  <!-- Case Study Featured Section -->
  <CaseStudyFeatured theme="dark" />

  <!-- Single Testimonial -->
  <SingleTestimonial name="Jane Doe" />

  <!-- How It Works Section -->
  <HowItWorks />

  <!-- Project Images -->
  <ProjectImages />

  <!-- Why Work With Us -->
  <WhyWorkWithUs />

  <!-- Services -->
  <Services />

  <!-- Image promo -->
  <ImagePromo />

  <!-- Testimonials Section -->
  <TestimonialShowcase />

  <!-- Future Section -->
  <Section>
    <div class="future_card u-theme-brand">
      <Layout ratio="35-65" variant="columns" verticalAlign="center">
        <Col slot="col1">
          <Heading tag="h2" variant="h3">
            Lorem ipsum dolor sit amet consectetur adipiscing elit.
          </Heading>
          <Text variant="large">
            Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris
            nisi ut aliquip ex ea commodo consequat duis aute irure dolor in
            reprehenderit.
          </Text>

          <div class="u-button-wrapper">
            <Button
              variant="primary"
              href="/contact"
              ariaLabel="Get started">Get Started</Button
            >
          </div>
        </Col>
        <Grid
          slot="col2"
          largeColumns={3}
          mediumColumns={3}
          smallColumns={2}
          rowGap={4}
        >
          <Visual src={future1} alt="Placeholder image" ratio="square" radius="small" />
          <Visual src={future2} alt="Placeholder image" ratio="square" radius="small" />
          <Visual src={future3} alt="Placeholder image" ratio="square" radius="small" />
          <Visual src={future4} alt="Placeholder image" ratio="square" radius="small" />
          <Visual src={future5} alt="Placeholder image" ratio="square" radius="small" />
          <Visual src={future6} alt="Placeholder image" ratio="square" radius="small" />
        </Grid>
      </Layout>
    </div>
  </Section>

  <!-- CTA Section -->
  <CTASection />
</BaseLayout>
