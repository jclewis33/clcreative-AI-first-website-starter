---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { serviceFaqJsonLd } from "../../lib/jsonld";
import { SITE } from "../../config/site";
import Section from "../../components/ui/Section.astro";
import Layout from "../../components/ui/Layout.astro";
import Col from "../../components/ui/Col.astro";
import Heading from "../../components/ui/Heading.astro";
import Text from "../../components/ui/Text.astro";
import Button from "../../components/ui/Button.astro";
import Visual from "../../components/ui/Visual.astro";
import Overlay from "../../components/ui/Overlay.astro";
import ContentWrapper from "../../components/ui/ContentWrapper.astro";
import Grid from "../../components/ui/Grid.astro";

// Section components
import SplitSection from "../../components/sections/SplitSection.astro";
import StackingPanels from "../../components/sections/StackingPanels.astro";
import StackingPanel from "../../components/sections/StackingPanel.astro";
import M2MFramework from "../../components/sections/M2MFramework.astro";
import CTASection from "../../components/sections/CTASection.astro";
import CaseStudyFeatured from "../../components/sections/CaseStudyFeatured.astro";
import HowWeWorkPromo from "../../components/sections/HowWeWorkPromo.astro";
import TestimonialShowcase from "../../components/sections/TestimonialShowcase.astro";
import HowItWorks from "../../components/sections/HowItWorks.astro";
import FAQ from "../../components/sections/FAQ.astro";
import NotReadyToBook from "../../components/sections/NotReadyToBook.astro";

// Data
import { webDesignChurchesFaqs } from "../../data/faqs";

// Images
import heroImg from "../../assets/industries/churches/church-hero.webp";
import site1Img from "../../assets/industries/churches/churches-site-1.webp";
import site2Img from "../../assets/industries/churches/churches-site-2.webp";
import pastorImg from "../../assets/industries/churches/churches-pastor-1.webp";
import connectionImg from "../../assets/industries/churches/churches-website-connection-1.webp";
import workHardImg from "../../assets/industries/churches/churches-website-work-hard.webp";
import marketingPlanImg from "../../assets/industries/churches/churches-marketing-plan.webp";

// Styles
import "../../styles/pages/churches.css";

const pageUrl = `${SITE.url}/web-design/churches`;

// Per-page structured data — Service + FAQPage combined into a single @graph.
// LocalBusiness lives sitewide in BaseLayout; referenced here via @id.
// Industry-scoped: audience (not a geographic areaServed).
const schemaGraph = serviceFaqJsonLd({
  pageUrl,
  serviceType: "Web Design",
  name: "Web Design for Churches and Ministries",
  description:
    "Strategy-first, mobile-first Webflow web design for churches and ministries, built by a former pastor. Clear, welcoming sites that answer a guest's real questions and help them take a next step, built on the M2M Framework.",
  audience: {
    type: "Audience",
    audienceType: "Churches and ministries",
  },
  faqs: webDesignChurchesFaqs,
});
---

<BaseLayout
  title="Web Design for Churches | CL Creative"
  description="Web design for churches, built by a former pastor. Clear sites that welcome guests and help them take a next step. Book a free strategy call."
  canonical={pageUrl}
  theme="light"
  schema={schemaGraph}
>
  <!-- ==================== HERO (contained card) ==================== -->
  <Section paddingBottom="none" id="churches-hero">
    <div class="churches-hero_card" data-theme="dark">
      <Visual
        src={heroImg}
        alt="CL Creative web design for churches and ministries"
        variant="background"
        radius="large"
        priority
      />
      <Overlay strength={78} />
      <div class="churches-hero_content u-hero-fade">
        <Heading class="churches-hero_eyebrow" variant="eyebrow">
          Web Design for Churches
        </Heading>
        <Heading tag="h1" variant="h2" maxWidth="20ch">
          Web Design for Churches That Helps Guests Take a Next Step
        </Heading>
        <Text variant="large" maxWidth="60ch">
          Before someone visits in person, they visit your website, looking for
          one thing: do I belong here, and what happens if I show up? But most
          church websites are built for the people already there, full of
          insider language and ministry acronyms with the service times buried,
          so a first-time guest leaves more unsure than when they arrived.
        </Text>
        <div class="u-button-wrapper">
          <Button href="/book-a-call" ariaLabel="Book a Strategy Call"
            >Book a Strategy Call</Button
          >
          <Button
            variant="secondary"
            href="/marketing-scorecard"
            ariaLabel="Free Marketing Health Quiz"
          >
            Free Marketing Health Quiz
          </Button>
        </div>
      </div>
    </div>
  </Section>

  <!-- ==================== AGITATION — STACKING PANELS ==================== -->
  <StackingPanels paddingTop="small">
    <Heading
      slot="heading"
      data-splittext
      data-prevent-flicker="true"
      tag="h2"
      variant="h2"
      >A beautiful church website that a guest can't make sense of won't help
      them take the next step</Heading
    >
    <StackingPanel>
      <Heading tag="h3" variant="h4"
        >The reason most church sites don't connect isn't the design.</Heading
      >
      <Text>It's that they're written for insiders.</Text>
      <Text>The homepage assumes you:</Text>
      <ul class="u-list">
        <li>Already know the lingo</li>
        <li>Already know where things are</li>
        <li>Already feel like you belong.</li>
      </ul>
      <Text marginBottom={0}>
        A first-time guest doesn't have any of that. They just want to know when
        you meet, what a service is like, what to do with their kids, and
        whether they'll feel welcome.
      </Text>
      <Visual
        slot="visual"
        src={site1Img}
        alt="A church website written for insiders that a first-time guest can't make sense of"
        ratio="landscape"
      />
    </StackingPanel>

    <StackingPanel reversed>
      <Heading tag="h3" variant="h4"
        >A church website that works answers visitors' questions</Heading
      >
      <Text>
        It speaks to the person who isn't here yet, not just the person who is.
      </Text>
      <Text>Clarity is what first-time visitors and guests want.</Text>
      <Text>That is what we build.</Text>
      <Visual
        slot="visual"
        src={site2Img}
        alt="A welcoming church website that answers a first-time guest's questions clearly"
        ratio="landscape"
      />
    </StackingPanel>
  </StackingPanels>

  <!-- ==================== EXPERIENCE ==================== -->
  <SplitSection
    image={pastorImg}
    imageAlt="The CL Creative founder, a former pastor who builds websites for churches"
    imagePosition="top"
  >
    <Heading
      data-splittext
      data-prevent-flicker="true"
      tag="h2"
      variant="h4"
      maxWidth="30ch"
    >
      A Web Designer Who Has Actually Pastored a Church
    </Heading>
    <div data-fade-in class="split_body u-rich-text">
      <p>
        CL Creative builds websites for churches and ministries, and we come at
        it from inside the church, not outside it.
      </p>
      <p>
        Before CL Creative, our founder pastored, and built the websites for the
        churches he led, along with the logo, the signage, and the print
        materials.
      </p>
      <p>
        We've made these decisions as the person responsible for them, with a
        real congregation, a real budget, and a heart for reaching the
        community, not as an outside vendor guessing at what a church needs.
      </p>
      <p>That experience shows up in the work.</p>
    </div>
  </SplitSection>

  <!-- ==================== M2M FRAMEWORK ==================== -->
  <M2MFramework paddingTop="none">
    <Fragment slot="intro">
      <Text data-fade-in maxWidth="60ch">
        We use a framework we created called <a href="/m2m-framework">M2M</a> to think
        through who you're trying to reach, members and guests alike, and what each
        of them needs to find. Then the whole site gets built around that:
      </Text>
      <ul data-fade-in class="u-list">
        <li>
          A clear answer to a guest's first questions: when you meet, what a
          service is like, what to do with their kids
        </li>
        <li>
          The next steps that matter, plan a visit, watch a message, find a
          group, give, made easy to find
        </li>
        <li>
          A layout built for a phone, because that's where most people will
          first meet your church
        </li>
        <li>
          A tone that sounds like your church, welcoming and real, not corporate
        </li>
      </ul>
      <Text data-fade-in maxWidth="60ch" marginBottom={0}>
        That's why the sites we build help churches connect with people instead
        of just looking nice.
      </Text>
    </Fragment>
    <Fragment slot="card2Body">
      We turn that research into conversion copy. Potential clients will see
      their problem and your solution. And they'll immediately know you're the
      right fit for them.
    </Fragment>
    <Fragment slot="card3Body">
      We then design and build you a custom <a href="/why-webflow"
        >Webflow site</a
      >
      that's easy to update and ready to scale as your business grows.
    </Fragment>
  </M2MFramework>

  <!-- ==================== COMPARISON / STAKES ==================== -->
  <Section gap={6}>
    <Visual
      data-fade-up
      data-prevent-flicker="true"
      src={connectionImg}
      alt="A church website connecting a first-time guest to a visit"
      ratio="16/9"
      radius="large"
    />

    <ContentWrapper align="center">
      <Heading
        data-splittext
        data-prevent-flicker="true"
        tag="h2"
        maxWidth="24ch"
      >
        Depending on the Designer, You'll End up with Two Very Different Church
        Websites
      </Heading>
    </ContentWrapper>

    <Grid
      data-fade-list
      data-prevent-flicker="true"
      largeColumns={2}
      mediumColumns={1}
      rowGap={6}
    >
      <div class="churches-compare_card u-theme-brand">
        <div class="churches-compare_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}>
            A site built for insiders
          </Heading>
        </div>
        <Text variant="large">
          It serves the people already there and overlooks the ones you're
          trying to reach.
        </Text>
        <ul class="u-list">
          <li>Full of acronyms and ministry language a guest doesn't know</li>
          <li>Service times and "what to expect" buried or missing</li>
          <li>
            Looks fine to your members, but loses the nervous first-time guest
          </li>
        </ul>
      </div>

      <div class="churches-compare_card u-theme-dark">
        <div class="churches-compare_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}>
            A site built to welcome visitors
          </Heading>
        </div>
        <Text variant="large">
          It works like a friendly member who greets people at the door.
        </Text>
        <ul class="u-list">
          <li>Answers a guest's real questions in the first scroll</li>
          <li>Makes planning a visit feel easy and low-pressure</li>
          <li>Built for a phone, where most guests first find you</li>
          <li>Sounds like your church: warm, clear, and genuinely inviting</li>
        </ul>
      </div>
    </Grid>
  </Section>

  <!-- ==================== CTA ==================== -->
  <CTASection
    heading="If Your Website Isn't Helping You Welcome and Reach People, Let's Talk."
    text="Book a 30-minute call. We'll look at your church and your current site, talk through what's working and what isn't, and you'll come away with a clear picture of what your website needs to do to welcome guests and serve your members, plus a rough budget range."
  />

  <!-- ==================== END RESULT ==================== -->
  <Section theme="dark">
    <ContentWrapper align="center">
      <Heading
        data-splittext
        data-prevent-flicker="true"
        tag="h2"
        variant="h2"
        maxWidth="26ch"
      >
        A Website That Helps Your Church Reach the People Right Outside Its
        Doors
      </Heading>
    </ContentWrapper>

    <Layout data-fade-list variant="columns" verticalAlign="center">
      <Col slot="col1">
        <Text variant="large">
          Picture the version of your site where a nervous first-time guest
          lands, feels welcomed before they've even visited, finds exactly what
          they need to know, and plans a visit, because nothing stood in their
          way.
        </Text>
        <Text variant="large">
          And the people your church is trying to reach stop slipping away at
          the front door, just because the website spoke a language they didn't
          know yet.
        </Text>
        <Heading variant="eyebrow" class="u-color-brand">
          That's what we build
        </Heading>
        <Text variant="large">
          Clear, warm, built for the people you're trying to reach, so your
          church can welcome them on purpose, not by accident.
        </Text>
      </Col>
      <Visual
        slot="col2"
        src={workHardImg}
        alt="A first-time guest planning a visit from a clear, welcoming church website"
        ratio="16/10"
      />
    </Layout>

    <ContentWrapper align="center" data-fade-in>
      <div class="u-button-wrapper">
        <Button href="/book-a-call" ariaLabel="Book a Strategy Call"
          >Book a Strategy Call</Button
        >
      </div>
    </ContentWrapper>
  </Section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <TestimonialShowcase />

  <!-- ==================== PROCESS ==================== -->
  <HowItWorks />

  <!-- ==================== HOW WE WORK ==================== -->
  <HowWeWorkPromo
    heading="We Build You a Marketing Plan and a Website That Brings in Visitors"
    image={marketingPlanImg}
    imageAlt="A church marketing plan and website working together"
    imageRatio="3/2"
  />

  <!-- ==================== FEATURED CASE STUDIES ==================== -->
  <CaseStudyFeatured
    theme="dark"
    slugs={[
      "potential-church-wordpress-to-webflow-migration",
      "ellis-baptist-association-migration-to-webflow",
      "troy-gramling-website-migration",
    ]}
  />

  <!-- ==================== FAQ ==================== -->
  <FAQ items={webDesignChurchesFaqs} />

  <!-- ==================== NOT READY TO BOOK ==================== -->
  <NotReadyToBook />
</BaseLayout>
