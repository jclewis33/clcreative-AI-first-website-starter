---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { serviceFaqJsonLd } from "../../lib/jsonld";
import { SITE } from "../../config/site";
import Section from "../../components/ui/Section.astro";
import Layout from "../../components/ui/Layout.astro";
import Col from "../../components/ui/Col.astro";
import Heading from "../../components/ui/Heading.astro";
import Text from "../../components/ui/Text.astro";
import Button from "../../components/ui/Button.astro";
import Visual from "../../components/ui/Visual.astro";
import Overlay from "../../components/ui/Overlay.astro";
import ContentWrapper from "../../components/ui/ContentWrapper.astro";
import Grid from "../../components/ui/Grid.astro";

// Section components
import SplitSection from "../../components/sections/SplitSection.astro";
import StackingPanels from "../../components/sections/StackingPanels.astro";
import StackingPanel from "../../components/sections/StackingPanel.astro";
import M2MFramework from "../../components/sections/M2MFramework.astro";
import CTASection from "../../components/sections/CTASection.astro";
import CaseStudyFeatured from "../../components/sections/CaseStudyFeatured.astro";
import HowWeWorkPromo from "../../components/sections/HowWeWorkPromo.astro";
import TestimonialShowcase from "../../components/sections/TestimonialShowcase.astro";
import HowItWorks from "../../components/sections/HowItWorks.astro";
import FAQ from "../../components/sections/FAQ.astro";
import NotReadyToBook from "../../components/sections/NotReadyToBook.astro";

// Data
import { webDesignHomeServicesFaqs } from "../../data/faqs";

// Images
import heroImg from "../../assets/industries/home-services/home-services-hero.webp";
import site1Img from "../../assets/industries/home-services/home-services-site-1.webp";
import site2Img from "../../assets/industries/home-services/home-services-site-2.webp";
import businessImg from "../../assets/industries/home-services/home-services-business-1.webp";
import connectionImg from "../../assets/industries/home-services/home-services-website-connection-2.webp";
import workHardImg from "../../assets/industries/home-services/home-services-website-work-hard.webp";
import marketingPlanImg from "../../assets/industries/home-services/home-services-marketing-plan.webp";

// Styles
import "../../styles/pages/home-services.css";

const pageUrl = `${SITE.url}/web-design/home-services`;

// Per-page structured data — Service + FAQPage combined into a single @graph.
// LocalBusiness lives sitewide in BaseLayout; referenced here via @id.
// Industry-scoped: audience (not a geographic areaServed).
const schemaGraph = serviceFaqJsonLd({
  pageUrl,
  serviceType: "Web Design",
  name: "Web Design for Home Services Companies",
  description:
    "Strategy-first, mobile-first Webflow web design for home services companies. Clear, fast, click-to-call sites that turn local searches into booked jobs, built on the M2M Framework.",
  audience: {
    audienceType: "Home services companies",
  },
  faqs: webDesignHomeServicesFaqs,
});
---

<BaseLayout
  title="Web Design for Home Services | CL Creative"
  description="Web design for home services companies, built mobile-first to turn local searches into booked jobs. Fast, click-to-call sites. Book a free strategy call."
  canonical={pageUrl}
  theme="light"
  schema={schemaGraph}
>
  <!-- ==================== HERO ==================== -->
  <Section theme="dark" minHeight id="home-services-hero">
    <Fragment slot="background">
      <Visual
        src={heroImg}
        alt="CL Creative web design for home services companies"
        variant="background"
        priority
      />
      <Overlay strength={70} />
    </Fragment>
    <Layout variant="stack">
      <Col slot="col1" class="u-hero-fade">
        <Heading variant="eyebrow" class="u-color-inherit">
          Web Design for Home Services Companies
        </Heading>
        <Heading tag="h1" variant="h2">
          When Someone Needs You Now, Your Website Has Seconds to Win the Job.
          Most Don't.
        </Heading>
        <Text variant="large" maxWidth="60ch">
          You do good work and your customers know it. But the customer who's
          never heard of you is judging you on your website in about five
          seconds, on a phone, while stressed, and if it doesn't make it dead
          simple to call you, that job goes to whoever's site did.
        </Text>
        <div class="u-button-wrapper">
          <Button href="/book-a-call" ariaLabel="Book a Strategy Call"
            >Book a Strategy Call</Button
          >
          <Button
            variant="secondary"
            href="/marketing-scorecard"
            ariaLabel="Free Marketing Health Quiz"
          >
            Free Marketing Health Quiz
          </Button>
        </div>
      </Col>
    </Layout>
  </Section>

  <!-- ==================== AGITATION — STACKING PANELS ==================== -->
  <StackingPanels paddingTop="small">
    <Heading
      slot="heading"
      data-splittext
      data-prevent-flicker="true"
      tag="h2"
      variant="h2"
      >A Fancier Website Won't Get You the Call. A Clearer, Faster One Will.</Heading
    >
    <StackingPanel>
      <Heading tag="h3" variant="h4"
        >The reason most home-services sites underperform isn't the design.</Heading
      >
      <Text>It's that they make a stressed customer work too hard.</Text>
      <ul class="u-list">
        <li>What you do isn't obvious in the first second.</li>
        <li>The areas you serve are buried.</li>
        <li>The phone number is hard to find or hard to tap.</li>
      </ul>
      <Text marginBottom={0}>
        So a ready-to-buy customer gives up and calls someone easier to deal
        with.
      </Text>
      <Visual
        slot="visual"
        src={site1Img}
        alt="A home-services website that buries what it does and makes a customer work too hard"
        ratio="landscape"
      />
    </StackingPanel>

    <StackingPanel reversed>
      <Heading tag="h3" variant="h4"
        >A home-services website that works does the opposite</Heading
      >
      <Text>
        The moment someone lands, they know what you do, that you serve their
        area, and exactly how to reach you.
      </Text>
      <Text>Clarity and speed win the job, not a flashier design.</Text>
      <Text>That is what we build.</Text>
      <Visual
        slot="visual"
        src={site2Img}
        alt="A home-services website that makes what you do, your service area, and how to call obvious"
        ratio="landscape"
      />
    </StackingPanel>
  </StackingPanels>

  <!-- ==================== EXPERIENCE ==================== -->
  <SplitSection
    image={businessImg}
    imageAlt="A home-services pro on the job, the kind of work CL Creative builds websites for"
    imagePosition="top"
  >
    <Heading
      data-splittext
      data-prevent-flicker="true"
      tag="h2"
      variant="h4"
      maxWidth="30ch"
    >
      A Web Designer Who Actually Knows the Work, Not Just the Website
    </Heading>
    <div data-fade-in class="split_body u-rich-text">
      <p>
        CL Creative builds websites for home-services companies, and we come at
        it with real respect for the trade. Our founder grew up renovating
        houses alongside his dad, and owns and maintains a rental property
        today.
      </p>
      <p>
        So we understand the work behind the work: the seasons, the service
        calls, the difference between a quick fix and a full job, and why a
        missed call is a missed paycheck.
      </p>
      <p>We've built sites across a wide range of home services:</p>
      <ul>
        <li>Irrigation and sprinkler companies</li>
        <li>
          <a
            href="/case-studies/dynamic-home-repair-m2m-messaging-webflow-rebuild"
            >Home repair and renovation</a
          >
        </li>
        <li>Spray foam insulation</li>
        <li>Natural and organic lawn care</li>
        <li>
          Commercial dumpster and large-load hauling for renovation and clean
          out projects
        </li>
      </ul>
      <p>
        Different trades, same core need: a website that turns a local search
        into a booked job.
      </p>
      <p>
        We bring that same focus to every industry we work in, from <a
          href="/web-design/recruiting-firm">recruiting firms</a
        > to <a href="/web-design/coaches">coaches</a>.
      </p>
    </div>
  </SplitSection>

  <!-- ==================== M2M FRAMEWORK ==================== -->
  <M2MFramework paddingTop="none">
    <Fragment slot="intro">
      <Text data-fade-in maxWidth="60ch">
        We use a framework we created called <a href="/m2m-framework">M2M</a> to figure
        out who your customer is, what they're searching for, and what makes them
        call you instead of the next company. Then the whole site gets built around
        that:
      </Text>
      <ul data-fade-in class="u-list">
        <li>
          A clear answer, in the first second, to what you do and where you do
          it
        </li>
        <li>
          A layout built for a phone, because that's where these searches happen
        </li>
        <li>
          A phone number and quote request that are impossible to miss and easy
          to tap
        </li>
        <li>
          The trust signals (reviews, service areas, guarantees) that make a
          stranger pick you
        </li>
      </ul>
      <Text data-fade-in maxWidth="60ch" marginBottom={0}>
        That's why the sites we build bring in calls and jobs instead of just
        compliments.
      </Text>
    </Fragment>
    <Fragment slot="card2Body">
      We turn that research into conversion copy. Potential clients will see
      their problem and your solution. And they'll immediately know you're the
      right fit for them.
    </Fragment>
    <Fragment slot="card3Body">
      We then design and build you a custom <a href="/why-webflow"
        >Webflow site</a
      >
      that's easy to update and ready to scale as your business grows.
    </Fragment>
  </M2MFramework>

  <!-- ==================== COMPARISON / STAKES ==================== -->
  <Section gap={6}>
    <Visual
      data-fade-up
      data-prevent-flicker="true"
      src={connectionImg}
      alt="A home-services website connecting a local search to a booked job"
      ratio="16/9"
      radius="large"
    />

    <ContentWrapper align="center">
      <Heading
        data-splittext
        data-prevent-flicker="true"
        tag="h2"
        maxWidth="24ch"
      >
        Depending on the Designer, You'll End up with Two Very Different Home
        Services Websites
      </Heading>
    </ContentWrapper>

    <Grid
      data-fade-list
      data-prevent-flicker="true"
      largeColumns={2}
      mediumColumns={1}
      rowGap={6}
    >
      <div class="home-services-compare_card u-theme-brand">
        <div class="home-services-compare_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}>
            A site built to look nice
          </Heading>
        </div>
        <Text variant="large">You win compliments and lose calls.</Text>
        <ul class="u-list">
          <li>Loads slowly and fights the customer on a phone</li>
          <li>Doesn't make it obvious what you do or where you work</li>
          <li>
            The phone number is buried, so a ready customer calls someone else
          </li>
        </ul>
      </div>

      <div class="home-services-compare_card u-theme-dark">
        <div class="home-services-compare_card_header">
          <Heading tag="h3" variant="h4" maxWidth="none" marginBottom={0}>
            A site built to get the call
          </Heading>
        </div>
        <Text variant="large">
          It works like your best office manager, answering before you can.
        </Text>
        <ul class="u-list">
          <li>Says what you do and where, the second someone lands</li>
          <li>Built for a phone, because that's where the search happens</li>
          <li>Click-to-call and quote requests that are impossible to miss</li>
          <li>
            Reviews and service areas right up front, so a stranger trusts you
            fast
          </li>
        </ul>
      </div>
    </Grid>
  </Section>

  <!-- ==================== CTA ==================== -->
  <CTASection
    heading="If Your Website Isn't Bringing In Calls and Jobs, We Need to Talk"
    text="Book a 30-minute strategy call. We'll look at your business and your current site, figure out what's working and what isn't, and you'll walk away with a clear picture of what your website needs to do to turn local searches into booked jobs, plus a rough budget range."
  />

  <!-- ==================== END RESULT ==================== -->
  <Section theme="dark">
    <ContentWrapper align="center">
      <Heading
        data-splittext
        data-prevent-flicker="true"
        tag="h2"
        variant="h2"
        maxWidth="26ch"
      >
        A Website That Keeps Your Crews Busy
      </Heading>
    </ContentWrapper>

    <Layout data-fade-list variant="columns" verticalAlign="center">
      <Col slot="col1">
        <Text variant="large">
          Picture the version of your site where a homeowner with a problem
          lands, instantly sees that you do exactly what they need and serve
          their area, and taps to call before they've scrolled halfway down.
        </Text>
        <Text variant="large">
          No friction. No second-guessing. Just the next job, booked.
        </Text>
        <Text variant="large">
          And you stop losing ready customers to competitors whose only
          advantage was an easier website.
        </Text>
        <Heading variant="eyebrow" class="u-color-brand">
          That's what we build
        </Heading>
        <Text variant="large">
          Clear, fast, built for the phone, and made to turn local searches into
          booked work. So your business grows on purpose, not by accident.
        </Text>
      </Col>
      <Visual
        slot="col2"
        src={workHardImg}
        alt="A homeowner tapping to call a home-services company from a clear, mobile-first website"
        ratio="16/10"
      />
    </Layout>

    <ContentWrapper align="center" data-fade-in>
      <div class="u-button-wrapper">
        <Button href="/book-a-call" ariaLabel="Book a Strategy Call"
          >Book a Strategy Call</Button
        >
      </div>
    </ContentWrapper>
  </Section>

  <!-- ==================== TESTIMONIALS ==================== -->
  <TestimonialShowcase />

  <!-- ==================== PROCESS ==================== -->
  <HowItWorks />

  <!-- ==================== HOW WE WORK ==================== -->
  <HowWeWorkPromo
    image={marketingPlanImg}
    imageAlt="A home-services marketing plan and website working together"
    imageRatio="3/2"
  />

  <!-- ==================== FEATURED CASE STUDIES ==================== -->
  <CaseStudyFeatured
    theme="dark"
    slugs={[
      "dynamic-home-repair-m2m-messaging-webflow-rebuild",
      "circle-t-specialities-building-a-brand-from-the-ground-up",
      "noble-administration-network-m2m-messaging-webflow-development",
    ]}
  />

  <!-- ==================== FAQ ==================== -->
  <FAQ items={webDesignHomeServicesFaqs} />

  <!-- ==================== NOT READY TO BOOK ==================== -->
  <NotReadyToBook />
</BaseLayout>
