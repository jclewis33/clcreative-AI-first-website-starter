---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Button from "../components/ui/Button.astro";
import Visual from "../components/ui/Visual.astro";
import ContentWrapper from "../components/ui/ContentWrapper.astro";
import Grid from "../components/ui/Grid.astro";
import FAQ from "../components/sections/FAQ.astro";
import CTASection from "../components/sections/CTASection.astro";
import Modal from "../components/ui/Modal.astro";
import { m2mFaqs } from "../data/faqs";

import heroPortrait from "../assets/m2m-framework/hero-portrait.avif";
import heroLandscape from "../assets/m2m-framework/hero-landscape.avif";
import mostAgenciesImg from "../assets/m2m-framework/most-agencies.avif";
import knowYourMarketImg from "../assets/m2m-framework/know-your-market.avif";
import refineYourMessageImg from "../assets/m2m-framework/refine-your-message.avif";
import generateQualifiedLeadsImg from "../assets/m2m-framework/generate-qualified-leads.avif";
import walkAwayWithImg from "../assets/m2m-framework/walk-away-with.avif";
import m2mWorkbookImg from "../assets/m2m-framework/m2m-workbook.avif";
---

<BaseLayout
  title="The M2M Framework | CL Creative"
  description="Our research-first process for turning unclear positioning into a website that attracts, qualifies, and converts the clients you actually want."
  theme="light"
>
  <!-- Hero -->
  <Section>
    <Layout variant="columns" verticalAlign="stretch">
      <Heading
        data-split-text
        data-prevent-flicker="true"
        slot="col1"
        tag="h1"
        variant="h1"
      >
        Most Websites Are Built Before Anyone Knows What They Should Say
      </Heading>
      <div
        slot="col2"
        class="u-display-flex u-flex-direction-column u-justify-content-end u-gap-5"
      >
        <Text
          data-fade-up
          data-prevent-flicker="true"
          data-delay="0.2"
          variant="large"
        >
          The M2M Framework is our research-first process for turning unclear
          positioning into a website that attracts, qualifies, and converts the
          clients you actually want, before we write a single line of copy or
          design a single page.
        </Text>
        <div
          data-fade-up
          data-prevent-flicker="true"
          data-delay="0.4"
          class="u-button-wrapper"
        >
          <Button href="#m2m-steps" ariaLabel="See how it works"
            >See How It Works</Button
          >
          <Button
            variant="secondary"
            href="#m2m-worksheet"
            ariaLabel="Start with a free market snapshot"
            >Start With a Free M2M Worksheet</Button
          >
        </div>
      </div>
    </Layout>

    <Layout
      data-prevent-flicker="true"
      data-fade-list
      variant="columns"
      ratio="1-3"
    >
      <Visual
        slot="col1"
        src={heroPortrait}
        alt="M2M Framework team discussing strategy"
        ratio="tall"
      />
      <Visual
        slot="col2"
        class="u-padding-top-8"
        src={heroLandscape}
        alt="Designer working on a Webflow site"
        ratio="landscape"
      />
    </Layout>
  </Section>

  <!-- Statement -->
  <Section theme="brand" container="narrow">
    <ContentWrapper align="center">
      <Heading data-prevent-flicker="true" data-split-text maxWidth="30ch">
        Pretty Websites Don't Generate Leads. Clear Messaging Does.
      </Heading>
    </ContentWrapper>
  </Section>

  <!-- Most Agencies -->
  <Section paddingBottom="none">
    <Layout variant="full" verticalAlign="center">
      <Col slot="col1">
        <div data-fade-in class="u-rich-text">
          <p>
            <strong>Here's what happens at most agencies:</strong> you fill out a
            creative brief, pick a few sites you like, and two months later you get
            a beautiful website that looks nothing like the competition — and performs
            exactly like it.
          </p>
          <p>
            No leads. No qualified inquiries. No real movement in the pipeline.
          </p>
          <p>
            The problem isn't the design. <strong
              >The problem is that nobody stopped to answer the question</strong
            > that matters most before the project started: <strong
              >who are we actually trying to reach, and what do they need to
              hear?</strong
            >
          </p>
        </div>
      </Col>
      <Visual
        data-fade-up
        slot="col2"
        src={mostAgenciesImg}
        alt="Person on a laptop browsing a website"
        ratio="landscape"
        transparent
      />
    </Layout>
  </Section>
  <!-- Most Agencies Cont'd -->
  <Section class="u-padding-top-6" paddingTop="none">
    <Heading data-split-text tag="p" variant="h4" maxWidth="30ch">
      When research comes after design, you get a guessing game. When research
      comes first, you get a website with a job.
    </Heading>
  </Section>

  <!-- M2M Framework -->
  <Section
    theme="brand"
    paddingTop="small"
    class="m2m_section"
    id="how-it-works"
  >
    <div class="m2m_watermark" aria-hidden="true">M2M</div>
    <ContentWrapper class="m2m_content">
      <Heading data-fade-in variant="eyebrow" maxWidth="30ch">
        Market to Message Framework
      </Heading>
      <Heading data-split-text tag="h2" maxWidth="22ch">
        Three Steps From Unclear to Unignorable
      </Heading>
      <Text data-fade-in variant="large" maxWidth="60ch">
        M2M stands for Market to Message. It's the process we use on every
        project to make sure the website we build is grounded in research — not
        assumption, not trend, not whatever looked good on Dribbble last week.
      </Text>
    </ContentWrapper>
    <Grid
      data-fade-list
      largeColumns={3}
      mediumColumns={1}
      smallColumns={1}
      rowGap={0}
      class="m2m_grid"
    >
      <div class="m2m_card">
        <span class="m2m_card_number u-font-mono">01</span>
        <Heading tag="h3" variant="h5" marginBottom={0}
          >Know Your Market</Heading
        >
        <Text marginBottom={0}>
          We map your ideal customer profile, with our M2M Workbook, so you know
          their pain points, the words they actually use, and the triggers that
          push them to buy.
        </Text>
      </div>
      <div class="m2m_card">
        <span class="m2m_card_number u-font-mono">02</span>
        <Heading tag="h3" variant="h5" marginBottom={0}
          >Refine Your Message</Heading
        >
        <Text marginBottom={0}>
          We translate that research into positioning, headlines, page
          structure, and calls to action that speak directly to the people you
          want to close.
        </Text>
      </div>
      <div class="m2m_card">
        <span class="m2m_card_number u-font-mono">03</span>
        <Heading tag="h3" variant="h5" marginBottom={0}>Build and Grow</Heading>
        <Text marginBottom={0}>
          We build a website engineered to attract the right prospects, filter
          out the wrong ones, and turn visitors into strategy calls.
        </Text>
      </div>
    </Grid>
  </Section>

  <!-- M2M Steps -->
  <Section id="m2m-steps" paddingBottom="small">
    <Layout variant="columns-reversed" verticalAlign="center">
      <Visual
        data-fade-up
        slot="col1"
        src={knowYourMarketImg}
        alt="Team mapping ideal customer profiles"
        ratio="square"
      />
      <Col slot="col2">
        <Heading data-fade-in variant="eyebrow" accent>Step 1</Heading>
        <Heading data-split-text tag="h3">Know Your Market</Heading>
        <div data-fade-in class="u-rich-text">
          <p>
            We figure out exactly who your website should be talking to, before
            we write a single line of copy.
          </p>
          <ul>
            <li>Who your best clients actually are, in plain language</li>
            <li>
              What they want, what's stopping them, and what they've already
              tried
            </li>
            <li>
              The exact phrases they use to describe their problem and the fix
              they want
            </li>
          </ul>
          <p>
            <strong>What You Get:</strong> A clear picture of the person your site
            needs to win over, in their words, not yours.
          </p>
        </div>
      </Col>
    </Layout>

    <Layout variant="columns" verticalAlign="center" class="u-margin-top-8">
      <Visual
        data-fade-up
        slot="col1"
        src={refineYourMessageImg}
        alt="Strategist refining positioning and messaging"
        ratio="square"
      />
      <Col slot="col2">
        <Heading data-fade-in variant="eyebrow" accent>Step 2</Heading>
        <Heading data-split-text tag="h3">Refine Your Message</Heading>
        <div data-fade-in class="u-rich-text">
          <p>
            We turn that research into a message that actually sounds like you
            and lands with the right buyer.
          </p>
          <ul>
            <li>The real value you create, named in a way clients recognize</li>
            <li>
              Your point of view, your promise, and the one thing every visitor
              should walk away with
            </li>
            <li>
              A one-page reference you can hand to anyone writing about your
              business
            </li>
          </ul>
          <p>
            <strong>What You Get:</strong> A messaging system you'll keep using long
            after the site launches.
          </p>
        </div>
      </Col>
    </Layout>

    <Layout
      variant="columns-reversed"
      verticalAlign="center"
      class="u-margin-top-8"
    >
      <Visual
        data-fade-up
        slot="col1"
        src={generateQualifiedLeadsImg}
        alt="Qualified leads converting through a launched website"
        ratio="square"
      />
      <Col slot="col2">
        <Heading data-fade-in variant="eyebrow" accent>Step 3</Heading>
        <Heading data-split-text tag="h3">Generate Qualified Leads</Heading>
        <div data-fade-in class="u-rich-text">
          <p>
            Now the site goes to work. Every page is built to do the filtering,
            nurturing, and converting for you.
          </p>
          <ul>
            <li>
              One clear next step on every page, so visitors always know what to
              do
            </li>
            <li>
              Copy that pulls in the right fit and turns the wrong fit away
            </li>
            <li>
              Proof and process placed exactly where people start to hesitate
            </li>
          </ul>
          <p>
            <strong>What You Get:</strong> Better leads first, then more of them.
            Calls from people who already know why they want to work with you.
          </p>
        </div>
      </Col>
    </Layout>
  </Section>

  <!-- Walk Away With -->
  <Section padding="none" class="why-work_section">
    <Layout
      columnGap="var(--gap-8)"
      variant="full-reversed"
      verticalAlign="center"
    >
      <Col slot="col1">
        <div class="why-work_content">
          <Heading maxWidth="40ch" data-split-text tag="h2" variant="h3"
            >What You Walk Away With</Heading
          >
          <Text data-fade-in>
            Three deliverables you own. The website is the most visible piece.
            The other two keep working long after launch.
          </Text>
          <div data-fade-list class="why-work_list">
            <div class="why-work_row">
              <p class="why-work_number">01</p>
              <div class="why-work_item_content">
                <Heading tag="h3" variant="h5" maxWidth="60ch" marginBottom={0}>
                  A clear picture of your best client
                </Heading>
                <Text marginBottom={0}>
                  Who they are, what they want, what's holding them back, and
                  the exact words they use, captured in one document you'll pull
                  up for every sales call, ad, and piece of content.
                </Text>
              </div>
            </div>
            <div class="why-work_row">
              <p class="why-work_number">02</p>
              <div class="why-work_item_content">
                <Heading tag="h3" variant="h5" maxWidth="60ch" marginBottom={0}>
                  A one-page playbook for anyone writing about your business
                </Heading>
                <Text marginBottom={0}>
                  The fastest way to bring a freelancer, employee, or contractor
                  up to speed on who you serve and how to talk to them.
                </Text>
              </div>
            </div>
            <div class="why-work_row">
              <p class="why-work_number">03</p>
              <div class="why-work_item_content">
                <Heading tag="h3" variant="h5" maxWidth="60ch" marginBottom={0}>
                  A website built around the person you actually want to reach
                </Heading>
                <Text marginBottom={0}>
                  Designed around your real buyer, written in language they
                  recognize, and built to bring more of them in.
                </Text>
              </div>
            </div>
          </div>
        </div>
      </Col>
      <Visual
        data-fade-up
        radius="none"
        slot="col2"
        src={walkAwayWithImg}
        alt="Team collaborating on M2M Framework deliverables"
        ratio="square"
      />
    </Layout>
  </Section>

  <!-- M2M Worksheet -->
  <Section theme="dark" id="m2m-worksheet">
    <ContentWrapper align="center">
      <Heading data-fade-in variant="eyebrow" accent>Free M2M Worksheet</Heading
      >
      <Heading data-split-text tag="h2" maxWidth="20ch">
        Get clear on your ideal client in 45 minutes
      </Heading>
    </ContentWrapper>

    <Layout variant="columns" verticalAlign="center">
      <Col slot="col1">
        <Text data-fade-in variant="large">
          The same first-pass discovery questions we run with every new client.
          Free, no call required, ready to use this week.
        </Text>
        <Heading maxWidth="none" data-fade-in variant="eyebrow" accent>
          What You'll Work Through
        </Heading>

        <ul class="u-list">
          <li>Who your ideal client actually is, on paper and online</li>
          <li>What they're trying to achieve in the next 6 to 12 months</li>
          <li>What's keeping them stuck and what they've already tried</li>
          <li>The exact words they use, so your copy can mirror them</li>
        </ul>

        <Heading maxWidth="none" data-fade-in variant="eyebrow" accent>
          Why We Give This Away?
        </Heading>
        <div data-fade-in class="u-rich-text">
          <p>
            The hardest part of any messaging project is starting. We'd rather
            hand you a real piece of the framework than gate it behind a sales
            call.
          </p>
          <p>
            If the worksheet is all you need, that's a win. If it surfaces work
            that's bigger than 45 minutes, you'll know where to find us.
          </p>
        </div>
      </Col>
      <Visual
        data-fade-up
        slot="col2"
        src={m2mWorkbookImg}
        alt="M2M Workbook cover"
        ratio="square"
      />
    </Layout>

    <ContentWrapper align="center">
      <div data-fade-in class="u-button-wrapper">
        <Button
          data-modal-trigger="m2m-worksheet-modal"
          ariaLabel="Get the free M2M worksheet"
        >
          Get the Free M2M Worksheet
        </Button>
      </div>
    </ContentWrapper>
  </Section>

  <!--FAQ's -->
  <FAQ items={[...m2mFaqs]} />

  <!-- CTA -->
  <CTASection
    heading="Ready to Stop Guessing and Start Building?"
    text="If your current website was built on assumption instead of research, working with CL Creative is the right next step"
    buttonText="Let's Fix Your Site"
    secondaryButtonText="Get Step 1 Free"
    secondaryButtonHref="#m2m-worksheet"
  />

  <!-- M2M Worksheet Modal -->
  <Modal
    id="m2m-worksheet-modal"
    variant="small"
    ariaLabel="Get the free M2M Worksheet"
  >
    <Heading maxWidth="40ch" variant="h4" tag="h2"
      >Build Your Ideal Client Profile — Free</Heading
    >
    <Text>
      A focused starter from our M2M Framework. About 45 minutes to a clearer
      ICP, sharper messaging, and better-fit leads.
    </Text>
    <Text>
      Delivered as a Notion template you can duplicate to your workspace. We'll
      send the link to your inbox.
    </Text>
    <div class="ml-embedded" data-form="F72MTv"></div>
    <Text maxWidth="none" variant="small" align="center" muted marginBottom={0}>
      No spam. Unsubscribe anytime.
    </Text>
  </Modal>
</BaseLayout>
