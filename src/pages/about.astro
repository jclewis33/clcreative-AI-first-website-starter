---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/ui/Section.astro";
import Layout from "../components/ui/Layout.astro";
import Col from "../components/ui/Col.astro";
import Heading from "../components/ui/Heading.astro";
import Text from "../components/ui/Text.astro";
import Button from "../components/ui/Button.astro";
import Visual from "../components/ui/Visual.astro";
import Overlay from "../components/ui/Overlay.astro";
import ContentWrapper from "../components/ui/ContentWrapper.astro";
import Marquee from "../components/ui/Marquee.astro";

// Section Components
import HowItWorks from "../components/sections/HowItWorks.astro";
import M2MFramework from "../components/sections/M2MFramework.astro";
import WhyWorkWithUs from "../components/sections/WhyWorkWithUs.astro";
import TestimonialShowcase from "../components/sections/TestimonialShowcase.astro";
import CTASection from "../components/sections/CTASection.astro";
import Services from "../components/sections/Services.astro";

// Images

import statsBackground from "../assets/placeholder-6.avif";
import aboutHero from "../assets/about/about-hero-image.avif";
import aboutCasey from "../assets/about/about-casey.webp";

// Styles
import "../styles/pages/about.css";
---

<BaseLayout
  title="About | CL Creative"
  description="Meet the team behind CL Creative. We build conversion-focused websites for growth-stage businesses using strategic positioning, Webflow, and SEO."
  theme="light"
>
  <!-- ==================== HERO ==================== -->
  <Section paddingBottom="none" id="about-hero">
    <Layout variant="stack">
      <Col slot="col1">
        <Heading variant="eyebrow" data-fade-in data-prevent-flicker="true"
          >About Us</Heading
        >
        <Heading
          maxWidth="30ch"
          tag="h1"
          variant="h1"
          data-splittext
          data-prevent-flicker="true"
        >
          We Build Webflow Websites and a Marketing Foundation that Attracts the
          Right Customers and Turns Views into Leads
        </Heading>
        <Text data-fade-up data-prevent-flicker="true">
          Learn more about our agency and how we help you build a website and
          marketing system that will grow your business on purpose rather than
          by accident.
        </Text>
        <div
          class="u-button-wrapper"
          data-fade-up
          data-prevent-flicker="true"
          data-duration="0.6"
        >
          <Button href="/how-we-work" ariaLabel="How We Fix Your Website & Marketing">How We Fix Your Website & Marketing</Button>
        </div>
      </Col>
    </Layout>
    <Visual
      data-prevent-flicker
      data-fade-in
      data-delay="0.6"
      class="about-hero_img"
      ratio="28.80/7.16"
      radius="none"
      src={aboutHero}
      alt="Your team thinking through who your best customer is"
    />
  </Section>

  <!-- ==================== ABOUT US ==================== -->
  <Section theme="light">
    <Layout variant="columns" verticalAlign="start">
      <Col slot="col1">
        <Heading data-fade-in variant="eyebrow">About Us</Heading>
        <Text variant="xlarge">
          Most businesses are just hoping they grow. When they do, it's by
          accident — or it's not sustainable, or at least it doesn't feel
          sustainable.
        </Text>
        <Text maxWidth="90ch">
          That's where I was. I'd grown CL Creative, but not on purpose. I
          couldn't point to what I did. The growth had happened, but I couldn't
          repeat it, and I couldn't shake the feeling it would stop.
        </Text>
        <Text maxWidth="90ch">
          So I built what was missing: a foundation underneath everything. The
          messaging, the website, the content, the tools — all wired together so
          growth wasn't accidental anymore.
        </Text>
        <Text maxWidth="90ch">
          That's the same place I see business owners stuck — two to seven years
          in, doing real revenue, but scared. They've grown, but they can't
          point to what they did. The wins came from one referral, one lucky
          channel, one good month.
        </Text>
        <Text maxWidth="90ch">
          CL Creative builds the foundation underneath, so your business stops
          growing by accident and starts growing in a way you can point to,
          repeat, and trust.
        </Text>
      </Col>
      <Visual
        slot="col2"
        src={aboutCasey}
        alt="Casey Lewis, founder of CL Creative"
      />
    </Layout>
  </Section>
  <!-- M2M Framework Section -->
  <M2MFramework paddingTop="none" paddingBottom="small" />

  <!-- ==================== WHO WE WORK WITH ==================== -->
  <Section gap={3} theme="light">
    <Heading marginBottom={0} variant="eyebrow">Who We Work With</Heading>
    <Layout variant="columns" verticalAlign="start">
      <Heading maxWidth="30ch" slot="col1" tag="h2" variant="h3">
        We Work Best with Growth-Stage Businesses Whose Websites and/or
        Marketing Aren't Bringing in the Leads they Need to Grow
      </Heading>
      <Text slot="col2" variant="large">
        If you have real revenue, real interest, and are closing deals, but
        can't seem to figure out how to sustain the momentum, we should talk.
      </Text>
    </Layout>
    <div class="who-we-work-with_marquees">
      <Marquee speed={25} gap={6} pauseOnHover={false}>
        <span class="marquee_item u-text-style-h3">Consultants</span>
        <span class="marquee_item u-text-style-h3">Real Estate</span>
        <span class="marquee_item u-text-style-h3">Wellness</span>
        <span class="marquee_item u-text-style-h3">Agencies</span>
        <span class="marquee_item u-text-style-h3">SaaS</span>
      </Marquee>
      <Marquee speed={25} gap={6} direction="right" pauseOnHover={false}>
        <span class="marquee_item u-text-style-h3">Non-Profits</span>
        <span class="marquee_item u-text-style-h3">Home Services</span>
        <span class="marquee_item u-text-style-h3">AI Companies</span>
        <span class="marquee_item u-text-style-h3">Financial Services</span>
        <span class="marquee_item u-text-style-h3">Recruiting</span>
      </Marquee>
    </div>
  </Section>

  <!-- ==================== STATEMENT ==================== -->
  <Section theme="brand" container="narrow">
    <ContentWrapper align="center">
      <Heading tag="h2" variant="h1" maxWidth="30ch">
        More Than a Web Design Agency — A Strategic Partner Who Gets Business
      </Heading>
    </ContentWrapper>
  </Section>

  <!-- ==================== STATS ==================== -->
  <Section theme="dark">
    <Layout variant="columns" verticalAlign="start">
      <Col slot="col1">
        <Heading variant="eyebrow">Real Results</Heading>
        <Heading tag="h2" variant="h2">The Numbers Behind the Strategy</Heading>
        <Text size="large">
          These aren't vanity metrics. They're the outcome of research-driven
          design, strategic messaging, and sites built to convert, not just
          impress.
        </Text>
      </Col>
      <div slot="col2" class="stats_list">
        <div class="stats_item">
          <p class="stats_number">530%</p>
          <p class="stats_label">more organic traffic</p>
        </div>
        <div class="stats_item">
          <p class="stats_number">1st month</p>
          <p class="stats_label">enterprise trials secured</p>
        </div>
        <div class="stats_item">
          <p class="stats_number">50+</p>
          <p class="stats_label">SEO pages deployed</p>
        </div>
      </div>
    </Layout>
  </Section>

  <!-- Why Work With Us -->
  <WhyWorkWithUs />

  <!-- Services -->
  <Services />

  <!-- How It Works Section -->
  <HowItWorks />

  <!-- Testimonials Section -->
  <TestimonialShowcase />

  <!-- CTA Section -->
  <CTASection />
</BaseLayout>
