---
/**
 * FormRadio — custom radio button (native input + plain CSS).
 *
 * When the native `<input>` is `:checked`, `.form_ui_item:has(:checked)`
 * styles the border, background, and dot indicator transitions — plain CSS, no variables.
 *
 * All radios in a group share the same `name` — only one can be selected.
 *
 * @example
 * ```astro
 * <div class="u-flex u-flex-wrap u-gap-4">
 *   <FormRadio label="Email" name="contact-method" value="email" checked />
 *   <FormRadio label="Phone" name="contact-method" value="phone" />
 *   <FormRadio label="Text" name="contact-method" value="text" />
 * </div>
 * ```
 */

interface Props {
  /** Label text displayed next to the radio button. */
  label: string;

  /** HTML `name` attribute. All radios in a group share this name. */
  name: string;

  /** Form value for this radio option. */
  value: string;

  /**
   * Whether this radio starts checked.
   * @default false
   */
  checked?: boolean;

  /**
   * Whether the field is required.
   * @default false
   */
  required?: boolean;

  /**
   * Disabled state.
   * @default false
   */
  disabled?: boolean;

  /** HTML `id` attribute. Auto-generated if not provided. */
  id?: string;

  /** Extra classes on the outer `.form_ui_item` wrapper. */
  class?: string;

  /** Catch-all for extra attributes spread onto the `<input>`. */
  [key: string]: any;
}

const {
  label,
  name,
  value,
  checked = false,
  required = false,
  disabled = false,
  id,
  class: className,
  ...rest
} = Astro.props;

const fieldId = id || `field-${name}-${value}`;
---

<div
  class:list={['form_ui_item', className]}
>
  <label class="form_ui_label" for={fieldId}>
    <input
      class="form_ui_input u-sr-only"
      type="radio"
      name={name}
      id={fieldId}
      value={value}
      checked={checked}
      required={required}
      disabled={disabled}
      {...rest}
    />

    <span class="form_ui_visual_wrap is-radio" aria-hidden="true">
      <span class="form_ui_visual_dot"></span>
    </span>

    <span class="form_ui_text">{label}</span>
  </label>
</div>
