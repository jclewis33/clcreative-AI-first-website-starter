---
/**
 * Footer Component
 *
 * Multi-column footer using the grid system.
 *
 * The footer's appearance is controlled by CSS variables in
 * `src/styles/variables/themes.css`:
 *   - `--footer-background` — footer background color
 *   - `--footer-text` — footer text color (cascades to links)
 *   - `--footer-border` — bottom bar divider color
 *
 * Each theme (light, dark, brand) defines its own set of footer
 * variables. To keep the footer dark across all themes, set the
 * same dark values in each theme block (this is the default).
 *
 * STRUCTURE:
 *   footer_wrap
 *     footer_contain u-container
 *       footer_layout u-grid-custom  (12-col grid → stacks at medium)
 *         footer_content              (left: logo + social, spans 4 cols)
 *         footer_links_wrap           (right: link groups, spans 8 cols)
 *           u-grid                     (one column per FOOTER_GROUPS entry)
 *             footer_group_wrap × N
 *     footer_bottom_wrap
 *       footer_bottom_contain u-container
 *         footer_bottom_layout
 *
 * ─── LINK CONTENT IS DATA-DRIVEN ──────────────────────────────────
 * The link columns, the "Locations Served" dropdown, and the bottom-bar
 * legal links all come from the single site-structure registry
 * (`src/data/site-structure.ts`): `FOOTER_GROUPS` and `OPTIONAL_PAGES`.
 * To add/remove a column or link, edit `FOOTER_GROUPS` there — the grid
 * column count below tracks `FOOTER_GROUPS.length` automatically.
 * Labels resolve from each page's `footerLabel` (→ navLabel → title).
 * ──────────────────────────────────────────────────────────────────
 */

import Logo from "./Logo.astro";
import { SITE } from "../../config/site";
import {
  FOOTER_GROUPS,
  OPTIONAL_PAGES,
  footerLabel,
  resolveFooterLink,
} from "../../data/site-structure";

const visibleSocialLinks = SITE.social.filter((link) => link.href !== "#");
---

<footer class="footer_wrap">
  <h2 class="footer_title u-sr-only">Footer</h2>

  <div class="footer_contain u-container">
    <div data-medium-columns="1" class="footer_layout u-grid-custom">
      <!-- ── Left column: Logo + Contact + Social ────────────── -->
      <div class="footer_content">
        <Logo variant="footer" class="footer_logo_wrap" />

        <div class="footer_contact_wrap">
          <a href={`mailto:${SITE.email}`} class="footer_contact_link">
            <div class="footer_contact_item">
              <div class="footer_contact_icon u-icon-24">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <rect
                    x="2"
                    y="4"
                    width="20"
                    height="16"
                    rx="2"
                    stroke="currentColor"
                    stroke-width="var(--border-width-main)"
                    stroke-linecap="round"
                    stroke-linejoin="round"></rect>
                  <path
                    d="M2 7L10.165 12.593C10.6834 12.9515 11.3343 13.1436 12 13.1436C12.6657 13.1436 13.3166 12.9515 13.835 12.593L22 7"
                    stroke="currentColor"
                    stroke-width="var(--border-width-main)"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <span class="footer_contact_text">{SITE.email}</span>
            </div>
          </a>

          <a href={`tel:${SITE.phone.tel}`} class="footer_contact_link">
            <div class="footer_contact_item">
              <div class="footer_contact_icon u-icon-24">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M8.38028 8.85335C9.07627 10.303 10.0251 11.6616 11.2266 12.8632C12.4282 14.0648 13.7869 15.0136 15.2365 15.7096C15.3612 15.7694 15.4235 15.7994 15.5024 15.8224C15.7828 15.9041 16.127 15.8454 16.3644 15.6754C16.4313 15.6275 16.4884 15.5704 16.6027 15.4561C16.9523 15.1064 17.1271 14.9316 17.3029 14.8174C17.9658 14.3864 18.8204 14.3864 19.4833 14.8174C19.6591 14.9316 19.8339 15.1064 20.1835 15.4561L20.3783 15.6509C20.9098 16.1824 21.1755 16.4481 21.3198 16.7335C21.6069 17.301 21.6069 17.9713 21.3198 18.5389C21.1755 18.8242 20.9098 19.09 20.3783 19.6214L20.2207 19.779C19.6911 20.3087 19.4263 20.5735 19.0662 20.7757C18.6667 21.0001 18.0462 21.1615 17.588 21.1601C17.1751 21.1589 16.8928 21.0788 16.3284 20.9186C13.295 20.0576 10.4326 18.4332 8.04466 16.0452C5.65668 13.6572 4.03221 10.7948 3.17124 7.76144C3.01103 7.19699 2.93092 6.91477 2.9297 6.50182C2.92833 6.0436 3.08969 5.42311 3.31411 5.0236C3.51636 4.66357 3.78117 4.39876 4.3108 3.86913L4.46843 3.7115C4.99987 3.18006 5.2656 2.91433 5.55098 2.76999C6.11854 2.48292 6.7888 2.48292 7.35636 2.76999C7.64174 2.91433 7.90747 3.18006 8.43891 3.7115L8.63378 3.90637C8.98338 4.25597 9.15819 4.43078 9.27247 4.60655C9.70347 5.26945 9.70347 6.12403 9.27247 6.78692C9.15819 6.96269 8.98338 7.1375 8.63378 7.4871C8.51947 7.60142 8.46231 7.65857 8.41447 7.72538C8.24446 7.96281 8.18576 8.30707 8.26748 8.58743C8.29048 8.66632 8.32041 8.72866 8.38028 8.85335Z"
                    stroke="currentColor"
                    stroke-width="var(--border-width-main)"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>
              <span class="footer_contact_text">{SITE.phone.display}</span>
            </div>
          </a>

          <div class="footer_contact_item">
            <div class="footer_contact_icon u-icon-24">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="100%"
                height="100%"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <circle
                  cx="12"
                  cy="12"
                  r="10"
                  stroke="currentColor"
                  stroke-width="var(--border-width-main)"
                  stroke-linecap="round"
                  stroke-linejoin="round"></circle>
                <path
                  d="M12 6V12L16 14"
                  stroke="currentColor"
                  stroke-width="var(--border-width-main)"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </div>
            <span class="footer_contact_text">{SITE.hours}</span>
          </div>
        </div>

        <div class="footer_social_wrap">
          <h3 class="footer_social_title u-text-style-h6 u-margin-bottom-4">
            Follow us
          </h3>
          <div role="list" class="footer_social_list">
            {
              visibleSocialLinks.map((link) => (
                <div role="listitem" class="footer_social_item">
                  <a
                    aria-label={link.label}
                    href={link.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="footer_social_link"
                  >
                    <svg
                      viewBox={link.viewBox}
                      aria-hidden="true"
                      class="u-svg"
                    >
                      <Fragment set:html={link.paths} />
                    </svg>
                  </a>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <!-- ── Right columns: Link groups ──────────────────────────
           Every column, link, and the "Locations Served" dropdown below comes
           from FOOTER_GROUPS in src/data/site-structure.ts. To add/remove a
           column or link, edit FOOTER_GROUPS there (NOT this markup) — the grid
           column count tracks FOOTER_GROUPS.length and labels resolve from each
           page's footerLabel (→ title). The Locations dropdown is the `locations`
           field on the Company group (FOOTER_LOCATIONS). -->
      <div class="footer_links_wrap u-gap-row-7">
        <div
          role="navigation"
          data-large-columns={String(FOOTER_GROUPS.length)}
          data-medium-columns="0"
          data-small-columns="2"
          data-xsmall-columns="1"
          class="u-grid"
        >
          {
            FOOTER_GROUPS.map((group) => (
              <section class="footer_group_wrap">
                <h3 class="footer_group_title u-text-style-h6 u-margin-bottom-3">
                  {group.title}
                </h3>
                <div role="list" class="footer_group_list">
                  {group.links.map((link) => {
                    const { label, href } = resolveFooterLink(link);
                    return (
                      <div
                        role="listitem"
                        class="footer_group_item"
                      >
                        <a href={href} class="footer_link_wrap">
                          <div class="footer_link_text u-text-style-small">
                            {label}
                          </div>
                        </a>
                      </div>
                    );
                  })}

                  {group.locations && (
                    <div
                      role="listitem"
                      class="footer_group_item footer_locations_item"
                    >
                      <div class="footer_locations_wrap">
                        <div class="accordion_list" role="list">
                          <div
                            class="accordion_item footer_locations_accordion_item"
                            role="listitem"
                          >
                            <div class="accordion_component">
                              <button
                                class="accordion_toggle_button footer_locations_button"
                                aria-expanded="false"
                                aria-controls="footer-locations-served"
                              >
                                <span class="footer_link_text u-text-style-small">
                                  Locations Served
                                </span>
                                <span
                                  class="accordion_toggle_icon footer_locations_icon"
                                  aria-hidden="true"
                                >
                                  <svg
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                  >
                                    <polyline points="6 9 12 15 18 9" />
                                  </svg>
                                </span>
                              </button>
                              <div
                                class="accordion_content_wrap"
                                id="footer-locations-served"
                                role="region"
                              >
                                <div class="accordion_content_padding footer_locations_panel">
                                  <div
                                    role="list"
                                    class="footer_locations_list"
                                  >
                                    {group.locations.map((path) => (
                                      <div
                                        role="listitem"
                                        class="footer_group_item"
                                      >
                                        <a href={path} class="footer_link_wrap">
                                          <div class="footer_link_text u-text-style-small">
                                            {footerLabel(path)}
                                          </div>
                                        </a>
                                      </div>
                                    ))}
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  )}
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </div>
  </div>

  <!-- ── Bottom bar ────────────────────────────────────────── -->
  <div class="footer_bottom_wrap">
    <div class="footer_bottom_contain u-container">
      <div class="footer_bottom_layout">
        <div class="footer_bottom_text u-text-style-small">
          <span>&copy; </span>
          <span class="footer_year">2026</span>
          <span>&nbsp;Copyright. All Rights Reserved.</span>
        </div>
        {/* Legal links come from the "optional"-group pages in the registry
            (OPTIONAL_PAGES, src/data/site-structure.ts). "Privacy Settings"
            below is a non-page action, so it stays hardcoded here. */}
        <div role="list" class="footer_bottom_list">
          {
            OPTIONAL_PAGES.map((page) => (
              <div
                role="listitem"
                class="footer_bottom_item"
              >
                <a href={page.path} class="footer_bottom_link_wrap">
                  <div class="footer_bottom_link_text u-text-style-small">
                    {footerLabel(page.path)}
                  </div>
                </a>
              </div>
            ))
          }
          <div
            role="listitem"
            class="footer_bottom_item"
          >
            <a
              id="usercentrics-psl"
              href="#"
              class="footer_bottom_link_wrap"
              data-uc-show-second-layer
            >
              <div class="footer_bottom_link_text u-text-style-small">
                Privacy Settings
              </div>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  document.querySelectorAll(".footer_year").forEach((el) => {
    el.textContent = new Date().getFullYear().toString();
  });

  // Open Usercentrics privacy settings (second layer)
  document.querySelectorAll("[data-uc-show-second-layer]").forEach((el) => {
    el.addEventListener("click", (e) => {
      e.preventDefault();
      const UC = (window as any).UC_UI;
      if (UC && typeof UC.showSecondLayer === "function") {
        UC.showSecondLayer();
      }
    });
  });

  // Footer "Locations Served" dropdown — drives the same .accordion_wrap
  // CSS that powers global accordions, but lives inline so it works on
  // every page (the Accordion.astro script only bundles into pages that
  // import it).
  document.querySelectorAll<HTMLElement>(".footer_locations_wrap").forEach((wrap) => {
    const button = wrap.querySelector<HTMLButtonElement>(".accordion_toggle_button");
    if (!button) return;
    button.addEventListener("click", () => {
      const open = button.getAttribute("aria-expanded") === "true";
      button.setAttribute("aria-expanded", open ? "false" : "true");
    });
    // Enable CSS transitions after initial paint so the closed state
    // doesn't animate in on first load.
    requestAnimationFrame(() => {
      requestAnimationFrame(() => wrap.classList.add("is-ready"));
    });
  });
</script>
