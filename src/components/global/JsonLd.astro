---
/**
 * JSON-LD structured data renderer.
 *
 * Serializes a plain object (or array) into a `<script type="application/ld+json">`
 * tag, with `<` escaped to `\u003c` so the payload can't break out of the
 * script element if any field contains `</script>`.
 */

interface Props {
  data: unknown;
}

const { data } = Astro.props;
const json = JSON.stringify(data).replace(/</g, "\\u003c");
---

<script type="application/ld+json" is:inline set:html={json} />
