---
/**
 * RichTextBlock — centered rich text content block.
 *
 * General-purpose block for introductions, conclusions, or any standalone
 * text section. Renders portable text HTML inside a u-rich-text container,
 * centered on the page with a configurable max-width (default 48rem).
 */

interface Props {
  html: string;
  maxWidth?: string;
}

const { html, maxWidth = '48rem' } = Astro.props;
---

<div class="case-study_detail_rich_text_wrap" style={`max-width: ${maxWidth}`} data-fade-in data-prevent-flicker="true">
  <div class="u-rich-text" set:html={html} />
</div>
