---
/**
 * FullWidthImage — case study content block.
 * Renders a single image spanning the full container width.
 */
import type { ImageMetadata } from "astro";
import Visual from "../../ui/Visual.astro";

interface Props {
  image: ImageMetadata | string;
  imageAlt: string;
  aspectRatio?: string;
  transparent?: boolean;
  position?: { x: number; y: number } | "center";
}

const { image, imageAlt, aspectRatio = "wide", transparent, position } = Astro.props;
---

<Visual src={image} alt={imageAlt} ratio={aspectRatio} transparent={transparent} position={position} data-fade-in data-prevent-flicker="true" />
