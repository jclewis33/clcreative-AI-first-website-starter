---
/**
 * SignUpForm — centered card with heading, subtext, and a simple contact form.
 *
 * Renders a rounded card inside a section with a generic form (name, email,
 * message). Wire up submission via client-side JS or a form action.
 *
 * @example Default usage
 * ```astro
 * <SignUpForm />
 * ```
 *
 * @example With anchor id
 * ```astro
 * <SignUpForm id="signup" />
 * ```
 */

import Section from "../ui/Section.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import ContentWrapper from "../ui/ContentWrapper.astro";
import Button from "../ui/Button.astro";
import Form from "../form/Form.astro";
import FormField from "../form/FormField.astro";
import FormTextarea from "../form/FormTextarea.astro";

type PaddingValue = "none" | "small" | "main" | "large" | "page-top";

interface Props {
  /**
   * **SignUpForm props:**
   * - `theme` — 'light' | 'dark' | 'brand' (default 'light')
   * - `padding` / `paddingTop` / `paddingBottom` — section padding
   * - `id` — section id for anchor links
   * - `class` — extra classes
   */
  docs?: string;

  theme?: "light" | "dark" | "brand";
  padding?: PaddingValue;
  paddingTop?: PaddingValue;
  paddingBottom?: PaddingValue;
  id?: string;
  class?: string;
  [key: string]: any;
}

const {
  docs,
  theme = "light",
  padding = "main",
  paddingTop = padding,
  paddingBottom = padding,
  id,
  class: className,
  ...rest
} = Astro.props;
---

<Section
  theme={theme}
  paddingTop={paddingTop}
  paddingBottom={paddingBottom}
  id={id}
  container="narrow"
  class={className}
  {...rest}
>
  <div data-fade-in class="signup_card" data-theme="dark">
    <ContentWrapper align="center">
      <Heading variant="h3">Lorem ipsum dolor sit amet consectetur?</Heading>
      <Text align="center"
        >Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do
        eiusmod tempor incididunt ut labore et dolore magna aliqua.</Text
      >
    </ContentWrapper>

    <Form name="signup" class="signup_form">
      <FormField label="Name" name="name" required />
      <FormField label="Email" name="email" type="email" required />
      <FormTextarea label="Message" name="message" rows={4} />
      <Button type="submit" ariaLabel="Submit">Submit</Button>
    </Form>
  </div>
</Section>
