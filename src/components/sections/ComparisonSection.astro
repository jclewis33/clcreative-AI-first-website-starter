---
/**
 * ComparisonSection â€” "Same Designer Hours. Two Very Different Websites."
 *
 * Side-by-side comparison of a looks-only website vs. a clear-message website.
 * All copy is identical across the location pages, so everything is a default;
 * a page typically only passes `leftImage` + `rightImage`.
 */
import Section from "../ui/Section.astro";
import Layout from "../ui/Layout.astro";
import Col from "../ui/Col.astro";
import Visual from "../ui/Visual.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Button from "../ui/Button.astro";
import ContentWrapper from "../ui/ContentWrapper.astro";

interface Props {
  /**
   * **ComparisonSection props:**
   * - `leftImage` / `rightImage` â€” the two comparison Visuals (required)
   * - `leftAlt` / `rightAlt` â€” alt text (sensible defaults)
   * - `title`, `left*`, `right*`, `buttonText`, `buttonHref` â€” copy overrides
   */
  docs?: string;

  /** Section heading. */
  title?: string;

  /** Left (looks-only) Visual â€” required. */
  leftImage: ImageMetadata | string;
  /** Left Visual alt text. */
  leftAlt?: string;
  /** Left column heading. */
  leftHeading?: string;
  /** Left column tagline. */
  leftTagline?: string;
  /** Left column bullet list. */
  leftItems?: string[];

  /** Right (clear-message) Visual â€” required. */
  rightImage: ImageMetadata | string;
  /** Right Visual alt text. */
  rightAlt?: string;
  /** Right column heading. */
  rightHeading?: string;
  /** Right column tagline. */
  rightTagline?: string;
  /** Right column bullet list. */
  rightItems?: string[];

  /** CTA button label. @default 'Get Started' */
  buttonText?: string;
  /** CTA button link. @default '/contact' */
  buttonHref?: string;

  [key: string]: any;
}

const {
  docs,
  title = "Lorem ipsum dolor sit amet consectetur.",
  leftImage,
  leftAlt = "Comparison option one",
  leftHeading = "Lorem ipsum dolor sit amet",
  leftTagline = "Consectetur adipiscing elit sed do.",
  leftItems = [
    "Lorem ipsum dolor sit amet consectetur adipiscing elit",
    "Sed do eiusmod tempor incididunt ut labore et dolore magna",
    "Ut enim ad minim veniam quis nostrud exercitation ullamco",
  ],
  rightImage,
  rightAlt = "Comparison option two",
  rightHeading = "Duis aute irure dolor in",
  rightTagline = "Reprehenderit in voluptate velit esse.",
  rightItems = [
    "Excepteur sint occaecat cupidatat non proident sunt",
    "In culpa qui officia deserunt mollit anim id est laborum",
    "Sed ut perspiciatis unde omnis iste natus error sit",
    "Voluptatem accusantium doloremque laudantium totam rem",
  ],
  buttonText = "Get Started",
  buttonHref = "/contact",
  ...rest
} = Astro.props;
---

<Section {...rest}>
  <ContentWrapper align="center">
    <Heading data-split-text tag="h2" variant="h2" maxWidth="25ch">
      {title}
    </Heading>
  </ContentWrapper>

  <Layout data-fade-list variant="columns" verticalAlign="center">
    <Visual slot="col1" src={leftImage} alt={leftAlt} ratio="landscape" />
    <Col slot="col2">
      <Heading tag="h3" variant="h3">{leftHeading}</Heading>
      <Text variant="xlarge">{leftTagline}</Text>
      <ul class="u-list">
        {leftItems.map((item) => <li>{item}</li>)}
      </ul>
    </Col>
  </Layout>

  <Layout data-fade-list variant="columns-reversed" verticalAlign="center">
    <Visual slot="col1" src={rightImage} alt={rightAlt} ratio="landscape" />
    <Col slot="col2">
      <Heading tag="h3" variant="h3">{rightHeading}</Heading>
      <Text variant="xlarge">{rightTagline}</Text>
      <ul class="u-list">
        {rightItems.map((item) => <li>{item}</li>)}
      </ul>
    </Col>
  </Layout>

  <ContentWrapper align="center" data-fade-in>
    <div class="u-button-wrapper">
      <Button href={buttonHref} ariaLabel={buttonText}>{buttonText}</Button>
    </div>
  </ContentWrapper>
</Section>
