---
/**
 * WebsiteGrowthPromo — dark "A Website That Helps Your {City} Business Grow on
 * Purpose" section.
 *
 * Centered heading + full-width Visual + a two-column block (a fixed "picture
 * the version of your site…" heading on the left, per-page body prose on the
 * right) + a centered CTA button. The body prose varies per page (and contains
 * inline links), so it's passed via the `body` slot.
 *
 * Slot:
 * - `body` — the right-column paragraphs (Text components, may include links)
 */
import Section from "../ui/Section.astro";
import Layout from "../ui/Layout.astro";
import Col from "../ui/Col.astro";
import Visual from "../ui/Visual.astro";
import Heading from "../ui/Heading.astro";
import Button from "../ui/Button.astro";
import ContentWrapper from "../ui/ContentWrapper.astro";

interface Props {
  /**
   * **WebsiteGrowthPromo props:**
   * - `heading` — section heading (includes the city name)
   * - `image` / `imageAlt` — the full-width Visual
   * - `pictureHeading` — left-column h3 (identical across pages by default)
   * - `buttonText` / `buttonHref` — CTA
   * - Slot `body` — right-column prose
   */
  docs?: string;

  /** Section heading (includes the city name). */
  heading: string;
  /** Full-width Visual source. */
  image: ImageMetadata | string;
  /** Full-width Visual alt text. */
  imageAlt: string;
  /** Left-column heading. */
  pictureHeading?: string;
  /** CTA button label. @default 'Book a Strategy Call' */
  buttonText?: string;
  /** CTA button link. @default '/book-a-call' */
  buttonHref?: string;

  [key: string]: any;
}

const {
  docs,
  heading,
  image,
  imageAlt,
  pictureHeading = "Picture the version of your site where the right customer lands and knows, right away, that they're in the right place.",
  buttonText = "Book a Strategy Call",
  buttonHref = "/book-a-call",
  ...rest
} = Astro.props;
---

<Section theme="dark" {...rest}>
  <ContentWrapper align="center">
    <Heading data-split-text tag="h2" variant="h2" maxWidth="35ch">
      {heading}
    </Heading>
  </ContentWrapper>

  <Visual data-fade-in src={image} alt={imageAlt} ratio="wide" />

  <Layout data-fade-list variant="columns" verticalAlign="start">
    <Heading slot="col1" tag="h3" variant="h4">{pictureHeading}</Heading>
    <Col slot="col2">
      <slot name="body" />
    </Col>
  </Layout>

  <ContentWrapper align="center" data-fade-in>
    <div class="u-button-wrapper">
      <Button href={buttonHref} ariaLabel={buttonText}>{buttonText}</Button>
    </div>
  </ContentWrapper>
</Section>
