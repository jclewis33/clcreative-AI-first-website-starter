/* ═══════════════════════════════════════════════════
   Filter & sort posts
   Use `posts` prop if provided, otherwise fall back to sample data.
   ═══════════════════════════════════════════════════ */

const allPosts = posts ?? samplePosts;
const excludeSet = new Set(excludeSlugs ?? []);
let filtered: BlogPost[] = [];

switch (variant) {
  case "related":
    filtered = allPosts
      .filter((p) => p.categories?.some((c: string) => currentCategories?.map((cc: string) => cc.toLowerCase()).includes(c.toLowerCase())) && p.slug !== currentSlug && !excludeSet.has(p.slug))
      .sort(
        (a, b) =>
          new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime(),
      )
      .slice(0, 3);
    break;

  case "recent":
    filtered = allPosts
      .filter((p) => (currentSlug ? p.slug !== currentSlug : true) && !excludeSet.has(p.slug))
      .sort(
        (a, b) =>
          new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime(),
      )
      .slice(0, 3);
    break;

  case "category":
    filtered = allPosts
      .filter(
        (p) =>
          p.categories?.some((c: string) => c.toLowerCase() === category?.toLowerCase()) &&
          (currentSlug ? p.slug !== currentSlug : true) &&
          !excludeSet.has(p.slug),
      )
      .sort(
        (a, b) =>
          new Date(b.date ?? 0).getTime() - new Date(a.date ?? 0).getTime(),
      )
      .slice(0, 3);
    break;

  case "manual":
    filtered = allPosts
      .filter((p) => (currentSlug ? p.slug !== currentSlug : true))
      .slice(0, 3);
    break;
}

/* ═══════════════════════════════════════════════════
   Resolve heading text
   ═══════════════════════════════════════════════════ */

const hasHeadingSlot = Astro.slots.has("heading");

const defaultHeadings: Record<GridVariant, string> = {
  related: "Related Posts",
  recent: "Recent Posts",
  category: `More in ${(category ?? "")}`,
  manual: "Related Posts",
};

const resolvedHeading = heading ?? defaultHeadings[variant];
const showHeading = hasHeadingSlot || resolvedHeading;
---

{
  filtered.length > 0 && (
    <Section
      theme={theme}
      padding={padding}
      paddingTop={paddingTop}
      paddingBottom={paddingBottom}
      id={id}
      class:list={["blog-post-grid_wrap", className]}
    >
      <Layout docs="" variant="stack" columnGap={columnGap} rowGap={rowGapProp}>
        <Col slot="col1">
          {/* Heading area */}
          {showHeading &&
            (hasHeadingSlot ? (
              <slot name="heading" />
            ) : (
              <>
                {eyebrow && <Heading variant="eyebrow">{eyebrow}</Heading>}
                <Heading tag="h2" variant="h2">
                  {resolvedHeading}
                </Heading>
              </>
            ))}
        </Col>

        {/* Blog card grid — 3 → 2 → 1 responsive */}
        <Grid
          slot="col2"
          largeColumns={3}
          mediumColumns={2}
          smallColumns={1}
          rowGap={6}
        >
          {filtered.map((post) => (
            <BlogCard
              title={post.title}
              description={post.description}
              categories={post.categories}
              href={`/blog/${post.slug}`}
              image={post.image}
              imageAlt={post.imageAlt}
              author={post.author}
              authorAvatar={post.authorAvatar}
              date={post.date}
            />
          ))}
        </Grid>
      </Layout>
    </Section>
  )
}
