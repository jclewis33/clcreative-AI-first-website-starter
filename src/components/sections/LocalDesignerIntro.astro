          stroke-width="var(--border-width-main)"></path>
        <path
          d="M2.66602 3.73268C2.66602 3.35931 2.66602 3.17263 2.73868 3.03002C2.80259 2.90458 2.90458 2.80259 3.03002 2.73868C3.17263 2.66602 3.35931 2.66602 3.73268 2.66602H6.93268C7.30605 2.66602 7.49273 2.66602 7.63534 2.73868C7.76078 2.80259 7.86277 2.90458 7.92669 3.03002C7.99935 3.17263 7.99935 3.35931 7.99935 3.73268V6.93268C7.99935 7.30605 7.99935 7.49273 7.92669 7.63534C7.86277 7.76078 7.76078 7.86277 7.63534 7.92669C7.49273 7.99935 7.30605 7.99935 6.93268 7.99935H3.73268C3.35931 7.99935 3.17263 7.99935 3.03002 7.92669C2.90458 7.86277 2.80259 7.76078 2.73868 7.63534C2.66602 7.49273 2.66602 7.30605 2.66602 6.93268V3.73268Z"
          stroke-width="var(--border-width-main)"></path>
      </svg>
      <Heading maxWidth="40ch" tag="h3" variant="h5" marginBottom={0}
        >Visuals Designed for your ICP</Heading
      >
      <Text variant="regular" marginBottom={0}>
        Images, illustrations, and color choices that signal "this is for you".
      </Text>
    </div>
  </Grid>
</Section>
