---
/**
 * LocalDesignerIntro — "A Web Designer Who's Part of the Community" block.
 *
 * Heading + a two-column intro (prose + portrait) + a two-column M2M block
 * (image + rich text) + a 3-card grid (ICP messaging / conversion structure /
 * visuals). The three cards are identical across the location pages, so they're
 * baked in here. The per-page prose is passed via the `intro` and `m2m` slots.
 *
 * Slots:
 * - `intro` — the intro paragraphs (Text components) shown beside the portrait
 * - `m2m`   — the M2M rich-text content (rendered inside `.u-rich-text`)
 */
import Section from "../ui/Section.astro";
import Layout from "../ui/Layout.astro";
import Col from "../ui/Col.astro";
import Heading from "../ui/Heading.astro";
import Visual from "../ui/Visual.astro";
import Grid from "../ui/Grid.astro";
import Text from "../ui/Text.astro";

// Card styles (.outgrown_grid / .outgrown_card) live in the web-design page CSS.
import "../../styles/pages/web-design.css";

interface Props {
  /**
   * **LocalDesignerIntro props:**
   * - `heading` — main section heading (varies per city)
   * - `portraitImage` / `portraitAlt` — founder portrait
   * - `m2mImage` / `m2mAlt` — M2M Framework image
   * - Slots: `intro` (prose beside portrait), `m2m` (rich text)
   */
  docs?: string;

  /** Main section heading. */
  heading: string;
  /** Founder portrait image. */
  portraitImage: ImageMetadata | string;
  /** Founder portrait alt text. */
  portraitAlt: string;
  /** M2M Framework image. */
  m2mImage: ImageMetadata | string;
  /** M2M Framework image alt text. */
  m2mAlt: string;

  [key: string]: any;
}

const { docs, heading, portraitImage, portraitAlt, m2mImage, m2mAlt, ...rest } =
  Astro.props;
---

<Section theme="dark" {...rest}>
  <Layout variant="stack">
    <Col slot="col1">
      <Heading
        data-split-text
        data-prevent-flicker="true"
        tag="h2"
        variant="h2"
        maxWidth="40ch"
      >
        {heading}
      </Heading>
    </Col>
  </Layout>

  <Layout data-fade-list variant="columns" ratio="4-8" verticalAlign="start">
    <Col slot="col1">
      <slot name="intro" />
    </Col>
    <Visual slot="col2" src={portraitImage} alt={portraitAlt} ratio="3/2" />
  </Layout>

  <Layout data-fade-list variant="columns" ratio="5-7" verticalAlign="center">
    <Visual slot="col1" src={m2mImage} alt={m2mAlt} />
    <div slot="col2" class="u-rich-text">
      <slot name="m2m" />
    </div>
  </Layout>

  <Grid
    data-fade-in
    largeColumns={3}
    mediumColumns={1}
    smallColumns={1}
    rowGap={0}
    class="outgrown_grid"
  >
    <div class="outgrown_card">
      <svg
        class="outgrown_card_icon"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"></path>
        <circle cx="9" cy="7" r="4"></circle>
        <polyline points="16 11 18 13 22 9"></polyline>
      </svg>
      <Heading maxWidth="40ch" tag="h3" variant="h5" marginBottom={0}
        >ICP-Aligned Messaging</Heading
      >
      <Text variant="regular" marginBottom={0}>
        Every headline and CTA speaks to your buyer's actual pain points, not
        generic benefits.
      </Text>
    </div>
    <div class="outgrown_card">
      <svg
        class="outgrown_card_icon"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polygon points="12 2 2 7 12 12 22 7 12 2"></polygon>
        <polyline points="2 17 12 22 22 17"></polyline>
        <polyline points="2 12 12 17 22 12"></polyline>
      </svg>
      <Heading maxWidth="40ch" tag="h3" variant="h5" marginBottom={0}
        >Conversion-Focused Structure</Heading
      >
      <Text variant="regular" marginBottom={0}>
        Page layouts ordered in the way your customer actually makes decisions
        so they know if your product or service solves their problem.
      </Text>
    </div>
    <div class="outgrown_card">
      <svg
        class="outgrown_card_icon"
        aria-hidden="true"
        viewBox="0 0 32 32"
        fill="none"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
