---
/**
 * WhyWorkWithUs — breakout-reversed section with numbered value props.
 *
 * Image bleeds to the left viewport edge, content on the right with
 * an eyebrow, heading, numbered list with dividers, and a CTA button.
 *
 * @example Default usage
 * ```astro
 * <WhyWorkWithUs />
 * ```
 *
 * @example Custom padding and theme
 * ```astro
 * <WhyWorkWithUs theme="dark" padding="large" />
 * ```
 */

import Section from "../ui/Section.astro";
import Layout from "../ui/Layout.astro";
import Col from "../ui/Col.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Visual from "../ui/Visual.astro";
import Button from "../ui/Button.astro";

import whyImage from "../../assets/components/why-work-with-us/why-work-with-us.webp";

type PaddingValue = "none" | "small" | "main" | "large" | "page-top";

interface Props {
  /**
   * **WhyWorkWithUs props:**
   * - `theme` — 'light' | 'dark' | 'brand'
   * - `padding` / `paddingTop` / `paddingBottom` — section padding
   * - `class` — extra classes
   * - Also accepts any HTML attribute
   */
  docs?: string;

  /** Color theme for the section. */
  theme?: "light" | "dark" | "brand";

  /** Section vertical padding. @default 'main' */
  padding?: PaddingValue;
  paddingTop?: PaddingValue;
  paddingBottom?: PaddingValue;

  /** Extra classes on the section. */
  class?: string;

  [key: string]: any;
}

const {
  docs,
  theme,
  padding = "none",
  paddingTop,
  paddingBottom,
  class: className,
  ...rest
} = Astro.props;

const items = [
  {
    number: "01",
    title: "Lorem ipsum dolor sit amet",
    text: "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.",
  },
  {
    number: "02",
    title: "Consectetur adipiscing elit sed",
    text: "Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat duis aute irure dolor in reprehenderit in voluptate velit.",
  },
  {
    number: "03",
    title: "Excepteur sint occaecat cupidatat",
    text: "Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum sed ut perspiciatis unde omnis.",
  },
];
---

<Section
  theme={theme}
  padding={padding}
  paddingTop={paddingTop}
  paddingBottom={paddingBottom}
  class:list={["why-work_section", className]}
  {...rest}
>
  <Layout
    docs=""
    columnGap="var(--gap-8)"
    variant="full-reversed"
    verticalAlign="center"
  >
    <Col slot="col1">
      <div class="why-work_content">
        <Heading data-fade-in variant="eyebrow"> Why Work With Us </Heading>
        <Heading data-split-text variant="h3">
          Lorem ipsum dolor sit amet consectetur adipiscing elit
        </Heading>

        <div class="why-work_list">
          {
            items.map((item) => (
              <div class="why-work_row" data-fade-in>
                <p class="why-work_number">{item.number}</p>
                <div class="why-work_item_content">
                  <Heading
                    maxWidth="none"
                    tag="h3"
                    variant="h5"
                    marginBottom={0}
                  >
                    {item.title}
                  </Heading>
                  <Text marginBottom={0} set:html={item.text} />
                </div>
              </div>
            ))
          }
        </div>

        <div class="u-button-wrapper">
          <Button href="/contact" ariaLabel="Get started">
            Get Started
          </Button>
        </div>
      </div>
    </Col>
    <Visual
      radius="none"
      slot="col2"
      src={whyImage}
      alt="Why work with us"
      ratio="portrait"
    />
  </Layout>
</Section>
