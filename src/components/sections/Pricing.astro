---
/**
 * Pricing — section with two-column intro, checklist, and full-width image.
 *
 * Left column: eyebrow + heading. Right column: body text, check-list items,
 * and a text-link CTA. Full-width image below.
 *
 * @example Default usage
 * ```astro
 * <Pricing />
 * ```
 *
 * @example Custom padding
 * ```astro
 * <Pricing paddingBottom="small" />
 * ```
 */

import Section from "../ui/Section.astro";
import Layout from "../ui/Layout.astro";
import Col from "../ui/Col.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Visual from "../ui/Visual.astro";
import Button from "../ui/Button.astro";
import ContentWrapper from "../ui/ContentWrapper.astro";
import PricingCard from "../ui/PricingCard.astro";
import PricingItem from "../ui/PricingItem.astro";

import afterLaunchImg from "../../assets/placeholder-images/placeholder-5.webp";
import Grid from "../ui/Grid.astro";

type PaddingValue = "none" | "small" | "main" | "large" | "page-top";

interface Props {
  /**
   * **Pricing props:**
   * - `theme` — 'light' | 'dark' | 'brand'
   * - `padding` / `paddingTop` / `paddingBottom` — section padding
   * - `class` — extra classes
   */
  docs?: string;

  theme?: "light" | "dark" | "brand";
  padding?: PaddingValue;
  paddingTop?: PaddingValue;
  paddingBottom?: PaddingValue;
  class?: string;
  [key: string]: any;
}

const {
  docs,
  theme = "brand",
  padding = "main",
  paddingTop = padding,
  paddingBottom = padding,
  class: className,
  ...rest
} = Astro.props;
---

<Section
  theme={theme}
  paddingTop={paddingTop}
  paddingBottom={paddingBottom}
  class={className}
  {...rest}
>
  {/* ---- General pricing card ---- */}
  <Layout verticalAlign="start" variant="columns">
    <Col slot="col1">
      <Heading variant="eyebrow"> Investment</Heading>
      <Heading tag="h3" variant="h2">Lorem ipsum dolor sit amet.</Heading>
      <Text
        >Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua ut enim ad minim
        veniam.</Text
      >
    </Col>
    <Layout rowGap="var(--space-5)" slot="col2" variant="stack">
      <PricingCard
        slot="col1"
        theme="light"
        variant="general"
        price="$5,000"
        priceLabel="Starting at"
        description="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor."
        href="/contact"
        buttonText="Get Started"
        buttonSupportText="Lorem ipsum dolor sit amet, consectetur adipiscing elit."
        itemsLabel="What's Included:"
        class="u-box-shadow-small"
      >
        <PricingItem>Lorem ipsum dolor sit amet consectetur</PricingItem>
        <PricingItem>Adipiscing elit sed do eiusmod tempor</PricingItem>
        <PricingItem>Incididunt ut labore et dolore magna</PricingItem>
        <PricingItem>Ut enim ad minim veniam quis nostrud</PricingItem>
        <PricingItem>Exercitation ullamco laboris nisi</PricingItem>
        <PricingItem>Duis aute irure dolor in reprehenderit</PricingItem>
      </PricingCard>
      <ContentWrapper slot="col2">
        <Text variant="h5">Looking for add-ons?</Text>
        <!-- Add-on cards -->
        <Grid largeColumns={2} mediumColumns={2} smallColumns={1} rowGap={3}>
          <PricingCard
            variant="compact"
            name="Add-on One"
            description="Lorem ipsum dolor sit amet consectetur adipiscing elit."
            href="/contact"
            buttonText="Learn More"
            buttonVariant="text"
            class="u-box-shadow-medium"
          />
          <PricingCard
            variant="compact"
            name="Add-on Two"
            description="Sed do eiusmod tempor incididunt ut labore et dolore."
            href="/contact"
            buttonText="Learn More"
            buttonVariant="text"
            class="u-box-shadow-medium"
          />
          <PricingCard
            variant="compact"
            name="Add-on Three"
            description="Ut enim ad minim veniam quis nostrud exercitation ullamco."
            href="/contact"
            buttonText="Learn More"
            buttonVariant="text"
            class="u-box-shadow-medium"
            style="grid-column: 1 / -1;"
          /></Grid
        >
      </ContentWrapper>
    </Layout>
  </Layout>
</Section>
