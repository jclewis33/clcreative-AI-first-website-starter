---
/**
 * M2MFramework — Market to Message Framework brand section.
 *
 * Orange brand-themed section with watermark, intro copy, and a 3-column
 * numbered card grid explaining the M2M process.
 *
 * All copy has sensible defaults. Override per-section via named slots:
 *   `heading`, `intro`, `card1Body`, `card2Body`, `card3Body`.
 * Card titles, numbers, eyebrow, and CTA stay consistent across the site.
 *
 * @example Default usage
 * ```astro
 * <M2MFramework />
 * ```
 *
 * @example Custom padding (e.g. after a section with no bottom padding)
 * ```astro
 * <M2MFramework paddingTop="none" />
 * ```
 *
 * @example Override heading + intro + card bodies for a specific page
 * ```astro
 * <M2MFramework>
 *   <Fragment slot="heading">Build Quality Doesn't Matter If the Site Says the Wrong Thing</Fragment>
 *   <Fragment slot="intro">
 *     A technically perfect Webflow site that doesn't speak to your ideal
 *     customer is still a broken site.
 *   </Fragment>
 *   <Fragment slot="card2Body">
 *     We turn that research into conversion copy...
 *   </Fragment>
 *   <Fragment slot="card3Body">
 *     We then design and build you a custom <a href="/why-webflow">Webflow site</a>...
 *   </Fragment>
 * </M2MFramework>
 * ```
 */

import Section from "../ui/Section.astro";
import ContentWrapper from "../ui/ContentWrapper.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Grid from "../ui/Grid.astro";
import Button from "../ui/Button.astro";

type PaddingValue = "none" | "small" | "main" | "large" | "page-top";

interface Props {
  /**
   * **M2MFramework props:**
   * - `padding` — sets both paddingTop and paddingBottom (default `'main'`)
   * - `paddingTop` — override top padding only
   * - `paddingBottom` — override bottom padding only
   * - `class` — extra classes on outer Section
   */
  docs?: string;

  /** Sets both paddingTop and paddingBottom @default 'main' */
  padding?: PaddingValue;
  /** Override top padding only */
  paddingTop?: PaddingValue;
  /** Override bottom padding only */
  paddingBottom?: PaddingValue;
  /** Extra classes on the outer Section */
  class?: string;
}

const {
  docs,
  padding = "main",
  paddingTop = padding,
  paddingBottom = padding,
  class: className,
} = Astro.props;
---

<Section
  theme="brand"
  paddingTop={paddingTop}
  paddingBottom={paddingBottom}
  class:list={["m2m_section", className]}
  id="m2m-framework"
>
  <div class="m2m_watermark" aria-hidden="true">M2M</div>
  <ContentWrapper class="m2m_content">
    <Heading data-fade-in variant="eyebrow" maxWidth="30ch">
      Market to Message Framework
    </Heading>
    <Heading data-split-text tag="h3" variant="h2" maxWidth="28ch">
      <slot name="heading"
        >We figure out who you're talking to before designing a single page.</slot
      >
    </Heading>
    <slot name="intro">
      <Text data-fade-in size="regular" maxWidth="60ch">
        Most agencies start with design. We start with your customer.
      </Text>
      <Text data-fade-in size="regular" maxWidth="60ch" marginBottom={0}>
        The Market to Message Framework is how we get from "who is this site
        really for?" to a finished site that speaks directly to them, without
        the guesswork that wrecks most redesigns.
      </Text>
    </slot>
  </ContentWrapper>
  <Grid
    data-fade-list
    largeColumns={3}
    mediumColumns={1}
    smallColumns={1}
    rowGap={0}
    class="m2m_grid"
  >
    <div class="m2m_card">
      <span class="m2m_card_number u-font-mono">01</span>
      <Heading tag="h4" variant="h4" marginBottom={0}>Know Your Market</Heading>
      <Text size="regular">
        <slot name="card1Body"
          >You'll work through our M2M Strategy Workbook to define exactly who
          your ideal customer is and what drives their decisions.</slot
        >
      </Text>
    </div>
    <div class="m2m_card">
      <span class="m2m_card_number u-font-mono">02</span>
      <Heading tag="h4" variant="h4" marginBottom={0}
        >Refine Your Message</Heading
      >
      <Text size="regular">
        <slot name="card2Body"
          >We turn that research into messaging that works everywhere — your
          website, your social posts, your sales conversations, your ads. Your
          customer sees their problem and your solution. They know you're the
          right fit.</slot
        >
      </Text>
    </div>
    <div class="m2m_card">
      <span class="m2m_card_number u-font-mono">03</span>
      <Heading tag="h4" variant="h4" marginBottom={0}>Build and Grow</Heading>
      <Text size="regular">
        <slot name="card3Body"
          >We then design and build you a custom <a href="/why-webflow"
            >Webflow site</a
          > and marketing foundation so that everything works together on day one.
          Then we work with you to grow your business.</slot
        >
      </Text>
    </div>
  </Grid>

  <ContentWrapper align="center">
    <div class="u-button-wrapper" data-fade-in>
      <Button
        href="/m2m-framework"
        ariaLabel="Learn more about the M2M Framework"
      >
        Learn More About the M2M Framework
      </Button>
    </div>
  </ContentWrapper>
</Section>
