---
/**
 * ImagePromo — brand-themed promo card pairing copy with an image.
 *
 * A flexible two-column promo: heading + body + CTA on one side, image on the
 * other. Renders as a filled `contain` card by default, or a `columns` layout
 * when `imageRatio` is provided.
 *
 * @example Default usage
 * ```astro
 * <ImagePromo />
 * ```
 */

import Section from "../ui/Section.astro";
import Layout from "../ui/Layout.astro";
import Col from "../ui/Col.astro";
import Heading from "../ui/Heading.astro";
import Text from "../ui/Text.astro";
import Visual from "../ui/Visual.astro";
import Button from "../ui/Button.astro";

import promoImg from "../../assets/placeholder-images/placeholder-3.webp";

type PaddingValue = "none" | "small" | "main" | "large" | "page-top";

interface Props {
  /**
   * **ImagePromo props:**
   * - `padding` / `paddingTop` / `paddingBottom` — section padding
   * - `heading` — override the section heading
   * - `image` — override the promo image
   * - `imageAlt` — alt text for the promo image
   * - `imageRatio` — when set, renders a contained `columns` layout at this ratio
   * - `class` — extra classes on outer Section
   */
  docs?: string;

  padding?: PaddingValue;
  paddingTop?: PaddingValue;
  paddingBottom?: PaddingValue;
  /** Override the section heading. */
  heading?: string;
  /** Override the promo image. */
  image?: ImageMetadata | string;
  /** Alt text for the promo image. */
  imageAlt?: string;
  /**
   * When provided, the image renders as a contained `columns` layout at this
   * aspect ratio (e.g. `'3/2'`, `'landscape'`) instead of the default filled
   * `contain` card.
   */
  imageRatio?: string;
  /** Extra classes on the outer Section */
  class?: string;
  [key: string]: any;
}

const {
  docs,
  class: className,
  heading = "Lorem ipsum dolor sit amet consectetur adipiscing elit",
  image = promoImg,
  imageAlt = "Placeholder promo image",
  imageRatio,
  ...rest
} = Astro.props;
---

<Section theme="brand" class={className} {...rest}>
  <Layout variant={imageRatio ? "columns" : "contain"} verticalAlign="center">
    <Col slot="col1">
      <Heading data-fade-in variant="eyebrow">Lorem ipsum</Heading>
      <Heading data-split-text tag="h2" variant="h3">
        {heading}
      </Heading>
      <Text data-fade-in variant="large">
        Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod
        tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim
        veniam, quis nostrud exercitation.
      </Text>
      <Text data-fade-in>
        Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua ut
        enim ad minim veniam.
      </Text>
      <div data-fade-in class="u-button-wrapper">
        <Button variant="secondary" href="/contact" ariaLabel="Learn more">
          Learn More
        </Button>
      </div>
    </Col>
    <Visual slot="col2" src={image} alt={imageAlt} ratio={imageRatio} />
  </Layout>
</Section>
