# Dynamic 301 redirects from the old Webflow URL structure to new Astro routes.
# Handled at the Cloudflare edge before the worker runs. Static (one-to-one)
# redirects live in `astro.config.mjs` under `redirects`.
#
# Format: <source pattern> <destination> <status>
# `:splat` captures the wildcard match.

# Case study path: singular → plural (preserves slug)
/case-study/* /case-studies/:splat 301

# Blog category structure change (preserves category)
/category/* /blog/category/:splat 301

# Old portfolio CMS items — collapse to case studies index
/portfolio/* /case-studies 301

# Discontinued local SEO landing pages (20 cities × 2 services)
# Cities with a new dedicated landing page take precedence over the wildcard.
/location/web-design-midlothian /web-design-midlothian 301
/location/web-design-waxahachie /web-design-waxahachie 301
/location/web-design-dallas /web-design-dallas 301
/location/* /services/web-design 301
/seo/* /services/seo 301
