# Wildcard / splat 301 redirects, handled at the Cloudflare edge before the
# worker runs. Empty by default — a new project starts with no redirects.
# Static one-to-one redirects live in `astro.config.mjs` under `redirects`.
#
# Format: <source pattern> <destination> <status>
# `:splat` captures the wildcard match. Example:
#   /old-blog/* /blog/:splat 301
