# ─────────────────────────────────────────────────────────────────────────
# Non-secret site identity (name, URL, email, phone, socials, Sanity ids) is
# centralized in src/config/site.ts — edit that first when re-skinning. The
# values below are the deploy-time/build-time env inputs only.
#
# The public (non-secret) vars must ALSO be set in Cloudflare wrangler.jsonc
# `vars`. The SANITY_API_READ_TOKEN must be a Cloudflare ENCRYPTED secret —
# never a plain wrangler var.
# ─────────────────────────────────────────────────────────────────────────

# Site URL (must match astro.config.mjs `site` value and SITE.url in site.ts)
SITE_URL=https://www.example.com

# Sanity CMS — public config (also set in Cloudflare wrangler.jsonc `vars`).
# Mirrors SITE.sanity in src/config/site.ts. astro.config.mjs carries a
# hardcoded fallback for CI (Cloudflare Workers Builds has no .env at config
# load), so a build still succeeds if these are blank — but set them locally.
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Sanity Viewer token — required in every environment. Used by
# /api/draft-mode/enable to validate Presentation preview URLs, and by
# loadQuery when the sanity-preview-mode cookie is set. Public visitors never
# trigger token use (the cookie is only set via the authenticated Studio →
# Presentation flow). Store as an encrypted Cloudflare secret — never a plain
# wrangler var. Generate at https://www.sanity.io/manage → API → Tokens with
# the Viewer role.
SANITY_API_READ_TOKEN=

# Analytics (uncomment and add your tracking ID)
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ─────────────────────────────────────────────────────────────────────────
# Scorecard email / lead-capture (OPTIONAL) — only needed if you keep the
# /marketing-scorecard funnel and want it to send emails + add subscribers.
# Read at runtime by src/pages/api/scorecard.ts. The site builds and runs
# fine without these (the scorecard just won't send mail). In production set
# them as Cloudflare secrets/vars — see docs/new-project-checklist.md §6.
# ─────────────────────────────────────────────────────────────────────────
# Resend (transactional email) — https://resend.com → API Keys
# RESEND_API_KEY=
# From address for scorecard emails (must be on a Resend-verified domain)
# RESEND_FROM=Your Company Scorecard <scorecard@example.com>
# Where the admin notification copy is sent
# NOTIFICATION_EMAIL=you@example.com
# MailerLite (add the lead to a group) — https://dashboard.mailerlite.com → Integrations → API
# MAILERLITE_API_KEY=
# MAILERLITE_GROUP_ID=
